    text-align: center;
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--text-light);
    font-weight: 500;
  }
  .footer-note a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }
  .footer-note a:hover {
    color: var(--accent);
  }

  @keyframes subtlePulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.35);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(249, 115, 22, 0);
    }
  }
  .pulse-once {
    animation: subtlePulse 1.2s ease-out 1;
  }
</style>

<script>
  // ROI Calculator Logic
  const formatINR = (value) =>
    new Intl.NumberFormat("en-IN", {
      style: "currency",
      currency: "INR",
      maximumFractionDigits: 0,
    }).format(value);

  const purchasePriceInput = document.getElementById("purchasePrice");
  const monthlyRentInput = document.getElementById("monthlyRent");
  const annualMaintenanceInput = document.getElementById("annualMaintenance");
  const appreciationInput = document.getElementById("appreciation");
  const purchasePriceSlider = document.getElementById("purchasePriceSlider");
  const monthlyRentSlider = document.getElementById("monthlyRentSlider");
  const annualMaintenanceSlider = document.getElementById(
    "annualMaintenanceSlider",
  );
  const appreciationSlider = document.getElementById("appreciationSlider");
  const roiButton = document.getElementById("roiCalcBtn");
  const roiResetBtn = document.getElementById("roiResetBtn");
  const roiResult = document.getElementById("roiResult");
  const netAnnualIncomeText = document.getElementById("netAnnualIncomeText");
  const totalAnnualReturnText = document.getElementById(
    "totalAnnualReturnText",
  );
  const annualRoiText = document.getElementById("annualRoiText");
  const incomeBar = document.getElementById("incomeBar");
  const appreciationBar = document.getElementById("appreciationBar");
  const legendIncome = document.getElementById("legendIncome");
  const legendAppreciation = document.getElementById("legendAppreciation");
  const quickPriceChips = document.getElementById("quickPriceChips");

  const syncNumberToSlider = (num, slider, isFloat) => {
    const val = parseFloat(num.value);
    if (
      !isNaN(val) &&
      val >= parseFloat(slider.min) &&
      val <= parseFloat(slider.max)
    ) {
      slider.value = isFloat ? val.toFixed(1) : val;
    }
  };
  const syncSliderToNumber = (slider, num, isFloat) => {
    num.value = isFloat ? parseFloat(slider.value).toFixed(2) : slider.value;
  };

  const highlightPriceChip = (price) => {
    quickPriceChips.querySelectorAll(".chip").forEach((chip) => {
      chip.classList.toggle(
        "active",
        parseInt(chip.dataset.price, 10) === price,
      );
    });
  };

  const calculateROI = () => {
    const purchasePrice = parseFloat(purchasePriceInput.value) || 0;
    const monthlyRent = parseFloat(monthlyRentInput.value) || 0;
    const annualMaintenance = parseFloat(annualMaintenanceInput.value) || 0;
    const appreciation = parseFloat(appreciationInput.value) || 0;

    if (purchasePrice <= 0) {
      roiResult.classList.remove("visible");
      return;
    }

    const annualRent = monthlyRent * 12;
    const netAnnualIncome = annualRent - annualMaintenance;
    const appreciationGain = (purchasePrice * appreciation) / 100;
    const totalAnnualReturn = netAnnualIncome + appreciationGain;
    const annualRoi = (totalAnnualReturn / purchasePrice) * 100;

    netAnnualIncomeText.textContent = formatINR(netAnnualIncome);
    totalAnnualReturnText.textContent = formatINR(totalAnnualReturn);
    annualRoiText.textContent = annualRoi.toFixed(2) + "%";

    // Visual breakdown: net income vs appreciation gain proportions
    const totalForBar = Math.abs(netAnnualIncome) + Math.abs(appreciationGain);
    if (totalForBar > 0) {
      const incomePct = (netAnnualIncome / totalForBar) * 100;
      const appPct = (appreciationGain / totalForBar) * 100;
      incomeBar.style.width = incomePct + "%";
      appreciationBar.style.width = appPct + "%";
      legendIncome.textContent = Math.round(incomePct) + "%";
      legendAppreciation.textContent = Math.round(appPct) + "%";
    } else {
      incomeBar.style.width = "50%";
      appreciationBar.style.width = "50%";
      legendIncome.textContent = "0%";
      legendAppreciation.textContent = "0%";
    }

    roiResult.classList.add("visible");
    roiResult.classList.remove("pulse-once");
    void roiResult.offsetWidth;
    roiResult.classList.add("pulse-once");
  };

  const debounce = (fn, delay) => {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  };
  const debouncedCalculate = debounce(calculateROI, 300);

  // Input events
  purchasePriceInput.addEventListener("input", () => {
    syncNumberToSlider(purchasePriceInput, purchasePriceSlider, false);
    highlightPriceChip(parseInt(purchasePriceInput.value, 10));
    debouncedCalculate();
  });
  monthlyRentInput.addEventListener("input", () => {
    syncNumberToSlider(monthlyRentInput, monthlyRentSlider, false);
    debouncedCalculate();
  });
  annualMaintenanceInput.addEventListener("input", () => {
    syncNumberToSlider(annualMaintenanceInput, annualMaintenanceSlider, false);
    debouncedCalculate();
  });
  appreciationInput.addEventListener("input", () => {
    syncNumberToSlider(appreciationInput, appreciationSlider, true);
    debouncedCalculate();
  });

  purchasePriceSlider.addEventListener("input", () => {
    syncSliderToNumber(purchasePriceSlider, purchasePriceInput, false);
    highlightPriceChip(parseInt(purchasePriceInput.value, 10));
    debouncedCalculate();
  });
  monthlyRentSlider.addEventListener("input", () => {
    syncSliderToNumber(monthlyRentSlider, monthlyRentInput, false);
    debouncedCalculate();
  });
  annualMaintenanceSlider.addEventListener("input", () => {
    syncSliderToNumber(annualMaintenanceSlider, annualMaintenanceInput, false);
    debouncedCalculate();
  });
  appreciationSlider.addEventListener("input", () => {
    syncSliderToNumber(appreciationSlider, appreciationInput, true);
    debouncedCalculate();
  });

  roiButton.addEventListener("click", () => {
    syncNumberToSlider(purchasePriceInput, purchasePriceSlider, false);
    syncNumberToSlider(monthlyRentInput, monthlyRentSlider, false);
    syncNumberToSlider(annualMaintenanceInput, annualMaintenanceSlider, false);
    syncNumberToSlider(appreciationInput, appreciationSlider, true);
    highlightPriceChip(parseInt(purchasePriceInput.value, 10));
    calculateROI();
    if (window.innerWidth < 768 && roiResult.classList.contains("visible")) {
      roiResult.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  });

  roiResetBtn.addEventListener("click", () => {
    purchasePriceInput.value = 7500000;
    monthlyRentInput.value = 30000;
    annualMaintenanceInput.value = 60000;
    appreciationInput.value = 5;
    purchasePriceSlider.value = 7500000;
    monthlyRentSlider.value = 30000;
    annualMaintenanceSlider.value = 60000;
    appreciationSlider.value = 5;
    highlightPriceChip(7500000);
    calculateROI();
  });

  quickPriceChips.addEventListener("click", (e) => {
    const chip = e.target.closest(".chip");
    if (!chip) return;
    const price = parseInt(chip.dataset.price, 10);
    purchasePriceInput.value = price;
    purchasePriceSlider.value = price;
    highlightPriceChip(price);
    calculateROI();
  });

  // Initial calculation
  calculateROI();
  highlightPriceChip(7500000);
</script>
