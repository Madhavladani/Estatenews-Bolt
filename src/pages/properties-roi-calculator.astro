  .info-banner {
    margin-top: 1.5rem;
    background: var(--primary-lightest);
    border: 1px solid var(--primary-lighter);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: flex-start;
