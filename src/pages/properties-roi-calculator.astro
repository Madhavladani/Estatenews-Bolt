---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Properties ROI Calculator | PropDiscover"
  description="Calculate expected return on investment for your property with PropDiscover's simple ROI calculator."
>
  <section class="py-14 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Properties ROI Calculator</h1>
      <p class="text-gray-600 mb-8">Estimate annual ROI and monthly rental yield for your property investment.</p>
      <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="text-sm text-gray-700">Property Purchase Price (INR)
            <input id="purchasePrice" type="number" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" placeholder="e.g. 7500000" />
          </label>
          <label class="text-sm text-gray-700">Monthly Rental Income (INR)
            <input id="monthlyRent" type="number" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" placeholder="e.g. 25000" />
          </label>
          <label class="text-sm text-gray-700">Annual Maintenance Cost (INR)
            <input id="annualMaintenance" type="number" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" placeholder="e.g. 60000" />
          </label>
          <label class="text-sm text-gray-700">Annual Property Appreciation (%)
            <input id="appreciation" type="number" step="0.1" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2" placeholder="e.g. 5" />
          </label>
        </div>
        <button id="roiCalcBtn" class="mt-6 px-5 py-2.5 bg-primary-700 hover:bg-primary-800 text-white rounded-lg text-sm font-semibold">Calculate ROI</button>
        <div id="roiResult" class="mt-6 hidden rounded-xl bg-primary-50 border border-primary-100 p-5">
          <p class="text-sm text-gray-600">Net Annual Income</p>
          <p id="netAnnualIncomeText" class="text-xl font-bold text-primary-800"></p>
          <p class="mt-3 text-sm text-gray-600">Total Annual Return (Income + Appreciation)</p>
          <p id="totalAnnualReturnText" class="text-xl font-bold text-primary-800"></p>
          <p class="mt-3 text-sm text-gray-600">Estimated Annual ROI</p>
          <p id="annualRoiText" class="text-2xl font-bold text-green-700"></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const formatINR = (value: number) =>
    new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(value);

  const roiButton = document.getElementById('roiCalcBtn');
  const roiResult = document.getElementById('roiResult');
  const netAnnualIncomeText = document.getElementById('netAnnualIncomeText');
  const totalAnnualReturnText = document.getElementById('totalAnnualReturnText');
  const annualRoiText = document.getElementById('annualRoiText');

  roiButton?.addEventListener('click', () => {
    const purchasePrice = Number((document.getElementById('purchasePrice') as HTMLInputElement)?.value || 0);
    const monthlyRent = Number((document.getElementById('monthlyRent') as HTMLInputElement)?.value || 0);
    const annualMaintenance = Number((document.getElementById('annualMaintenance') as HTMLInputElement)?.value || 0);
    const appreciation = Number((document.getElementById('appreciation') as HTMLInputElement)?.value || 0);

    if (purchasePrice <= 0) return;

    const annualRent = monthlyRent * 12;
    const netAnnualIncome = annualRent - annualMaintenance;
    const appreciationGain = (purchasePrice * appreciation) / 100;
    const totalAnnualReturn = netAnnualIncome + appreciationGain;
    const annualRoi = (totalAnnualReturn / purchasePrice) * 100;

    if (netAnnualIncomeText && totalAnnualReturnText && annualRoiText && roiResult) {
      netAnnualIncomeText.textContent = formatINR(netAnnualIncome);
      totalAnnualReturnText.textContent = formatINR(totalAnnualReturn);
      annualRoiText.textContent = `${annualRoi.toFixed(2)}%`;
      roiResult.classList.remove('hidden');
    }
  });
</script>
