    margin-bottom: 0.3rem;
    letter-spacing: -0.02em;
  }
  .faq-subtitle {
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 1.5rem;
  }
  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
