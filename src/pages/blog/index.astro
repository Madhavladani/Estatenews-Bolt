---
export const prerender = false;
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogNavigation from "../../components/BlogNavigation.astro";
import FeaturedBlogCard from "../../components/FeaturedBlogCard.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import BlogCard from "../../components/BlogCard.astro";
import BlogSectionHeader from "../../components/BlogSectionHeader.astro";
import BlogHubHeader from "../../components/BlogHubHeader.astro";
import { supabase } from "../../lib/supabase";
import type {
  Blog,
  City,
  BlogCategory,
  BlogSubCategory,
} from "../../lib/types";

// Fetch all published articles
const { data: articlesData } = await supabase
  .from("news")
  .select("*, author:authors(*)")
  .eq("is_published", true)
  .order("published_at", { ascending: false });

const articles: Blog[] = articlesData || [];

// Fetch cities for city-based section
const { data: citiesData } = await supabase
  .from("cities")
  .select("id, name, slug")
  .limit(10);
const cities: City[] = citiesData || [];

// Fetch Categories & Sub-categories
const { data: dbCategories } = await supabase
  .from("blog_categories")
  .select("*");
const { data: dbSubCategories } = await supabase
  .from("blog_sub_categories")
  .select("*");
const categories = (dbCategories || []) as BlogCategory[];
const subCategories = (dbSubCategories || []) as BlogSubCategory[];

// Helper to filter articles by category name or ID
const filterByCategory = (catName: string) => {
  const cat = categories.find((c: BlogCategory) => c.name === catName);
  return articles.filter(
    (a: Blog) => a.category_id === cat?.id || a.category === catName,
  );
};

// Group articles by category for sections
const lifestyleArticles = filterByCategory("Lifestyle").slice(0, 4);
const policiesArticles = filterByCategory("Policies").slice(0, 3);
const financeArticles = filterByCategory("Finance & Legal").slice(0, 4);
const researchArticles = filterByCategory("Research").slice(0, 3);
const cityNewsArticles = filterByCategory("City News").slice(0, 4);
const realtyArticles = filterByCategory("Realty Bytes").slice(0, 4);

// Featured Hero Article (most recent)
const heroArticle = articles[0];
const heroSideArticles = articles.slice(1, 4);

// Highlights / Main Categories (Dynamic from Sub-categories)
const mainCategories = subCategories
  .filter((s: BlogSubCategory) => s.show_in_scroller)
  .map((s: BlogSubCategory) => {
    const cat = categories.find((c: BlogCategory) => c.id === s.category_id);
    if (!cat) return null;
    return {
      name: s.name,
      count: articles.filter(
        (a: Blog) => a.sub_category_id === s.id || a.sub_category === s.name,
      ).length,
      image:
        s.image_url ||
        "https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=400",
      href: `/blog/${cat.slug}/${s.slug}/`,
    };
  })
  .filter((c): c is NonNullable<typeof c> => c !== null);
---

<BaseLayout
  title="Real Estate Blog Gujarat - Latest News & Insights | Home Nesto"
  description="Stay updated with the latest real estate news, analysis, and property market trends in Gujarat. Expert insights on RERA, home decor, and financial planning."
  canonical="https://homenesto.com/blog/"
>
  <BlogNavigation />

  <main class="bg-gray-50 pb-20">
    <BlogHubHeader />

    <!-- ── Hero Section ── -->
    <section class="py-10 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          {
            heroArticle && (
              <div class="lg:col-span-2">
                <FeaturedBlogCard article={heroArticle} />
              </div>
            )
          }
          <div class="space-y-6">
            <h3 class="text-xl font-bold border-l-4 border-[#f97316] pl-3 mb-6">
              Trending Stories
            </h3>
            {
              heroSideArticles.map((article) => (
                <a href={`/blog/${article.slug}/`} class="flex gap-4 group">
                  <div class="w-24 h-24 flex-none rounded-lg overflow-hidden">
                    <img
                      src={article.featured_image}
                      alt={article.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      width="96"
                      height="96"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="flex-1">
                    <span class="text-[10px] uppercase font-bold text-[#f97316] tracking-wider inline-block mb-1">
                      {article.sub_category || article.category}
                    </span>
                    <h4 class="text-sm font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-tight">
                      {article.title}
                    </h4>
                    <div class="mt-2 text-[10px] text-gray-400 font-medium whitespace-nowrap">
                      {new Date(article.published_at).toLocaleDateString(
                        "en-IN",
                        { day: "2-digit", month: "short", year: "numeric" },
                      )}
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ── Category Scroller ── -->
    <section class="py-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex items-center gap-6 overflow-x-auto no-scrollbar pb-4 -mx-4 px-4 sm:mx-0 sm:px-0"
        >
          {mainCategories.map((cat: any) => <CategoryCard {...cat} />)}
          <div class="flex-none pr-4 sm:pr-0"></div>
        </div>
      </div>
    </section>

    <!-- ── Make Your House a Home (Lifestyle) ── -->
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BlogSectionHeader
          title="Make Your House a Home"
          href="/blog/lifestyle/"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {lifestyleArticles.map((article) => <BlogCard article={article} />)}
        </div>
      </div>
    </section>

    <!-- ── Home Improvement Tips (Grid + Featured) ── -->
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BlogSectionHeader
          title="Home Improvement Tips from Experts"
          href="/blog/lifestyle/"
        />
        <div
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 lg:grid-rows-2 gap-8 h-auto lg:h-[600px]"
        >
          {
            lifestyleArticles.slice(0, 4).map((article, i) => (
              <a
                href={`/blog/${article.slug}`}
                class:list={[
                  "relative group rounded-2xl overflow-hidden shadow-lg",
                  i === 0 ? "md:row-span-2 md:col-span-2" : "",
                ]}
              >
                <img
                  src={article.featured_image}
                  alt={article.title}
                  class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  width="1200"
                  height="675"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />
                <div class="absolute bottom-0 p-6 w-full">
                  <span class="text-xs font-bold text-orange-400 uppercase tracking-widest mb-2 inline-block">
                    Experts Choice
                  </span>
                  <h3
                    class:list={[
                      "font-extrabold text-white group-hover:text-orange-300 transition-colors leading-tight",
                      i === 0 ? "text-2xl md:text-3xl" : "text-lg",
                    ]}
                  >
                    {article.title}
                  </h3>
                  <div class="mt-4 text-xs text-gray-300 font-medium">
                    {article.author?.full_name || article.author_name} •{" "}
                    {new Date(article.published_at).toLocaleDateString("en-IN")}
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Updates in Policie
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BlogSectionHeader title="Updates in Policies" href="/blog/policies/" />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
          <div class="lg:col-span-2">
            <div class="space-y-10">
              {
                policiesArticles.map((article) => (
                  <div class="flex flex-col md:flex-row gap-6 group">
                    <a
                      href={`/blog/${article.slug}/`}
                      class="md:w-1/3 aspect-video rounded-xl overflow-hidden shadow-md flex-none"
                    >
                      <img
                        src={article.featured_image}
                        alt={article.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        width="800"
                        height="450"
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                    <div class="flex-1 flex flex-col justify-center">
                      <span class="text-[10px] uppercase font-bold text-[#f97316] tracking-wider mb-2">
                        Policy Update
                      </span>
                      <a
                        href={`/blog/${article.slug}/`}
                        class="group-hover:text-orange-600 transition-colors"
                      >
                        <h3 class="text-xl font-extrabold text-gray-900 leading-tight mb-3">
                          {article.title}
                        </h3>
                      </a>
                      <p class="text-sm text-gray-500 line-clamp-2 md:line-clamp-3 mb-4">
                        {article.excerpt}
                      </p>
                      <div class="mt-auto text-[11px] text-gray-400 font-medium">
                        {new Date(article.published_at).toLocaleDateString(
                          "en-IN",
                          { day: "2-digit", month: "short", year: "numeric" },
                        )}{" "}
                        • By {article.author?.full_name || article.author_name}
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <div
            class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100"
          >
            <h3 class="text-lg font-bold border-l-4 border-[#f97316] pl-3 mb-6">
              Popular in Policies
            </h3>
            <div class="space-y-6">
              {
                policiesArticles.map((article, i) => (
                  <div class="flex gap-4 group">
                    <span class="text-3xl font-black text-gray-100 group-hover:text-orange-500/10 transition-colors">
                      0{i + 1}
                    </span>
                    <div class="flex-1">
                      <a
                        href={`/blog/${article.slug}/`}
                        class="text-sm font-bold text-gray-900 group-hover:text-orange-600 line-clamp-2 leading-snug"
                      >
                        {article.title}
                      </a>
                      <div class="mt-1 text-[10px] text-gray-400">
                        {new Date(article.published_at).toLocaleDateString()}
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  -->

    <!-- ── Real Estate Tips (Video/Standard Cards) ── -->
    <section class="py-12 bg-gray-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex items-center justify-between mb-10 border-l-4 border-[#f97316] pl-4 py-1"
        >
          <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">
            Interior Tips from Experts
          </h2>
          <a
            href="/blog/"
            class="text-sm font-semibold text-gray-400 hover:text-orange-500 uppercase tracking-widest"
            >Explore More →</a
          >
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {
            articles.slice(10, 14).map((article) => (
              <a href={`/blog/${article.slug}/`} class="group">
                <div class="relative aspect-video rounded-xl overflow-hidden mb-4 shadow-2xl">
                  <img
                    src={article.featured_image}
                    alt={article.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                    width="800"
                    height="450"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors" />
                  <div class="absolute inset-x-0 bottom-0 p-4 bg-gradient-to-t from-black/80 to-transparent">
                    <span class="inline-flex items-center gap-1.5 text-[9px] font-bold uppercase tracking-widest text-orange-500">
                      <svg
                        class="w-3 h-3"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                      >
                        <path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" />
                      </svg>
                      Expert Video
                    </span>
                  </div>
                </div>
                <h4 class="text-base font-bold group-hover:text-orange-500 transition-colors line-clamp-2 leading-tight">
                  {article.title}
                </h4>
                <div class="mt-3 text-[11px] text-gray-500 font-medium uppercase tracking-wider">
                  {article.author?.full_name || article.author_name} •{" "}
                  {new Date(article.published_at).getFullYear()}
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Finance & Legal ── 
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <BlogSectionHeader
          title="Updates in Finance & Legal"
          href="/blog/finance-legal/"
        />
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="lg:col-span-1">
            {financeArticles[0] && <BlogCard article={financeArticles[0]} />}
          </div>
          <div class="lg:col-span-2 space-y-6">
            {
              financeArticles.slice(1).map((article) => (
                <a
                  href={`/blog/${article.slug}/`}
                  class="flex gap-4 p-4 bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow group"
                >
                  <div class="w-40 h-24 flex-none overflow-hidden rounded-lg">
                    <img
                      src={article.featured_image}
                      alt={article.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      width="160"
                      height="96"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="flex-1">
                    <span class="text-[9px] uppercase font-bold text-[#f97316] mb-1 block">
                      Legal Update
                    </span>
                    <h4 class="text-base font-bold text-gray-900 group-hover:text-orange-600 transition-colors line-clamp-2 leading-tight">
                      {article.title}
                    </h4>
                    <p class="text-xs text-gray-500 mt-2 line-clamp-1">
                      {article.excerpt}
                    </p>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  -->
    <!-- ── Town Tabs (City News) ── -->
    <section class="py-12 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex flex-col md:flex-row md:items-center justify-between mb-10 gap-6"
        >
          <h2
            class="text-2xl md:text-3xl font-extrabold border-l-4 border-[#f97316] pl-4 py-1"
          >
            What's New in
          </h2>
          <div class="flex gap-2 overflow-x-auto no-scrollbar pb-2">
            <button
              class="city-tab-btn active px-4 py-2 rounded-full text-xs font-bold bg-[#f97316] text-white shadow-lg transition-all"
              data-city="all">All Gujarat</button
            >
            {
              cities.map((city) => (
                <button
                  class="city-tab-btn px-4 py-2 rounded-full text-xs font-bold text-gray-500 bg-gray-100 hover:bg-gray-200 transition-all whitespace-nowrap"
                  data-city={city.id}
                >
                  {city.name}
                </button>
              ))
            }
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            articles.slice(0, 6).map((article) => (
              <a
                href={`/blog/${article.slug}/`}
                class="city-article group"
                data-city-id={article.city_id || "all"}
              >
                <div class="aspect-[16/9] rounded-xl overflow-hidden mb-4 shadow-md bg-gray-100">
                  <img
                    src={article.featured_image}
                    alt={article.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    width="800"
                    height="450"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <span class="text-[10px] uppercase font-bold text-gray-400 mb-2 block">
                  {article.category}
                </span>
                <h4 class="text-lg font-extrabold text-gray-900 group-hover:text-orange-600 transition-colors leading-tight mb-2">
                  {article.title}
                </h4>
                <p class="text-[13px] text-gray-500 line-clamp-2">
                  {article.excerpt}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Property Tools CTA ── -->
    <section
      class="py-16 bg-gradient-to-br from-primary-900 to-header text-white"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex flex-col lg:flex-row items-center justify-between gap-10"
        >
          <div class="max-w-2xl text-center lg:text-left">
            <h2 class="text-3xl md:text-4xl font-extrabold mb-4">
              Plan Your Property Purchase Like a Pro
            </h2>
            <p class="text-lg text-gray-300 mb-8">
              Use our advanced real estate calculators and tools to estimate
              EMI, affordability, ROI, and more. Make informed decisions with
              Home Nesto.
            </p>
            <div class="flex flex-wrap justify-center lg:justify-start gap-4">
              <a
                href="/tools/"
                class="px-8 py-4 bg-[#f97316] hover:bg-orange-600 text-white font-bold rounded-xl transition-all shadow-lg hover:shadow-orange-900/40"
                >Try Property Tools</a
              >
              <a
                href="/loan-emi-calculator/"
                class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-bold rounded-xl transition-all backdrop-blur-sm"
                >EMI Calculator</a
              >
            </div>
          </div>
          <div
            class="hidden lg:block w-72 h-72 bg-gradient-to-br from-orange-500/20 to-transparent rounded-full blur-3xl"
          >
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".city-tab-btn");
  const cityArticles = document.querySelectorAll<HTMLElement>(".city-article");

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const cityId = btn.dataset.city;

      // Active state
      tabBtns.forEach((b) => {
        b.classList.remove("active", "bg-[#f97316]", "text-white", "shadow-lg");
        b.classList.add("text-gray-500", "bg-gray-100");
      });
      btn.classList.add("active", "bg-[#f97316]", "text-white", "shadow-lg");
      btn.classList.remove("text-gray-500", "bg-gray-100");

      // Filter
      cityArticles.forEach((article) => {
        const articleCityId = article.dataset.cityId;
        if (cityId === "all" || articleCityId === cityId) {
          article.style.display = "block";
        } else {
          article.style.display = "none";
        }
      });
    });
  });
</script>
