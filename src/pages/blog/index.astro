---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { supabase } from '../../lib/supabase';
import { buildBreadcrumbSchema } from '../../lib/seo';
import type { Blog } from '../../lib/types';

const { data } = await supabase
  .from('news')
  .select('*')
  .eq('is_published', true)
  .order('published_at', { ascending: false })
  .limit(60);

const articles: Blog[] = data || [];

// Collect all unique tags for filter chips
const allTags = [...new Set(articles.flatMap((a) => a.tags || []))].slice(0, 12);

// ItemList schema for the blog index
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Latest Real Estate Blog — PropDiscover',
  url: 'https://propdiscover.com/blog',
  numberOfItems: articles.length,
  itemListElement: articles.slice(0, 10).map((article, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://propdiscover.com/blog/${article.slug}`,
    name: article.title,
  })),
};

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://propdiscover.com' },
  { name: 'Blog', url: 'https://propdiscover.com/blog' },
]);
---

<BaseLayout
  title="Latest Real Estate Blog in Gujarat | PropDiscover"
  description="Read the latest real estate blog, updates, and insights across Gujarat. Market trends, new launches, policy changes, and investment tips."
  keywords="real estate blog Gujarat, property blog India, new launch news, real estate market updates, PropDiscover"
  jsonLd={[breadcrumbSchema, itemListSchema]}
  breadcrumbs={[{ name: 'Blog', url: '/blog' }]}
>
  <section class="py-14 bg-gray-50 min-h-[60vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {/* ── Page header */}
      <header class="mb-10">
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">Real Estate Blog</h1>
        <p class="text-gray-500 mt-2 text-lg">Latest updates, launches, and market insights across Gujarat.</p>

        {/* ── Tag filter chips */}
        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-5" id="tag-filters">
            <button
              class="tag-filter-btn active text-xs font-semibold px-4 py-1.5 rounded-full border transition-colors bg-blue-600 text-white border-blue-600"
              data-tag="all"
            >
              All
            </button>
            {allTags.map((tag) => (
              <button
                class="tag-filter-btn text-xs font-semibold px-4 py-1.5 rounded-full border border-gray-200 text-gray-600 bg-white hover:bg-blue-50 hover:border-blue-400 hover:text-blue-700 transition-colors"
                data-tag={tag}
              >
                {tag}
              </button>
            ))}
          </div>
        )}
      </header>

      {/* ── Article grid */}
      {articles.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="blog-grid">
          {articles.map((article) => (
            <div class="blog-item h-full" data-tags={(article.tags || []).join(',')}>
              <BlogCard article={article} />
            </div>
          ))}
        </div>
      ) : (
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-10 text-center text-gray-500">
          No blogs published yet.
        </div>
      )}

      {/* ── No results message (hidden by default) */}
      <p id="no-results" class="hidden text-center text-gray-400 py-16">No articles found for this topic.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.blog-item');
  const noResults = document.getElementById('no-results');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';

      // Update active state
      filterBtns.forEach((b) => {
        b.classList.remove('active', 'bg-blue-600', 'text-white', 'border-blue-600');
        b.classList.add('border-gray-200', 'text-gray-600', 'bg-white');
      });
      btn.classList.add('active', 'bg-blue-600', 'text-white', 'border-blue-600');
      btn.classList.remove('border-gray-200', 'text-gray-600', 'bg-white');

      // Filter cards
      let visible = 0;
      items.forEach((item) => {
        const tags = item.dataset.tags?.split(',') ?? [];
        const show = tag === 'all' || tags.includes(tag);
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    });
  });
</script>
