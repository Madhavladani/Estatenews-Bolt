---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleTOC from "../../components/ArticleTOC.astro";
import ArticleShareBar from "../../components/ArticleShareBar.astro";
import RelatedArticles from "../../components/RelatedArticles.astro";
import ArticleFAQ from "../../components/ArticleFAQ.astro";
import { supabase } from "../../lib/supabase";
import {
  buildBreadcrumbSchema,
  buildBlogArticleSchema,
  buildFAQSchema,
  calculateReadingTime,
  extractFAQs,
  extractTOC,
} from "../../lib/seo";
import type { Blog } from "../../lib/types";

export async function getStaticPaths() {
  const { data } = await supabase
    .from("news")
    .select("*")
    .eq("is_published", true)
    .order("published_at", { ascending: false });

  const articles = (data || []) as Blog[];

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article, allArticles: articles },
  }));
}

const { article, allArticles } = Astro.props as {
  article: Blog;
  allArticles: Blog[];
};

const canonicalPath = article.canonical_path || `/blog/${article.slug}`;
const canonicalUrl = `https://propdiscover.com${canonicalPath}`;
const ogImage = article.og_image || article.featured_image || undefined;
const heroImage = article.featured_image || undefined;

// ── Content utilities
const html = article.content_html || "";
const readingTime = calculateReadingTime(html);
const toc = extractTOC(html);
const htmlFaqs = extractFAQs(html);
const faqs = [...(article.faqs || []), ...htmlFaqs];

// ── Keywords
const keywords = article.meta_keywords
  ? article.meta_keywords
  : article.tags?.join(", ") || undefined;

// ── Schema
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: "https://propdiscover.com" },
  { name: "Blog", url: "https://propdiscover.com/blog" },
  { name: article.title, url: canonicalUrl },
]);
const articleSchema = buildBlogArticleSchema(article);
const faqSchema = faqs.length > 0 ? buildFAQSchema(faqs) : null;
const schemas = [
  breadcrumbSchema,
  articleSchema,
  ...(faqSchema ? [faqSchema] : []),
];

// ── Formatted date
const publishedDate = new Date(article.published_at);
const formattedDate = publishedDate.toLocaleDateString("en-IN", {
  year: "numeric",
  month: "long",
  day: "2-digit",
});

// ── Author display
const authorSlug = article.author_name
  ? article.author_name.toLowerCase().replace(/\s+/g, "-")
  : null;
---

<BaseLayout
  title={article.meta_title || `${article.title} | PropDiscover`}
  description={article.meta_description ||
    article.excerpt ||
    "Latest real estate blog and updates."}
  canonical={canonicalUrl}
  ogImage={ogImage}
  noindex={article.noindex}
  jsonLd={schemas}
  breadcrumbs={[
    { name: "Blog", url: "/blog" },
    { name: article.title, url: `/blog/${article.slug}` },
  ]}
  keywords={keywords}
  heroImagePreload={heroImage}
  ogType="article"
  articlePublishedTime={article.published_at}
  articleModifiedTime={article.updated_at || article.published_at}
  articleTags={article.tags || []}
>
  {/* ── Progress bar + sticky share (desktop sidebar) */}
  <ArticleShareBar
    title={article.meta_title || article.title}
    url={canonicalUrl}
  />

  <article
    class="py-10 lg:py-14"
    itemscope
    itemtype="https://schema.org/BlogPosting"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* ── Two-column layout: article + sticky TOC sidebar */}
      <div
        class:list={[
          toc.length > 1 ? "lg:grid lg:grid-cols-[220px_1fr] xl:grid-cols-[260px_1fr] lg:gap-10 xl:gap-14 items-start" : "max-w-4xl mx-auto"
        ]}
      >
        {/* ── Main article column */}
        {
          toc.length > 1 && (
            <div class="hidden lg:block self-start">
              <ArticleTOC toc={toc} />
            </div>
          )
        }

        <div class="min-w-0">
          {/* ── Article header */}
          <header class="mb-8">
            {/* Category / tags row */}
            {
              article.tags?.length > 0 && (
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  {article.tags.slice(0, 4).map((tag) => (
                    <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-blue-50 text-blue-700 border border-blue-100">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }

            <h1
              class="text-3xl md:text-4xl lg:text-[2.6rem] font-extrabold text-gray-900 leading-tight tracking-tight"
              itemprop="headline"
            >
              {article.title}
            </h1>

            {
              (article.excerpt || article.meta_description) && (
                <p
                  class="text-lg text-gray-500 mt-4 leading-relaxed"
                  itemprop="description"
                >
                  {article.excerpt || article.meta_description}
                </p>
              )
            }

            {/* ── Meta row: date · author · read time */}
            <div
              class="flex flex-wrap items-center gap-x-4 gap-y-2 mt-5 text-sm text-gray-400"
            >
              <time
                datetime={article.published_at}
                itemprop="datePublished"
                class="font-medium text-gray-500"
              >
                {formattedDate}
              </time>

              {
                article.author_name && (
                  <span
                    class="flex items-center gap-1.5"
                    itemprop="author"
                    itemscope
                    itemtype="https://schema.org/Person"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
                      />
                    </svg>
                    <span itemprop="name">{article.author_name}</span>
                  </span>
                )
              }

              <span class="flex items-center gap-1.5">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                {readingTime} min read
              </span>
            </div>
          </header>

          {/* ── Mobile TOC (above hero image) */}
          {toc.length > 1 && (
            <div class="lg:hidden">
              <ArticleTOC toc={toc} />
            </div>
          )}

          {/* ── Hero image */}
          {
            heroImage && (
              <figure class="mb-10 rounded-2xl overflow-hidden border border-gray-100 shadow-md">
                <img
                  src={heroImage}
                  alt={`${article.title} — PropDiscover`}
                  class="w-full object-cover"
                  loading="eager"
                  fetchpriority="high"
                  width="1200"
                  height="630"
                  itemprop="image"
                />
                {article.excerpt && (
                  <figcaption class="sr-only">{article.excerpt}</figcaption>
                )}
              </figure>
            )
          }

          {/* ── Article body */}
          <div
            class="prose prose-lg max-w-none prose-headings:scroll-mt-24 prose-headings:font-bold prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-img:shadow-sm"
            itemprop="articleBody"
          >
            <div set:html={html} />
          </div>

          {/* ── Tags */}
          {
            article.tags?.length > 0 && (
              <div class="mt-10 pt-8 border-t border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900 mb-3">Topics</h2>
                <div class="flex flex-wrap gap-2">
                  {article.tags.map((t) => (
                    <span class="text-xs px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 font-medium hover:bg-blue-50 hover:text-blue-700 transition-colors cursor-default">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            )
          }

          {/* ── FAQ section */}
          <ArticleFAQ faqs={faqs} />

          {/* ── Related articles */}
          <RelatedArticles
            articles={allArticles}
            currentSlug={article.slug}
            currentTags={article.tags || []}
          />
        </div>

      </div>
    </div>
  </article>
</BaseLayout>
