---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Buying Guide', url: '/buying-guide' },
  { name: 'Property documents checklist', url: '/buying-guide/property-documents-checklist' },
];
---

<BaseLayout
  title="Property Documents Checklist (Before You Buy) | PropDiscover"
  description="A practical checklist of property documents to verify before buying: title, approvals, encumbrance, taxes, agreements, and handover papers."
  breadcrumbs={breadcrumbs}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": b.name,
      "item": `https://propdiscover.com${b.url}`,
    })),
  }}
>
  <section class="py-14 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Property documents checklist</h1>
      <p class="text-gray-600 mb-8">
        Always consult a qualified lawyer for a full title search. This list helps you ask the right questions and collect the right papers early.
      </p>

      <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8 space-y-7 text-gray-700 leading-relaxed">
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">A) Ownership & title</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Sale deed / conveyance deed (current owner’s proof).</li>
            <li>Chain of title documents (previous transfers, if applicable).</li>
            <li>Encumbrance certificate / lien status (as applicable).</li>
            <li>Mutation / khata / property card entries (where applicable).</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">B) Approvals & compliance</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Approved layout/building plans and commencement permission.</li>
            <li>Occupancy/Completion certificate (for ready/near-ready projects, where applicable).</li>
            <li>RERA registration details (for applicable projects/phases).</li>
          </ul>
          <p class="mt-3">
            Read: <a class="text-primary-700 hover:text-primary-800" href="/buying-guide/rera-guide">RERA guide</a>.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">C) Financial & payment proofs</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Demand schedule and payment receipts.</li>
            <li>NOC from lender (if resale and loan closed) / loan statement (if any).</li>
            <li>Society NOC (where applicable) and maintenance dues clearance.</li>
          </ul>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">D) Tax & utility</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Latest paid property tax receipts.</li>
            <li>Electricity/water bills and meter transfer process details.</li>
          </ul>
          <p class="mt-3">
            Read: <a class="text-primary-700 hover:text-primary-800" href="/buying-guide/property-tax-guide">Property tax guide</a>.
          </p>
        </div>

        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">E) Agreement & handover</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li>Agreement to sell / builder-buyer agreement (key clauses, penalties, possession date).</li>
            <li>Final sale deed + stamp duty & registration proof.</li>
            <li>Handover letter, keys, and inventory/fixture list (if applicable).</li>
          </ul>
          <p class="mt-3">
            Read: <a class="text-primary-700 hover:text-primary-800" href="/buying-guide/stamp-duty-guide">Stamp duty & registration guide</a>.
          </p>
        </div>

        <div class="pt-2">
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Next reads</h2>
          <ul class="list-disc pl-5 space-y-2">
            <li><a class="text-primary-700 hover:text-primary-800" href="/buying-guide/how-to-buy-property">How to buy property</a></li>
            <li><a class="text-primary-700 hover:text-primary-800" href="/buying-guide/home-loan-guide">Home loan guide</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

