---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Buying Guide', url: '/buying-guide' },
  { name: 'How to buy property', url: '/buying-guide/how-to-buy-property' },
];

const steps = [
  {
    num: 1,
    title: "Fix your budget (the right way)",
    items: [
      "Down payment + registration costs (stamp duty, registration, legal, broker, moving).",
      "Monthly comfort: EMI + maintenance + utilities.",
      "Keep a buffer for interior work and emergencies."
    ]
  },
  {
    num: 2,
    title: "Shortlist locations and projects",
    items: [
      "Commute, schools, hospitals, and upcoming infrastructure.",
      "Builder reputation and track record for on-time delivery.",
      "Compare price trends and resale / rental demand."
    ]
  },
  {
    num: 3,
    title: "Do a proper site visit",
    items: [
      "Visit at different times (traffic, noise, waterlogging).",
      "Check parking, ventilation, sunlight, and amenities quality.",
      "Ask for detailed payment schedule and possession timeline in writing."
    ]
  },
  {
    num: 4,
    title: "Legal & due diligence checks",
    items: [
      "Title/ownership and chain of documents.",
      "Approvals (layout/building), occupancy status, and encumbrances.",
      "RERA registration details (for applicable projects)."
    ],
    note: "Before paying a booking amount, verify the basics:",
    link: { text: "Property documents checklist", url: "/buying-guide/property-documents-checklist" }
  },
  {
    num: 5,
    title: "Home loan (if applicable)",
    items: [
      "Compare rates, processing fees, and prepayment rules.",
      "Prefer a sanction letter before committing to large payments."
    ],
    link: { text: "Home loan guide", url: "/buying-guide/home-loan-guide" }
  },
  {
    num: 6,
    title: "Agreement, payments, and registration",
    items: [
      "Read the agreement carefully (carpet area, possession date, penalties, refund clauses).",
      "Make payments via traceable methods and collect receipts.",
      "Plan stamp duty and registration in advance."
    ],
    link: { text: "Stamp duty guide", url: "/buying-guide/stamp-duty-guide" }
  }
];
---

<BaseLayout
  title="How to Buy Property (Step-by-step) | Home Nesto"
  description="A practical, step-by-step guide on how to buy property in India: budget, shortlist, site visit, legal checks, agreement, payments, and registration."
  breadcrumbs={breadcrumbs}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": b.name,
        "item": `https://homenesto.com${b.url}`,
      })),
    },
    {
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "How to Buy Property in India",
      "description": "A practical, step-by-step guide on how to buy property in India: budget, shortlist, site visit, legal checks, agreement, payments, and registration.",
      "step": steps.map((s, i) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "name": s.title,
        "itemListElement": s.items.map((item, j) => ({
          "@type": "HowToDirection",
          "position": j + 1,
          "text": item,
        })),
      })),
    },
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "How to Buy Property (Step-by-step)",
      "url": "https://homenesto.com/buying-guide/how-to-buy-property",
      "isPartOf": {
        "@type": "WebSite",
        "name": "Home Nesto",
        "url": "https://homenesto.com",
      },
    },
  ]}
>

  <!-- ========== HERO HEADER ========== -->
  <section class="relative overflow-hidden" style="background-color: #0a1929;">
    <!-- Subtle gradient overlay -->
    <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background: radial-gradient(ellipse at 30% 50%, #f97316 0%, transparent 70%);"></div>
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background: radial-gradient(ellipse at 75% 30%, #ffffff 0%, transparent 60%);"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 relative z-10">
      <!-- Accent badge -->
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase mb-5" style="background-color: rgba(249,115,22,0.15); color: #f97316; border: 1px solid rgba(249,115,22,0.3);">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Buying Guide
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4 tracking-tight">
        How to buy property
        <span class="block text-xl sm:text-2xl md:text-3xl font-semibold mt-1 opacity-80" style="color: #f97316;">Step-by-step checklist</span>
      </h1>
      <p class="text-base md:text-lg max-w-2xl leading-relaxed" style="color: rgba(255,255,255,0.75);">
        Plan your purchase with confidence. Avoid surprises, keep documentation ready from day one, and move through each stage methodically.
      </p>

      <!-- Quick jump stats -->
      <div class="flex flex-wrap gap-4 mt-8">
        <div class="flex items-center gap-2 text-sm font-medium" style="color: rgba(255,255,255,0.6);">
          <svg class="w-4 h-4" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          6 essential steps
        </div>
        <div class="flex items-center gap-2 text-sm font-medium" style="color: rgba(255,255,255,0.6);">
          <svg class="w-4 h-4" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Free checklist
        </div>
        <div class="flex items-center gap-2 text-sm font-medium" style="color: rgba(255,255,255,0.6);">
          <svg class="w-4 h-4" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H5a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          India-focused
        </div>
      </div>
    </div>
  </section>

  <!-- ========== STEPS SECTION ========== -->
  <section class="py-12 md:py-16" style="background-color: #f8fafc;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Progress indicator (decorative) -->
      <div class="hidden md:flex items-center justify-between mb-12 px-2">
        {steps.map((s, i) => (
          <div class="flex items-center flex-1 last:flex-none">
            <div class="flex flex-col items-center gap-1.5">
              <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white shadow-md transition-all" style="background-color: #1e3a5f;">
                {s.num}
              </div>
              <span class="text-[11px] font-semibold uppercase tracking-wider text-center leading-tight" style="color: #1e3a5f;">
                {s.title.split('(')[0].trim().replace('Fix your budget', 'Budget').replace('Shortlist locations and projects', 'Shortlist').replace('Do a proper site visit', 'Site Visit').replace('Legal & due diligence checks', 'Legal').replace('Home loan', 'Loan').replace('Agreement, payments, and registration', 'Close')}
              </span>
            </div>
            {i < steps.length - 1 && (
              <div class="flex-1 h-0.5 mx-1 rounded-full" style="background: linear-gradient(90deg, #1e3a5f 0%, #e2e8f0 100%);"></div>
            )}
          </div>
        ))}
      </div>

      <!-- Step cards -->
      <div class="space-y-6">
        {steps.map((step) => (
          <div class="group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden" id={`step-${step.num}`}>
            <!-- Left accent bar -->
            <div class="absolute left-0 top-0 bottom-0 w-1.5 transition-colors duration-300" style="background-color: #f97316;"></div>

            <div class="p-5 sm:p-7 pl-6 sm:pl-9">
              <div class="flex items-start gap-4">
                <!-- Step number badge -->
                <div class="flex-shrink-0 w-10 h-10 sm:w-11 sm:h-11 rounded-xl flex items-center justify-center text-base sm:text-lg font-extrabold text-white shadow-sm" style="background-color: #1e3a5f;">
                  {step.num}
                </div>

                <div class="flex-1 min-w-0">
                  <h2 class="text-lg sm:text-xl font-bold mb-3" style="color: #0a1929;">
                    {step.title}
                  </h2>

                  {step.note && (
                    <p class="text-sm font-medium mb-3 px-3 py-2 rounded-lg border-l-2" style="color: #1e3a5f; background-color: rgba(30,58,95,0.04); border-left-color: #f97316;">
                      <svg class="w-4 h-4 inline-block mr-1.5 -mt-0.5" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      {step.note}
                    </p>
                  )}

                  <ul class="space-y-2.5">
                    {step.items.map((item, idx) => (
                      <li class="flex items-start gap-3 text-sm sm:text-base leading-relaxed" style="color: #334155;">
                        <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full" style="background-color: #f97316;"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>

                  {step.link && (
                    <a
                      href={step.link.url}
                      class="inline-flex items-center gap-2 mt-4 text-sm font-semibold px-4 py-2 rounded-lg transition-all duration-200 hover:gap-3"
                      style="background-color: rgba(30,58,95,0.06); color: #1e3a5f;"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                      {step.link.text}
                      <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- ========== QUICK NEXT READS ========== -->
      <div class="mt-12 bg-white rounded-2xl border border-gray-100 shadow-sm p-6 sm:p-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color: rgba(249,115,22,0.1);">
            <svg class="w-5 h-5" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          </div>
          <h2 class="text-xl font-bold" style="color: #0a1929;">Quick next reads</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          <a href="/buying-guide/rera-guide" class="flex items-center gap-3 px-4 py-3.5 rounded-xl border border-gray-100 hover:shadow-sm transition-all duration-200 group" style="background-color: #f8fafc;">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: rgba(30,58,95,0.08);">
              <svg class="w-4 h-4" style="color: #1e3a5f;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <span class="text-sm font-semibold flex-1" style="color: #1e3a5f;">RERA guide</span>
            <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-hover:translate-x-1" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/buying-guide/property-tax-guide" class="flex items-center gap-3 px-4 py-3.5 rounded-xl border border-gray-100 hover:shadow-sm transition-all duration-200 group" style="background-color: #f8fafc;">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: rgba(30,58,95,0.08);">
              <svg class="w-4 h-4" style="color: #1e3a5f;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <span class="text-sm font-semibold flex-1" style="color: #1e3a5f;">Property tax guide</span>
            <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-hover:translate-x-1" style="color: #f97316;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- ========== BOTTOM CTA ========== -->
      <div class="mt-10 text-center rounded-2xl p-6 sm:p-8" style="background: linear-gradient(135deg, #1e3a5f 0%, #0a1929 100%);">
        <p class="text-white font-semibold text-base sm:text-lg mb-1">Ready to dive deeper?</p>
        <p class="text-sm mb-4" style="color: rgba(255,255,255,0.7);">Explore our full buying guide for more in-depth resources.</p>
        <a
          href="/buying-guide"
          class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full text-sm font-bold transition-all duration-200 hover:shadow-lg"
          style="background-color: #f97316; color: #fff;"
        >
          View all guides
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

    </div>
  </section>

</BaseLayout>