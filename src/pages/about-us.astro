---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us | PropDiscover"
  description="Learn about PropDiscover, our mission, and how we help people discover real estate projects across Gujarat."
>
  <section class="py-14 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">About Us</h1>
      <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8 space-y-6 text-gray-700 leading-relaxed">
        <p>
          PropDiscover is a real estate discovery platform focused on helping buyers and investors explore residential and commercial
          projects with clarity and confidence.
        </p>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">What We Do</h2>
          <p>
            We curate project information, highlight key amenities and location context, and publish helpful guides so you can compare
            options without the noise.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Our Mission</h2>
          <p>
            Make property discovery simple, transparent, and practical by putting useful information first and keeping the experience
            fast and easy to navigate.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Get in Touch</h2>
          <p>
            For questions, partnerships, or feedback, email us at{' '}
            <a class="text-primary-700 hover:text-primary-800" href="mailto:support@propdiscover.com">support@propdiscover.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

