---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Down Payment Calculator | Home Nesto"
  description="Calculate how much down payment you need for your property purchase based on price and loan-to-value ratio."
>
  <header class="page-header">
    <span class="header-badge">💳 Savings Planner</span>
    <h1>Down Payment Calculator<span class="accent-dot">.</span></h1>
    <p>
      Estimate the upfront cash required and the loan amount for your next property.
    </p>
  </header>

  <main class="main-container">
    <div class="calculator-card">
      <div class="input-grid">
        <div class="input-group">
          <label for="propertyPrice">Property Price (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="propertyPrice" value="5000000" step="50000" />
          </div>
          <input type="range" id="propertyPriceSlider" class="range-slider" min="1000000" max="100000000" step="100000" value="5000000" />
        </div>

        <div class="input-group">
          <label for="downPaymentPercent">Down Payment (%)</label>
          <div class="input-wrapper">
            <span class="prefix">%</span>
            <input type="number" id="downPaymentPercent" value="20" step="1" />
          </div>
          <input type="range" id="downPaymentPercentSlider" class="range-slider" min="10" max="95" step="1" value="20" />
        </div>

        <div class="input-group">
          <label for="registrationPercent">Registration & Stamp Duty (%)</label>
          <div class="input-wrapper">
            <span class="prefix">%</span>
            <input type="number" id="registrationPercent" value="6" step="0.5" />
          </div>
          <input type="range" id="registrationPercentSlider" class="range-slider" min="0" max="15" step="0.5" value="6" />
        </div>

        <div class="input-group">
          <label for="otherCosts">Brokerage & Other Costs (%)</label>
          <div class="input-wrapper">
            <span class="prefix">%</span>
            <input type="number" id="otherCosts" value="1" step="0.5" />
          </div>
          <input type="range" id="otherCostsSlider" class="range-slider" min="0" max="10" step="0.5" value="1" />
        </div>
      </div>

      <div class="calc-btn-wrapper">
        <button id="calculateBtn" class="btn-calculate">Calculate Upfront Cash</button>
        <button id="resetBtn" class="btn-reset">↺ Reset</button>
      </div>

      <div id="resultContainer" class="results-container">
        <p class="result-header">💰 Estimated Upfront Requirement</p>
        <div class="result-inner-grid">
          <div class="result-item emi-highlight">
            <p class="result-label">Total Upfront Cash</p>
            <p id="totalCashText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Base Down Payment</p>
            <p id="baseDownPaymentText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Total Loan Amount</p>
            <p id="totalLoanText" class="result-value">—</p>
          </div>
        </div>
      </div>
    </div>

    <section class="faq-section">
      <h2>Down Payment FAQ</h2>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>What is a standard down payment for a home?</summary>
          <div class="faq-answer">
            In India, most banks require a minimum down payment of 20% of the property value. Some schemes might allow for 10-15% for smaller ticket sizes.
          </div>
        </details>
        <details class="faq-item">
          <summary>What extra costs should I budget for?</summary>
          <div class="faq-answer">
            Beyond the down payment, you must budget for Stamp Duty (varies by state, usually 5-7%), Registration fees (approx 1%), and brokerage or legal fees (1-2%).
          </div>
        </details>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  function calculateDownPayment() {
    const price = parseFloat(document.getElementById('propertyPrice').value) || 0;
    const dpPercent = parseFloat(document.getElementById('downPaymentPercent').value) || 0;
    const regPercent = parseFloat(document.getElementById('registrationPercent').value) || 0;
    const otherPercent = parseFloat(document.getElementById('otherCosts').value) || 0;

    const baseDownPayment = (price * dpPercent) / 100;
    const registrationCosts = (price * regPercent) / 100;
    const otherCosts = (price * otherPercent) / 100;
    
    const totalCashRequired = baseDownPayment + registrationCosts + otherCosts;
    const loanAmount = price - baseDownPayment;

    document.getElementById('totalCashText').innerText = '₹' + Math.round(totalCashRequired).toLocaleString('en-IN');
    document.getElementById('baseDownPaymentText').innerText = '₹' + Math.round(baseDownPayment).toLocaleString('en-IN');
    document.getElementById('totalLoanText').innerText = '₹' + Math.round(loanAmount).toLocaleString('en-IN');
    
    document.getElementById('resultContainer').classList.add('visible');
  }

  const inputs = ['propertyPrice', 'downPaymentPercent', 'registrationPercent', 'otherCosts'];
  inputs.forEach(id => {
    const input = document.getElementById(id);
    const slider = document.getElementById(id + 'Slider');
    if (slider) {
      input.addEventListener('input', () => { slider.value = input.value; });
      slider.addEventListener('input', () => { input.value = slider.value; });
    }
  });

  document.getElementById('calculateBtn').addEventListener('click', calculateDownPayment);
  document.getElementById('resetBtn').addEventListener('click', () => {
    location.reload();
  });
</script>

<style is:global>
  :root {
    --primary: #1e3a5f;
    --accent: #f97316;
    --text-dark: #1a1a2e;
    --text-medium: #4a5568;
    --text-light: #718096;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-200: #e2e8f0;
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
    --radius-xl: 24px;
  }

  .page-header {
    background: linear-gradient(160deg, #0a1929 0%, #0d2137 40%, #122d4a 100%);
    padding: 3rem 1.5rem 3.5rem;
    text-align: center;
    color: white;
  }
  .header-badge {
    background: rgba(249, 115, 22, 0.15);
    color: #fca35d;
    padding: 0.35rem 1rem;
    border-radius: 50px;
    font-size: 0.8rem;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .main-container {
    max-width: 960px;
    margin: -2rem auto 0;
    padding: 0 1.25rem 3rem;
  }

  .calculator-card {
    background: white;
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
  }

  .input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .input-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .input-wrapper { position: relative; margin-bottom: 0.5rem; }
  .prefix { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-weight: 700; }
  .input-wrapper input { width: 100%; padding: 0.75rem 1rem 0.75rem 2rem; border: 2px solid var(--gray-200); border-radius: 12px; font-size: 1.1rem; }

  .range-slider { width: 100%; accent-color: var(--primary); }

  .calc-btn-wrapper { display: flex; gap: 1rem; }
  .btn-calculate { background: var(--accent); color: white; border: none; padding: 1rem 2rem; border-radius: 50px; font-weight: 700; cursor: pointer; }

  .results-container {
    margin-top: 2rem;
    background: #1e3a5f;
    color: white;
    padding: 2rem;
    border-radius: 20px;
    display: none;
  }
  .results-container.visible { display: block; }
  .result-inner-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
  .result-item { background: rgba(255,255,255,0.1); padding: 1.25rem; border-radius: 15px; }

  .faq-section { margin-top: 4rem; }
  .faq-item { background: white; padding: 1rem; border-radius: 12px; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .input-grid { grid-template-columns: 1fr; }
    .result-inner-grid { grid-template-columns: 1fr; }
  }
</style>
