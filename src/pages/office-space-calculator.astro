---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Office Space Calculator | Home Nesto"
  description="Estimate the amount of office space your business needs based on employee count and workstation types."
>
  <header class="page-header">
    <span class="header-badge">🏢 Commercial Planning</span>
    <h1>Office Space Calculator<span class="accent-dot">.</span></h1>
    <p>
      Plan your workspace efficiently by estimating the square footage required for your team.
    </p>
  </header>

  <main class="main-container">
    <div class="calculator-card">
      <div class="input-grid">
        <div class="input-group">
          <label for="employees">Number of Employees</label>
          <div class="input-wrapper">
            <input type="number" id="employees" value="20" min="1" step="1" />
          </div>
        </div>

        <div class="input-group">
          <label for="workstyle">Workstyle / Space Type</label>
          <div class="input-wrapper">
            <style>
                .custom-select { width: 100%; padding: 0.75rem; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 1rem; appearance: none; background: white; }
            </style>
            <select id="workstyle" class="custom-select">
              <option value="100">Standard (Closed Cubicles)</option>
              <option value="75" selected>Modern (Open Plan)</option>
              <option value="60">Compact (Coworking style)</option>
              <option value="150">Premium (Executive focus)</option>
            </select>
          </div>
        </div>

        <div class="input-group">
          <label for="meetingRooms">Meeting Rooms Needs</label>
          <select id="meetingRooms" class="custom-select">
            <option value="0">None</option>
            <option value="150" selected>Basic (1-2 rooms)</option>
            <option value="400">Moderate (3-5 rooms)</option>
            <option value="800">High (Boardrooms + cabins)</option>
          </select>
        </div>

        <div class="input-group">
          <label for="amenities">Kitchen / Lounge Area</label>
          <select id="amenities" class="custom-select">
            <option value="0">None</option>
            <option value="100" selected>Small Pantry</option>
            <option value="300">Large Lounge & Kitchen</option>
          </select>
        </div>
      </div>

      <div class="calc-btn-wrapper">
        <button id="calculateBtn" class="btn-calculate">Estimate Space</button>
        <button id="resetBtn" class="btn-reset">↺ Reset</button>
      </div>

      <div id="resultContainer" class="results-container">
        <p class="result-header">🏢 Your Office Space Estimate</p>
        <div class="result-inner-grid">
          <div class="result-item emi-highlight">
            <p class="result-label">Total Sq. Ft. Required</p>
            <p id="totalSqFtText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Workstation Area</p>
            <p id="workstationAreaText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Efficiency Factor</p>
            <p id="efficiencyText" class="result-value">1.15x</p>
          </div>
        </div>
      </div>
    </div>

    <section class="faq-section">
      <h2>Office Planning FAQ</h2>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>How much space does one employee need?</summary>
          <div class="faq-answer">
            Typically, 75-100 sq ft per person is standard for open office layouts. This includes their desk plus a share of common walkways.
          </div>
        </details>
        <details class="faq-item">
          <summary>What is the circulation factor?</summary>
          <div class="faq-answer">
            It's the space used for hallways and movement. We add a 15-20% buffer to the net area to account for this.
          </div>
        </details>
      </div>
    </section>
    <div style="margin-top: 3rem; text-align: center;">
      <a href="/tools/" style="color: var(--accent); font-weight: 700; text-decoration: none;">← Back to All Tools</a>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  function calculateOfficeSpace() {
    const employees = parseInt(document.getElementById('employees').value) || 0;
    const workstyleValue = parseInt(document.getElementById('workstyle').value) || 0;
    const meetingValue = parseInt(document.getElementById('meetingRooms').value) || 0;
    const amenityValue = parseInt(document.getElementById('amenities').value) || 0;

    const workstationArea = employees * workstyleValue;
    const netArea = workstationArea + meetingValue + amenityValue;
    const grossArea = netArea * 1.15; // 15% circulation buffer

    document.getElementById('totalSqFtText').innerText = Math.round(grossArea).toLocaleString() + ' Sq. Ft.';
    document.getElementById('workstationAreaText').innerText = Math.round(workstationArea).toLocaleString() + ' Sq. Ft.';
    
    document.getElementById('resultContainer').classList.add('visible');
  }

  document.getElementById('calculateBtn').addEventListener('click', calculateOfficeSpace);
  document.getElementById('resetBtn').addEventListener('click', () => { location.reload(); });
</script>

<style is:global>
  :root {
    --primary: #1e3a5f;
    --accent: #f97316;
    --text-dark: #1a1a2e;
    --text-medium: #4a5568;
    --text-light: #718096;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-200: #e2e8f0;
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
    --radius-xl: 24px;
  }
  .page-header { background: linear-gradient(160deg, #0a1929 0%, #0d2137 40%, #122d4a 100%); padding: 3rem 1.5rem 3.5rem; text-align: center; color: white; }
  .header-badge { background: rgba(249, 115, 22, 0.15); color: #fca35d; padding: 0.35rem 1rem; border-radius: 50px; font-size: 0.8rem; margin-bottom: 1rem; display: inline-block; }
  .main-container { max-width: 960px; margin: -2rem auto 0; padding: 0 1.25rem 3rem; }
  .calculator-card { background: white; border-radius: var(--radius-xl); padding: 2.5rem; box-shadow: var(--shadow-lg); }
  .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
  .input-group label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; }
  .input-wrapper input { width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--gray-200); border-radius: 12px; font-size: 1.1rem; }
  .calc-btn-wrapper { display: flex; gap: 1rem; }
  .btn-calculate { background: var(--accent); color: white; border: none; padding: 1rem 2rem; border-radius: 50px; font-weight: 700; cursor: pointer; }
  .results-container { margin-top: 2rem; background: #1e3a5f; color: white; padding: 2rem; border-radius: 20px; display: none; }
  .results-container.visible { display: block; }
  .result-inner-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
  .result-item { background: rgba(255,255,255,0.1); padding: 1.25rem; border-radius: 15px; }
  @media (max-width: 768px) { .input-grid { grid-template-columns: 1fr; } .result-inner-grid { grid-template-columns: 1fr; } }
</style>
