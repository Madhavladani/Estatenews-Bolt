---
export const prerender = false;
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { supabase } from "../../../lib/supabase";
import { normalizeCitySlug, fallbackCityFromStatic } from "../../../lib/city-slug";
import { buildBreadcrumbSchema } from "../../../lib/seo";
import type { City } from "../../../lib/types";

const { city: rawCitySlug } = Astro.params;
const { slug: citySlug } = normalizeCitySlug(rawCitySlug);

if (rawCitySlug && citySlug !== rawCitySlug) {
  return Astro.redirect(`/${citySlug}/builders`, 301);
}

const { data: cityData } = await supabase
  .from("cities")
  .select("*")
  .eq("slug", citySlug)
  .single();

const city: City | null =
  (cityData as City) || fallbackCityFromStatic(citySlug);

if (!city) return new Response(null, { status: 404 });

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400",
);

// Fetch all builders for this city
const { data: buildersData } = await supabase
  .from("builders")
  .select("id,name,slug,logo,year_established,headquarters,about_builder,full_profile")
  .contains("cities_served", [city.id])
  .order("name");

const builders = (buildersData || []) as any[];

// Fetch all projects for this city to count per builder
const { data: allProjects } = await supabase
  .from("projects")
  .select("id,builder_id,builder_name")
  .eq("city_id", city.id);

const projects = allProjects || [];

// Compute project count per builder (by id OR by name legacy match)
const builderWithCounts = builders.map((b) => {
  const count = projects.filter(
    (p: any) =>
      (p.builder_id && p.builder_id === b.id) ||
      (p.builder_name &&
        p.builder_name.toLowerCase() === b.name.toLowerCase()),
  ).length;
  return { ...b, project_count: count };
});

// ── SEO ─────────────────────────────────────────────────────────
const pageTitle =
  `Top Real Estate Builders in ${city.name} | Trusted Developers ${city.state}`;
const pageDescription =
  `Explore ${builderWithCounts.length} trusted real estate builders and developers in ${city.name}, ${city.state}. View their latest projects, portfolios, and contact details on HomeNesto.`;
const canonicalUrl = `https://homenesto.com/${city.slug}/builders/`;

// ── LD-JSON Schemas ─────────────────────────────────────────────
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: "https://homenesto.com" },
  { name: city.name, url: `https://homenesto.com/${city.slug}` },
  { name: `Builders in ${city.name}`, url: canonicalUrl },
]);

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Real Estate Builders in ${city.name}`,
  description: pageDescription,
  numberOfItems: builderWithCounts.length,
  itemListElement: builderWithCounts.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    url: `https://homenesto.com/${city.slug}/builders/${b.slug}/`,
  })),
};

const collectionPageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://homenesto.com" },
      { "@type": "ListItem", position: 2, name: city.name, item: `https://homenesto.com/${city.slug}` },
      { "@type": "ListItem", position: 3, name: `Builders in ${city.name}`, item: canonicalUrl },
    ],
  },
};

const jsonLdSchemas = [breadcrumbSchema, itemListSchema, collectionPageSchema];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
  jsonLd={jsonLdSchemas}
  breadcrumbs={[
    { name: city.name, url: `/${city.slug}` },
    { name: `Builders`, url: `/${city.slug}/builders` },
  ]}
>
  <!-- Hero Banner -->
  <section class="bg-[#0a1929] text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex text-xs font-medium text-slate-400 mb-6 uppercase tracking-wider" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-2">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          <li class="flex items-center">
            <span class="text-slate-600 mx-2">/</span>
            <a href={`/${city.slug}`} class="hover:text-white transition-colors capitalize">{city.name}</a>
          </li>
          <li class="flex items-center">
            <span class="text-slate-600 mx-2">/</span>
            <span class="text-orange-400 font-semibold">Builders</span>
          </li>
        </ol>
      </nav>

      <div class="max-w-3xl">
        <p class="text-accent-400 font-medium text-sm mb-3 uppercase tracking-wider">{city.state}</p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
          Real Estate Builders in{" "}
          <span class="text-orange-400">{city.name}</span>
        </h1>
        <p class="text-gray-300 text-base md:text-lg leading-relaxed">
          Discover {builderWithCounts.length} trusted builders and developers in {city.name}.
          Explore their projects, portfolios, and contact details.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <span class="inline-flex items-center gap-2 bg-white/10 border border-white/15 text-white text-sm font-semibold px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            {builderWithCounts.length} Builders
          </span>
          <a
            href={`/${city.slug}`}
            class="text-sm text-gray-400 hover:text-white transition-colors flex items-center gap-1"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to {city.name}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Builders Grid -->
  <section class="py-12 bg-gray-50 min-h-[40vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {builderWithCounts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {builderWithCounts.map((builder) => (
            <a
              href={`/${city.slug}/builders/${builder.slug}`}
              class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-lg hover:border-orange-200 transition-all duration-200 flex flex-col overflow-hidden"
            >
              <!-- Logo Area -->
              <div class="flex items-center justify-center p-6 bg-gradient-to-br from-slate-50 to-gray-100 border-b border-gray-100 group-hover:from-orange-50/30 transition-colors">
                {builder.logo ? (
                  <img
                    src={builder.logo}
                    alt={`${builder.name} real estate builder logo`}
                    class="w-24 h-24 object-contain"
                    loading="lazy"
                    width="96"
                    height="96"
                  />
                ) : (
                  <div class="w-24 h-24 rounded-2xl bg-[#1e3a5f] flex items-center justify-center text-white text-4xl font-black shadow-inner">
                    {builder.name.charAt(0)}
                  </div>
                )}
              </div>

              <!-- Info Area -->
              <div class="p-5 flex flex-col flex-1">
                <h2 class="font-bold text-gray-900 text-base leading-tight group-hover:text-orange-600 transition-colors mb-3 line-clamp-2">
                  {builder.name}
                </h2>

                <!-- Stats Row -->
                <div class="grid grid-cols-2 gap-2 mb-4">
                  {builder.year_established && (
                    <div class="bg-gray-50 rounded-lg px-3 py-2 text-center">
                      <p class="text-[10px] font-medium text-gray-400 uppercase tracking-wide">Since</p>
                      <p class="text-sm font-bold text-gray-800">{builder.year_established}</p>
                    </div>
                  )}
                  <div class={`rounded-lg px-3 py-2 text-center ${builder.year_established ? "bg-orange-50" : "col-span-2 bg-orange-50"}`}>
                    <p class="text-[10px] font-medium text-orange-400 uppercase tracking-wide">Projects</p>
                    <p class="text-sm font-bold text-orange-600">{builder.project_count}</p>
                  </div>
                </div>

                {builder.headquarters && (
                  <p class="text-xs text-gray-400 flex items-center gap-1 mb-3">
                    <svg class="w-3 h-3 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="truncate">{builder.headquarters}</span>
                  </p>
                )}

                <!-- CTA -->
                <div class="mt-auto pt-3 border-t border-gray-100">
                  <span class="inline-flex items-center gap-1.5 text-xs font-bold text-[#1e3a5f] group-hover:text-orange-600 transition-colors uppercase tracking-wider">
                    View Profile
                    <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center text-gray-300 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h2 class="text-xl font-bold text-gray-700 mb-2">No Builders Listed Yet</h2>
          <p class="text-gray-500 text-sm max-w-sm">
            We're adding builders in {city.name} soon. Check back later or explore projects directly.
          </p>
          <a
            href={`/${city.slug}`}
            class="mt-6 px-6 py-3 bg-[#1e3a5f] hover:bg-[#0a1929] text-white font-semibold rounded-lg transition-colors text-sm"
          >
            Explore {city.name} Projects
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Internal Links footer strip -->
  <section class="py-8 bg-[#0a1929] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-3">Explore More in {city.name}</p>
      <div class="flex flex-wrap gap-4">
        <a href={`/${city.slug}`} class="text-sm text-gray-400 hover:text-white transition-colors">
          {city.name} Real Estate
        </a>
        <a href={`/${city.slug}/residential`} class="text-sm text-gray-400 hover:text-white transition-colors">
          Residential Projects in {city.name}
        </a>
        <a href={`/${city.slug}/commercial`} class="text-sm text-gray-400 hover:text-white transition-colors">
          Commercial Projects in {city.name}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
