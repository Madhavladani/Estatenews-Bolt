---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { supabase } from "../../../lib/supabase";
import { buildBuilderSchema, buildBreadcrumbSchema } from "../../../lib/seo";
import ProjectCard from "../../../components/ProjectCard.astro";
import type { Builder, Project, City } from "../../../lib/types";

export const prerender = false;

Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=86400, s-maxage=86400, stale-while-revalidate=86400",
);

const { city: citySlug, slug: builderSlug } = Astro.params;

// Fetch City
const { data: cityData } = await supabase
  .from("cities")
  .select("*")
  .eq("slug", citySlug)
  .single();

if (!cityData) {
  return new Response("City Not Found", { status: 404 });
}
const city = cityData as City;

// Fetch Builder
const { data: builderData } = await supabase
  .from("builders")
  .select("*")
  .eq("slug", builderSlug)
  .single();

if (!builderData) {
  return new Response("Builder Not Found", { status: 404 });
}
const builder = builderData as Builder;

// Fetch ALL Projects for this Builder — match by builder_id (new) OR builder_name (legacy)
const [{ data: byId }, { data: byName }] = await Promise.all([
  supabase.from("projects").select("*").eq("builder_id", builder.id),
  supabase.from("projects").select("*").ilike("builder_name", builder.name),
]);

// Merge, deduplicate by project id, and sort newest first
const seenIds = new Set<string>();
const projects = ([...(byId || []), ...(byName || [])] as Project[])
  .filter((p) => {
    if (seenIds.has(p.id)) return false;
    seenIds.add(p.id);
    return true;
  })
  .sort(
    (a, b) =>
      new Date(b.created_at).getTime() - new Date(a.created_at).getTime(),
  )
  .map((p) => ({ ...p, city: city })); // attach city so ProjectCard can build URLs

// For FAQs and Reviews, if they're in builder jsonb, parse them:
const reviews =
  typeof builder.google_reviews_summary === "string"
    ? JSON.parse(builder.google_reviews_summary || "{}")
    : builder.google_reviews_summary || {};
const testimonialsList =
  typeof builder.testimonials === "string"
    ? JSON.parse(builder.testimonials || "[]")
    : builder.testimonials || [];

const {
  name,
  logo,
  cover_image,
  about_builder,
  year_established,
  headquarters,
  cities_served,
  full_profile,
  phone,
  email,
  website,
  social_links,
  whatsapp,
  founder_details,
  awards,
  videos,
  press_coverage,
  meta_title,
  meta_description,
} = builder;

const pageTitle =
  meta_title ||
  `${name} Real Estate Builder in ${city.name} | Projects & Reviews`;
const pageDescription =
  meta_description ||
  `Discover ${name} in ${city.name}. View their latest residential and commercial projects, read reviews, and explore their portfolio.`;
const canonical = Astro.url.href.endsWith("/")
  ? Astro.url.href
  : Astro.url.href + "/";

const builderSchema = buildBuilderSchema({ builder, city, url: canonical });

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: new URL("/", Astro.url).href },
  { name: city.name, url: new URL(`/${city.slug}`, Astro.url).href },
  {
    name: `Builders in ${city.name}`,
    url: new URL(`/${city.slug}/builders`, Astro.url).href,
  },
  { name: name, url: canonical },
]);

const itemListSchema =
  projects.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: `${name} Projects`,
        description: `Real estate projects by ${name}`,
        numberOfItems: projects.length,
        itemListElement: projects.map((p, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: p.title,
          url: p.city?.slug
            ? p.locality?.slug
              ? new URL(
                  `/${p.city.slug}/${p.project_type}/${p.locality.slug}/${p.slug}/`,
                  Astro.url,
                ).href
              : new URL(
                  `/${p.city.slug}/${p.project_type}/${p.slug}/`,
                  Astro.url,
                ).href
            : canonical,
        })),
      }
    : null;

const jsonLdSchemas = [
  builderSchema,
  breadcrumbSchema,
  ...(itemListSchema ? [itemListSchema] : []),
];

const completedProjects = projects.filter(
  (p) => p.project_status === "ready-to-move",
);
const ongoingProjects = projects.filter(
  (p) =>
    p.project_status === "under-construction" ||
    p.project_status === "new-launch",
);

const socialLinksParsed =
  typeof social_links === "string"
    ? JSON.parse(social_links || "{}")
    : social_links || {};

const formatList = (arr: any) => (Array.isArray(arr) ? arr : []);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogImage={cover_image || logo}
  jsonLd={jsonLdSchemas}
>
  <div
    class="bg-slate-50/50 min-h-screen text-slate-800 antialiased selection:bg-orange-500/10 selection:text-orange-600"
  >
    {/* Breadcrumbs Wrapper */}
    <div class="bg-[#0a1929] border-b border-slate-800/40 py-3.5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav
          class="flex text-xs font-medium text-slate-400 tracking-wide uppercase"
          aria-label="Breadcrumb"
        >
          <ol class="inline-flex items-center space-x-2">
            <li class="inline-flex items-center">
              <a href="/" class="hover:text-white transition-colors">Home</a>
            </li>
            <li class="flex items-center">
              <span class="text-slate-600 mx-2 text-[10px] select-none">/</span>
              <a
                href={`/${city.slug}`}
                class="hover:text-white transition-colors capitalize"
                >{city.name}</a
              >
            </li>
            <li aria-current="page" class="flex items-center">
              <span class="text-slate-600 mx-2 text-[10px] select-none">/</span>
              <span
                class="text-orange-400 font-semibold truncate max-w-[180px] sm:max-w-none"
                >{name}</span
              >
            </li>
          </ol>
        </nav>
      </div>
    </div>

    {/* Elegant Hero Framework */}
    <div class="bg-white border-b border-slate-200/80 shadow-sm relative">
      <div class="w-full h-56 md:h-80 overflow-hidden relative bg-[#0a1929]">
        {
          cover_image ? (
            <img
              src={cover_image}
              alt={`${name} Cover Showcase`}
              class="w-full h-full object-cover opacity-80 mix-blend-luminosity"
              loading="eager"
            />
          ) : (
            <div class="absolute inset-0 bg-gradient-to-tr from-[#0a1929] via-[#1e3a5f] to-[#0a1929]" />
          )
        }
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"
        >
        </div>
      </div>

      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative -mt-16 md:-mt-20 pb-8"
      >
        <div
          class="flex flex-col md:flex-row items-center md:items-end gap-5 md:gap-7 text-center md:text-left"
        >
          {/* Identity Shield Container */}
          <div
            class="bg-white p-2.5 rounded-2xl shadow-xl shadow-slate-200/60 ring-1 ring-slate-100 flex-shrink-0 z-10 w-36 h-36 md:w-44 md:h-44 flex items-center justify-center backdrop-blur-md transform hover:scale-[1.02] transition-transform duration-300"
          >
            {
              logo ? (
                <img
                  src={logo}
                  alt={`${name} Corporate Brand Identity`}
                  class="max-w-full max-h-full object-contain"
                />
              ) : (
                <span class="text-5xl font-black text-slate-200 bg-slate-100 w-full h-full rounded-xl flex items-center justify-center border border-dashed border-slate-300/60">
                  {name.charAt(0)}
                </span>
              )
            }
          </div>

          <div class="flex-1 z-10 pt-2 md:pt-0">
            <h1
              class="text-3xl md:text-4xl lg:text-5xl font-black text-[#0a1929] tracking-tight"
            >
              {name}
            </h1>
            <div
              class="text-sm text-slate-500 font-medium mt-3 flex flex-wrap items-center justify-center md:justify-start gap-y-2 gap-x-5"
            >
              {
                headquarters && (
                  <span class="inline-flex items-center gap-1.5 bg-slate-100 px-3 py-1 rounded-full text-slate-600 border border-slate-200/40 shadow-sm">
                    <svg
                      class="w-4 h-4 text-slate-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <>
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                        />
                      </>
                    </svg>
                    HQ: {headquarters}
                  </span>
                )
              }
              {
                year_established && (
                  <span class="inline-flex items-center gap-1.5 bg-slate-100 px-3 py-1 rounded-full text-slate-600 border border-slate-200/40 shadow-sm">
                    <svg
                      class="w-4 h-4 text-slate-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    Established {year_established}
                  </span>
                )
              }
            </div>
          </div>
        </div>

        {/* Matrix Metrics Array (Now includes Social Media Box if available) */}
        <div
          class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-8 pt-6 border-t border-slate-100"
        >
          <div
            class="p-4 bg-gradient-to-br from-slate-50 to-white rounded-xl border border-slate-200/60 shadow-sm group hover:border-emerald-600/30 transition-colors"
          >
            <div
              class="text-3xl font-extrabold text-emerald-600 tracking-tight"
            >
              {completedProjects.length}
            </div>
            <div
              class="text-xs font-semibold uppercase tracking-wider text-slate-400 mt-1"
            >
              Completed Deliveries
            </div>
          </div>
          <div
            class="p-4 bg-gradient-to-br from-slate-50 to-white rounded-xl border border-slate-200/60 shadow-sm group hover:border-orange-500/30 transition-colors"
          >
            <div class="text-3xl font-extrabold text-[#f97316] tracking-tight">
              {ongoingProjects.length}
            </div>
            <div
              class="text-xs font-semibold uppercase tracking-wider text-slate-400 mt-1"
            >
              Under Construction
            </div>
          </div>

          {/* Dynamic Social Media Integration */}
          {(socialLinksParsed.facebook || socialLinksParsed.instagram || socialLinksParsed.youtube) && (
            <div class="p-4 bg-gradient-to-br from-slate-50 to-white rounded-xl border border-slate-200/60 shadow-sm group hover:border-blue-500/30 transition-colors col-span-2 md:col-span-2 lg:col-span-2 flex flex-col justify-center">
              <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-3">
                Official Channels
              </div>
              <div class="flex items-center gap-3">
                {socialLinksParsed.facebook && (
                  <a href={socialLinksParsed.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-[#1877F2]/10 text-[#1877F2] flex items-center justify-center hover:bg-[#1877F2] hover:text-white transition-all shadow-sm">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                  </a>
                )}
                {socialLinksParsed.instagram && (
                  <a href={socialLinksParsed.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-[#E1306C]/10 text-[#E1306C] flex items-center justify-center hover:bg-gradient-to-tr hover:from-[#F58529] hover:via-[#DD2A7B] hover:to-[#8134AF] hover:text-white transition-all shadow-sm">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                  </a>
                )}
                {socialLinksParsed.youtube && (
                  <a href={socialLinksParsed.youtube} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-[#FF0000]/10 text-[#FF0000] flex items-center justify-center hover:bg-[#FF0000] hover:text-white transition-all shadow-sm">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                  </a>
                )}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Primary Layout Engine */}
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          {/* Core Profile Stack */}
          <div class="lg:col-span-2 space-y-10">
            {/* About Section Block */}
            <section
              class="bg-white p-6 md:p-8 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden"
            >
              <div
                class="w-1.5 h-8 bg-[#1e3a5f] absolute top-6 left-0 rounded-r"
              >
              </div>
              <h2 class="text-2xl font-bold text-[#0a1929] mb-5 tracking-tight">
                About {name}
              </h2>
              <div
                class="prose max-w-none text-slate-600 leading-relaxed font-normal"
                set:html={about_builder ||
                  `<p>${name} is a renowned real estate builder in ${city.name}, offering premium residential and commercial projects.</p>`}
              />

              {
                !full_profile && (
                  <div class="mt-8 p-5 bg-gradient-to-r from-amber-50 to-orange-50/50 border border-amber-200/70 rounded-xl flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                    <div class="flex items-start gap-3">
                      <svg
                        class="w-5 h-5 text-[#f97316] mt-0.5 flex-shrink-0"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                      <p class="text-amber-900 text-sm font-medium">
                        This profile is a verified structural business listing.
                        Are you the management representative?
                      </p>
                    </div>
                    <a
                      href="/contact"
                      class="font-bold text-xs uppercase tracking-wider text-white bg-[#1e3a5f] hover:bg-[#0a1929] px-4 py-2.5 rounded-lg whitespace-nowrap shadow-sm transition-all"
                    >
                      Claim Premium Profile
                    </a>
                  </div>
                )
              }
            </section>

            {/* Extended Premium Canvas */}
            {
              full_profile && (
                <>
                  {founder_details && (
                    <section class="bg-white p-6 md:p-8 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden">
                      <div class="w-1.5 h-8 bg-[#1e3a5f] absolute top-6 left-0 rounded-r" />
                      <h2 class="text-2xl font-bold text-[#0a1929] mb-5 tracking-tight">
                        Founder & Leadership
                      </h2>
                      <div
                        class="prose max-w-none text-slate-600 leading-relaxed"
                        set:html={founder_details}
                      />
                    </section>
                  )}

                  {formatList(awards).length > 0 && (
                    <section class="bg-white p-6 md:p-8 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden">
                      <div class="w-1.5 h-8 bg-[#f97316] absolute top-6 left-0 rounded-r" />
                      <h2 class="text-2xl font-bold text-[#0a1929] mb-5 tracking-tight">
                        Awards & Recognition
                      </h2>
                      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3.5">
                        {formatList(awards).map((award: string) => (
                          <li class="flex items-start gap-3 p-3.5 bg-slate-50/70 rounded-xl border border-slate-200/40 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">
                            <svg
                              class="w-5 h-5 text-[#f97316] flex-shrink-0 mt-0.5"
                              fill="currentColor"
                              viewBox="0 0 20 20"
                            >
                              <path
                                fill-rule="evenodd"
                                d="M10 2l1.64 5.093h5.36l-4.32 3.14 1.64 5.094L10 12.187l-4.32 3.14 1.64-5.094-4.32-3.14h5.36L10 2z"
                                clip-rule="evenodd"
                              />
                            </svg>
                            <span>{award}</span>
                          </li>
                        ))}
                      </ul>
                    </section>
                  )}

                  {formatList(videos).length > 0 && (
                    <section class="bg-white p-6 md:p-8 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden">
                      <div class="w-1.5 h-8 bg-[#1e3a5f] absolute top-6 left-0 rounded-r" />
                      <h2 class="text-2xl font-bold text-[#0a1929] mb-5 tracking-tight">
                        Digital Site Tours & Media
                      </h2>
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {formatList(videos).map((video: string) => (
                          <div class="aspect-w-16 aspect-h-9 rounded-xl overflow-hidden bg-slate-900 border border-slate-200/60 shadow-sm">
                            <iframe
                              src={video}
                              class="w-full h-full rounded-xl"
                              loading="lazy"
                              allowfullscreen
                            />
                          </div>
                        ))}
                      </div>
                    </section>
                  )}

                  {testimonialsList.length > 0 && (
                    <section class="bg-white p-6 md:p-8 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden">
                      <div class="w-1.5 h-8 bg-[#1e3a5f] absolute top-6 left-0 rounded-r" />
                      <h2 class="text-2xl font-bold text-[#0a1929] mb-5 tracking-tight">
                        Client Endorsements
                      </h2>
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {testimonialsList.map((t: any) => (
                          <div class="p-5 bg-gradient-to-br from-slate-50 to-white rounded-xl border border-slate-200/50 flex flex-col justify-between shadow-sm relative">
                            <div>
                              <div class="flex text-amber-400 gap-0.5 mb-3">
                                {[...Array(5)].map((_, i) => (
                                  <svg
                                    class={`w-4 h-4 ${i < (t.rating || 5) ? "fill-current" : "text-slate-200"}`}
                                    viewBox="0 0 20 20"
                                  >
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                  </svg>
                                ))}
                              </div>
                              <p class="text-slate-600 text-sm italic leading-relaxed">
                                "{t.content}"
                              </p>
                            </div>
                            <div class="text-xs font-semibold text-[#0a1929] mt-4 border-t border-slate-100 pt-3 flex items-center justify-between">
                              <span>- {t.name}</span>
                              <span class="text-[10px] text-slate-400 uppercase tracking-wide">
                                Verified Buyer
                              </span>
                            </div>
                          </div>
                        ))}
                      </div>
                    </section>
                  )}
                </>
              )
            }

            {/* Development Portfolio Array */}
            <section>
              <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-[#0a1929] tracking-tight">
                  Active Developments
                </h2>
                <span
                  class="text-xs font-bold uppercase tracking-wider bg-[#1e3a5f]/10 text-[#1e3a5f] px-3 py-1 rounded-full"
                  >{projects.length} Total</span
                >
              </div>
              {
                projects.length > 0 ? (
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {projects.map((project) => (
                      <div class="transform hover:-translate-y-1 transition-all duration-300">
                        <ProjectCard project={project} />
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="bg-white p-10 text-center rounded-2xl border border-dashed border-slate-300 shadow-sm max-w-md mx-auto">
                    <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 mx-auto mb-3">
                      <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                        />
                      </svg>
                    </div>
                    <p class="text-slate-500 font-medium text-sm">
                      No properties currently cataloged within {city.name}.
                    </p>
                  </div>
                )
              }
            </section>

            {/* Google Performance Analytics Summary */}
            {
              reviews && reviews.rating && (
                <section class="bg-white p-6 md:p-8 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden">
                  <div class="w-1.5 h-8 bg-emerald-500 absolute top-6 left-0 rounded-r" />
                  <h2 class="text-2xl font-bold text-[#0a1929] mb-5 tracking-tight">
                    Reputation Engine
                  </h2>
                  <div class="flex items-center gap-6 bg-slate-50 p-5 rounded-xl border border-slate-200/40">
                    <div class="text-5xl font-black text-[#0a1929] tracking-tighter bg-white px-4 py-3 rounded-xl shadow-sm border border-slate-100 flex items-center justify-center">
                      {reviews.rating}
                    </div>
                    <div>
                      <div class="flex text-amber-400 gap-0.5">
                        {[...Array(5)].map((_, i) => (
                          <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                          </svg>
                        ))}
                      </div>
                      <div class="text-xs font-bold uppercase tracking-wider text-slate-400 mt-2">
                        Aggregate Google Verified Score •{" "}
                        {reviews.count || "several"} testimonials
                      </div>
                    </div>
                  </div>
                </section>
              )
            }
          </div>

          {/* Dynamic Widget Console (Sidebar) */}
          <div class="space-y-6 lg:sticky lg:top-8">
            {/* Action Module Shield */}
            <div
              class="bg-white rounded-2xl border border-slate-200/80 shadow-md overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-slate-200/40"
            >
              <div
                class="bg-[#0a1929] p-4.5 border-b border-slate-800 flex items-center justify-between"
              >
                <h3
                  class="font-bold text-sm uppercase tracking-wider text-white"
                >
                  Builder Inquiry
                </h3>
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"
                ></span>
              </div>
              <div class="p-6">
                {
                  full_profile ? (
                    <div class="space-y-3">
                      {phone && (
                        <a
                          href={`tel:${phone.replace(/[^0-9+]/g, "")}`}
                          class="flex items-center gap-3.5 w-full py-3.5 px-4 bg-slate-50 hover:bg-[#1e3a5f]/5 text-slate-700 hover:text-[#1e3a5f] font-semibold text-sm rounded-xl transition-all border border-slate-200/50 hover:border-[#1e3a5f]/20 shadow-sm group"
                        >
                          <svg
                            class="w-5 h-5 text-slate-400 group-hover:text-[#1e3a5f] transition-colors flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            />
                          </svg>
                          <span class="truncate">{phone}</span>
                        </a>
                      )}
                      {whatsapp && (
                        <a
                          href={`https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}`}
                          target="_blank"
                          rel="noopener"
                          class="flex items-center gap-3.5 w-full py-3.5 px-4 bg-emerald-500/5 hover:bg-emerald-500/10 text-emerald-700 font-semibold text-sm rounded-xl transition-all border border-emerald-500/20 shadow-sm group"
                        >
                          <svg
                            class="w-5 h-5 text-emerald-600 flex-shrink-0"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                          </svg>
                          Connect on WhatsApp
                        </a>
                      )}
                      {email && (
                        <a
                          href={`mailto:${email}`}
                          class="flex items-center gap-3.5 w-full py-3.5 px-4 bg-slate-50 hover:bg-[#1e3a5f]/5 text-slate-700 hover:text-[#1e3a5f] font-semibold text-sm rounded-xl transition-all border border-slate-200/50 hover:border-[#1e3a5f]/20 shadow-sm group"
                        >
                          <svg
                            class="w-5 h-5 text-slate-400 group-hover:text-[#1e3a5f] transition-colors flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            />
                          </svg>
                          <span class="truncate">{email}</span>
                        </a>
                      )}
                      {website && (
                        <a
                          href={website}
                          target="_blank"
                          rel="noopener"
                          class="flex items-center gap-3.5 w-full py-3.5 px-4 bg-slate-50 hover:bg-[#1e3a5f]/5 text-slate-700 hover:text-[#1e3a5f] font-semibold text-sm rounded-xl transition-all border border-slate-200/50 hover:border-[#1e3a5f]/20 shadow-sm group"
                        >
                          <svg
                            class="w-5 h-5 text-slate-400 group-hover:text-[#1e3a5f] transition-colors flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                            />
                          </svg>
                          <span>Corporate Portfolio</span>
                        </a>
                      )}

                      {/* Lead Generation Routing Engine */}
                      <div class="pt-5 mt-4 border-t border-slate-100">
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-3.5">
                          Schedule Structural Consultation
                        </p>
                        <form class="space-y-3.5">
                          <div>
                            <input
                              type="text"
                              placeholder="Full Name"
                              class="w-full px-4 py-3 border border-slate-200 bg-slate-50/50 text-slate-800 rounded-xl text-sm focus:bg-white focus:ring-2 focus:ring-[#1e3a5f]/20 focus:border-[#1e3a5f] outline-none transition-all placeholder:text-slate-400"
                              required
                            />
                          </div>
                          <div>
                            <input
                              type="tel"
                              placeholder="Mobile Number"
                              class="w-full px-4 py-3 border border-slate-200 bg-slate-50/50 text-slate-800 rounded-xl text-sm focus:bg-white focus:ring-2 focus:ring-[#1e3a5f]/20 focus:border-[#1e3a5f] outline-none transition-all placeholder:text-slate-400"
                              required
                            />
                          </div>
                          <div>
                            <textarea
                              placeholder="Enquiry Parameters..."
                              rows="3"
                              class="w-full px-4 py-3 border border-slate-200 bg-slate-50/50 text-slate-800 rounded-xl text-sm focus:bg-white focus:ring-2 focus:ring-[#1e3a5f]/20 focus:border-[#1e3a5f] outline-none transition-all placeholder:text-slate-400 resize-none"
                              required
                            />
                          </div>
                          <button
                            type="submit"
                            class="w-full py-3.5 bg-[#f97316] hover:bg-[#e2620d] text-white font-bold rounded-xl text-xs uppercase tracking-wider shadow-md shadow-orange-500/10 hover:shadow-orange-500/20 active:scale-[0.99] transition-all"
                          >
                            Submit Request
                          </button>
                        </form>
                      </div>
                    </div>
                  ) : (
                    <div class="text-center py-4">
                      <div class="w-14 h-14 mx-auto mb-4 bg-amber-50 border border-amber-200 text-[#f97316] rounded-2xl flex items-center justify-center shadow-sm">
                        <svg
                          class="w-6 h-6"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
                          />
                        </svg>
                      </div>
                      <h4 class="font-bold text-[#0a1929] text-base mb-1.5">
                        Premium Verification Required
                      </h4>
                      <p class="text-xs text-slate-500 max-w-xs mx-auto leading-relaxed mb-5">
                        Direct digital integrations, contact strings, and
                        localized brochure access require full property
                        verification.
                      </p>
                      <a
                        href="/contact"
                        class="inline-block w-full py-3 bg-[#1e3a5f] hover:bg-[#0a1929] text-white font-bold rounded-xl text-xs uppercase tracking-wider text-center shadow-sm transition-colors"
                      >
                        Claim Profile to Unlock
                      </a>
                    </div>
                  )
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
