---
export const prerender = false;
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import ProjectCard from "../../../../components/ProjectCard.astro";
import FAQSection from "../../../../components/FAQSection.astro";
import { supabase } from "../../../../lib/supabase";
import {
  buildBreadcrumbSchema,
  buildProjectSchema,
  buildFAQSchema,
  generateProjectFAQs,
  generateProjectDescription,
  formatStatus,
  formatProjectType,
} from "../../../../lib/seo";
import type { City, Locality, Project, FloorPlan } from "../../../../lib/types";

const { city: citySlug, type: projectType, locality: localitySlug, slug } =
  Astro.params;

const { data: cityData } = await supabase
  .from('cities')
  .select('*')
  .eq('slug', citySlug as string)
  .single();

if (!cityData) {
  return new Response(null, { status: 404 });
}

const { data: localityData } = await supabase
  .from("localities")
  .select("*")
  .eq("city_id", (cityData as City).id)
  .eq("slug", localitySlug as string)
  .single();

if (!localityData) {
  return new Response(null, { status: 404 });
}

const { data: projectData } = await supabase
  .from("projects")
  .select("*")
  .eq('city_id', (cityData as City).id)
  .eq('project_type', projectType as string)
  .eq('slug', slug as string)
  .maybeSingle();

Astro.response.headers.set('Cache-Control', 'public, s-maxage=86400, stale-while-revalidate=604800');

if (!projectData) {
  return new Response(null, { status: 404 });
}

const city = cityData as City;
const locality = localityData as Locality;
const project = projectData as Project;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/['"]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const requestedLocalitySlug = String(localitySlug || "").toLowerCase();
let actualLocalitySlug = "";

const projectLocalityId = (project as any)?.locality_id as string | null | undefined;
if (projectLocalityId) {
  const { data: locById } = await supabase
    .from("localities")
    .select("slug")
    .eq("id", projectLocalityId)
    .maybeSingle();
  actualLocalitySlug = String((locById as any)?.slug || "").toLowerCase();
}

if (!actualLocalitySlug && typeof (project as any)?.location === "string" && (project as any).location.trim()) {
  const { data: locByName } = await supabase
    .from("localities")
    .select("slug")
    .eq("city_id", city.id)
    .eq("name", String((project as any).location).trim())
    .maybeSingle();
  actualLocalitySlug = String((locByName as any)?.slug || "").toLowerCase();
}

// If we know the project's canonical locality slug and it doesn't match the URL, redirect.
if (actualLocalitySlug && actualLocalitySlug !== requestedLocalitySlug) {
  return new Response(null, {
    status: 301,
    headers: {
      Location: `/${city.slug}/${project.project_type}/${actualLocalitySlug}/${project.slug}`,
    },
  });
}

// Fallback validation for projects without locality relation filled in.
// Don't 404 on mismatch; render the project (better UX), but still validate obvious matches.
const locationSlug = typeof project.location === "string" ? slugify(project.location) : "";
void locationSlug;

let relatedProjects: (Project & { city?: City })[] = [];
let galleryImages: string[] = [];
let featuredImage = "";
let floorPlans: FloorPlan[] = [];
let faqs: { question: string; answer: string }[] = [];
let statusLabel = "";
let typeLabel = "";
let breadcrumbSchema: any = null;
let projectSchema: any = null;
let faqSchema: any = null;

const { data: relatedData } = await supabase
  .from("projects")
  .select("*")
  .eq("city_id", city.id)
  .eq("project_type", project.project_type)
  .neq("id", project.id)
  .limit(4);

{
  const { data: cityLocalitiesData } = await supabase
    .from("localities")
    .select("id,slug,name")
    .eq("city_id", city.id);
  const cityLocalities = (cityLocalitiesData || []) as any[];
  const localityById = new Map(cityLocalities.map((l) => [l.id, l]));
  const localityByName = new Map(cityLocalities.map((l) => [String(l.name).toLowerCase(), l]));

  relatedProjects = (relatedData || []).map((p: any) => {
    const byId = p.locality_id ? localityById.get(p.locality_id) : undefined;
    const byName = !byId && p.location ? localityByName.get(String(p.location).trim().toLowerCase()) : undefined;
    const loc = byId || byName;
    return loc
      ? ({ ...(p as any), city, locality: { slug: loc.slug, name: loc.name } } as any)
      : ({ ...(p as any), city } as any);
  });
}

  galleryImages = Array.isArray(project.gallery_images)
    ? project.gallery_images.map((s) => String(s || "").trim()).filter(Boolean)
    : typeof (project as any)?.gallery_images === "string"
      ? String((project as any).gallery_images)
          .split("\n")
          .map((s) => s.trim())
          .filter(Boolean)
      : [];

  featuredImage =
    typeof (project as any)?.featured_image === "string" &&
    String((project as any).featured_image).trim()
      ? String((project as any).featured_image).trim()
      : galleryImages[0] || "";

  floorPlans = Array.isArray(project.floor_plans) ? project.floor_plans : [];
  const hasCustomFaqs =
    !!(project as any)?.use_custom_faqs &&
    Array.isArray((project as any)?.custom_faqs) &&
    (project as any).custom_faqs.length > 0;
  faqs = hasCustomFaqs ? (project as any).custom_faqs : generateProjectFAQs(project, city);
  statusLabel = formatStatus(project.project_status);
  typeLabel = formatProjectType(project.project_type);

breadcrumbSchema = buildBreadcrumbSchema([
    { name: "Home", url: "https://homenesto.com" },
    { name: city.name, url: `https://homenesto.com/${city.slug}` },
    {
      name: typeLabel,
      url: `https://homenesto.com/${city.slug}/${project.project_type}`,
    },
    {
      name: locality.name,
      url: `https://homenesto.com/${city.slug}/${project.project_type}/${locality.slug}`,
    },
    {
      name: project.title,
      url: `https://homenesto.com/${city.slug}/${project.project_type}/${locality.slug}/${project.slug}`,
    },
  ]);
projectSchema = buildProjectSchema(project, city);
faqSchema = buildFAQSchema(faqs);
---
<BaseLayout
  title={project.meta_title ||
    `${project.title} ${city.name} | ${project.builder_name} - ${project.price_range}`}
  description={project.meta_description ||
    generateProjectDescription(project, city)}
  ogImage={featuredImage || undefined}
  jsonLd={[breadcrumbSchema, projectSchema, faqSchema]}
  breadcrumbs={[
    { name: city.name, url: `/${city.slug}` },
    { name: typeLabel, url: `/${city.slug}/${project.project_type}` },
    { name: locality.name, url: `/${city.slug}/${project.project_type}/${locality.slug}` },
    {
      name: project.title,
      url: `/${city.slug}/${project.project_type}/${locality.slug}/${project.slug}`,
    },
  ]}
>
<!-- Project Hero Gallery -->
<section class="bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    {
      (() => {
        const allGalleryImages = [
          ...(featuredImage ? [featuredImage] : []),
          ...galleryImages.filter((img) => img !== featuredImage),
        ];

        return (
          <div class="grid grid-cols-1 gap-4">

            <!-- Main Preview -->
            <div class="relative overflow-hidden rounded-2xl bg-black border border-white/10">
              <img
                id="mainGalleryImage"
                src={allGalleryImages[0] || ""}
                alt={`${project.title} - ${project.project_type} project in ${project.location}, ${city.name}`}
                class="w-full h-[260px] sm:h-[400px] md:h-[550px] object-contain bg-black"
                loading="eager"
                fetchpriority="high"
                width="1200"
                height="675"
              />

              <div class="absolute top-4 left-4 flex gap-2 z-10">
                <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-white/90 text-gray-800 backdrop-blur-sm">
                  {statusLabel}
                </span>

                <span class="text-xs font-semibold px-3 py-1.5 rounded-full bg-accent-500 text-white">
                  {typeLabel}
                </span>
              </div>
            </div>

            <!-- Thumbnails -->
            {
              allGalleryImages.length > 1 && (
                <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3">

                  {allGalleryImages.map((img, i) => (
                    <button
                      type="button"
                      class="gallery-thumb relative aspect-square overflow-hidden rounded-xl border border-white/10 bg-gray-800 hover:border-accent-500 transition-all"
                      data-image={img}
                    >
                      <img
                        src={img}
                        alt={`${project.title} gallery image ${i + 1}`}
                        loading="lazy"
                        class="w-full h-full object-cover"
                        width="200"
                        height="200"
                      />

                      {
                        i === 4 && allGalleryImages.length > 5 && (
                          <div class="absolute inset-0 bg-black/70 flex items-center justify-center text-white font-bold text-lg">
                            +{allGalleryImages.length - 5} More
                          </div>
                        )
                      }
                    </button>
                  ))}

                </div>
              )
            }

          </div>
        );
      })()
    }

  </div>
</section>

<script is:inline>
  const mainImage = document.getElementById("mainGalleryImage");

  document.querySelectorAll(".gallery-thumb").forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const image = thumb.getAttribute("data-image");

      if (mainImage && image) {
        mainImage.setAttribute("src", image);
      }
    });
  });
</script>

  <!-- Project Info -->
  <section class="py-8">
