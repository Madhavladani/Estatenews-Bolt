---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="List Your Project / Properties | PropDiscover"
  description="List your real estate project or property on PropDiscover and reach serious buyers and investors."
>
  <section class="py-14 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">List Your Project / Properties</h1>
      <p class="text-gray-600 mb-8">Showcase your project to thousands of property seekers across Gujarat.</p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl border border-gray-100 p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Why list with us?</h2>
          <ul class="space-y-3 text-gray-700">
            <li>High-intent audience focused on real estate.</li>
            <li>City and project type based visibility.</li>
            <li>Dedicated support for listing optimization.</li>
            <li>Fast review and publishing workflow.</li>
          </ul>
        </div>
        <form class="bg-white rounded-2xl border border-gray-100 p-6 space-y-4">
          <h2 class="text-xl font-semibold text-gray-900">Submit Listing Request</h2>
          <input type="text" placeholder="Full Name" class="w-full rounded-lg border border-gray-300 px-3 py-2" />
          <input type="text" placeholder="Company / Builder Name" class="w-full rounded-lg border border-gray-300 px-3 py-2" />
          <input type="email" placeholder="Email Address" class="w-full rounded-lg border border-gray-300 px-3 py-2" />
          <input type="tel" placeholder="Phone Number" class="w-full rounded-lg border border-gray-300 px-3 py-2" />
          <input type="text" placeholder="Project / Property Name" class="w-full rounded-lg border border-gray-300 px-3 py-2" />
          <textarea rows="4" placeholder="Tell us about your listing..." class="w-full rounded-lg border border-gray-300 px-3 py-2"></textarea>
          <button type="button" class="w-full px-5 py-2.5 bg-primary-700 hover:bg-primary-800 text-white rounded-lg text-sm font-semibold">Submit</button>
          <p class="text-xs text-gray-500">Our team will contact you shortly after reviewing your request.</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
