---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Land Unit / Area Converter | Home Nesto"
  description="Easily convert between various land units like Square Feet, Square Yards, Acre, Bigha, Guntha, and more."
>
  <header class="page-header">
    <span class="header-badge">🔄 Unit Converter</span>
    <h1>Land Unit / Area Converter<span class="accent-dot">.</span></h1>
    <p>
      Instant conversion between regional and standard area units across India.
    </p>
  </header>

  <main class="main-container">
    <div class="calculator-card">
      <div class="input-grid">
        <div class="input-group">
          <label for="fromValue">Value to Convert</label>
          <div class="input-wrapper">
            <input type="number" id="fromValue" value="1000" step="1" />
          </div>
        </div>

        <div class="input-group">
          <label for="fromUnit">From Unit</label>
          <select id="fromUnit" class="custom-select">
            <option value="1" selected>Square Feet (Sq. Ft.)</option>
            <option value="9">Square Yards (Gaj)</option>
            <option value="10.7639">Square Meters</option>
            <option value="43560">Acre</option>
            <option value="1089">Guntha</option>
            <option value="27225">Bigha (UP/Punjab)</option>
            <option value="17424">Bigha (Bengal)</option>
            <option value="435.6">Cent</option>
          </select>
        </div>

        <div class="input-group">
          <label for="toUnit">To Unit</label>
          <select id="toUnit" class="custom-select">
            <option value="1">Square Feet (Sq. Ft.)</option>
            <option value="9" selected>Square Yards (Gaj)</option>
            <option value="10.7639">Square Meters</option>
            <option value="43560">Acre</option>
            <option value="1089">Guntha</option>
            <option value="27225">Bigha (UP/Punjab)</option>
            <option value="17424">Bigha (Bengal)</option>
            <option value="107639">Hectare</option>
            <option value="435.6">Cent</option>
          </select>
        </div>
      </div>

      <div class="calc-btn-wrapper">
        <button id="convertBtn" class="btn-calculate">Convert Area</button>
        <button id="resetBtn" class="btn-reset">↺ Reset</button>
      </div>

      <div id="resultContainer" class="results-container">
        <p class="result-header">🔄 Conversion Result</p>
        <div class="result-inner-grid">
          <div class="result-item emi-highlight">
            <p class="result-label">Converted Value</p>
            <p id="resultText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Base Sq. Ft.</p>
            <p id="baseSqFtText" class="result-value">—</p>
          </div>
        </div>
      </div>
    </div>

    <section class="faq-section">
      <h2>Area Conversion FAQ</h2>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>How many Sq. Yards are in 1 Acre?</summary>
          <div class="faq-answer">
            1 Acre is equal to 4,840 Square Yards or 43,560 Square Feet.
          </div>
        </details>
        <details class="faq-item">
          <summary>Is Bigha the same everywhere in India?</summary>
          <div class="faq-answer">
            No, the size of a Bigha varies by state. For example, in UP it's approx 27,000 sq ft, whereas in West Bengal it's approx 17,424 sq ft.
          </div>
        </details>
      </div>
    </section>
    <div style="margin-top: 3rem; text-align: center;">
      <a href="/tools/" style="color: var(--accent); font-weight: 700; text-decoration: none;">← Back to All Tools</a>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  function convertArea() {
    const val = parseFloat(document.getElementById('fromValue').value) || 0;
    const fromFactor = parseFloat(document.getElementById('fromUnit').value);
    const toFactor = parseFloat(document.getElementById('toUnit').value);

    const baseSqFt = val * fromFactor;
    const converted = baseSqFt / toFactor;

    document.getElementById('resultText').innerText = converted.toLocaleString(undefined, {maximumFractionDigits: 4});
    document.getElementById('baseSqFtText').innerText = baseSqFt.toLocaleString() + ' Sq. Ft.';
    
    document.getElementById('resultContainer').classList.add('visible');
  }

  document.getElementById('convertBtn').addEventListener('click', convertArea);
  document.getElementById('resetBtn').addEventListener('click', () => { location.reload(); });
</script>

<style is:global>
  :root {
    --primary: #1e3a5f;
    --accent: #f97316;
    --text-dark: #1a1a2e;
    --text-medium: #4a5568;
    --text-light: #718096;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-200: #e2e8f0;
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
    --radius-xl: 24px;
  }
  .page-header { background: linear-gradient(160deg, #0a1929 0%, #0d2137 40%, #122d4a 100%); padding: 3rem 1.5rem 3.5rem; text-align: center; color: white; }
  .header-badge { background: rgba(249, 115, 22, 0.15); color: #fca35d; padding: 0.35rem 1rem; border-radius: 50px; font-size: 0.8rem; margin-bottom: 1rem; display: inline-block; }
  .main-container { max-width: 960px; margin: -2rem auto 0; padding: 0 1.25rem 3rem; }
  .calculator-card { background: white; border-radius: var(--radius-xl); padding: 2.5rem; box-shadow: var(--shadow-lg); }
  .input-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
  .input-group label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; }
  .custom-select { width: 100%; padding: 0.75rem; border: 2px solid #e2e8f0; border-radius: 12px; font-size: 1rem; background: white; }
  .input-group input { width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--gray-200); border-radius: 12px; font-size: 1.1rem; }
  .calc-btn-wrapper { display: flex; gap: 1rem; }
  .btn-calculate { background: var(--accent); color: white; border: none; padding: 1rem 2rem; border-radius: 50px; font-weight: 700; cursor: pointer; }
  .results-container { margin-top: 2rem; background: #1e3a5f; color: white; padding: 2rem; border-radius: 20px; display: none; }
  .results-container.visible { display: block; }
  .result-inner-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .result-item { background: rgba(255,255,255,0.1); padding: 1.25rem; border-radius: 15px; }
  @media (max-width: 768px) { .input-grid { grid-template-columns: 1fr; } .result-inner-grid { grid-template-columns: 1fr; } }
</style>
