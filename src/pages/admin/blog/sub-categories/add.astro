---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabase } from '../../../../lib/supabase';
import type { BlogCategory, BlogSubCategory } from '../../../../lib/types';

const id = Astro.url.searchParams.get('id');
let subCategory: BlogSubCategory | null = null;

if (id) {
  const { data } = await supabase.from('blog_sub_categories').select('*').eq('id', id).single();
  subCategory = data;
}

const { data: categories } = await supabase.from('blog_categories').select('id, name').order('name');
const allCategories = (categories || []) as BlogCategory[];

const pageTitle = subCategory ? 'Edit Sub-category' : 'Add Sub-category';
---

<AdminLayout title={pageTitle} activeTab="blog">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/blog/sub-categories" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-2xl">
    <form id="subcategory-form" class="space-y-6">
      <input type="hidden" id="s-id" value={subCategory?.id || ''} />
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Parent Category *</label>
        <select id="s-category-id" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">
          <option value="">Select Category</option>
          {allCategories.map(c => (
            <option value={c.id} selected={subCategory?.category_id === c.id}>{c.name}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
        <input type="text" id="s-name" required value={subCategory?.name || ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
        <input type="text" id="s-slug" required value={subCategory?.slug || ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Image URL (Sub-category Card)</label>
        <div class="flex gap-2">
          <input type="text" id="s-image-url" value={subCategory?.image_url || ''} class="flex-1 px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" placeholder="https://..." />
          <button type="button" id="upload-img-btn" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium transition-colors">
            Upload
          </button>
        </div>
        <div id="image-preview" class="mt-4 hidden">
          <img src={subCategory?.image_url || ''} alt={subCategory?.name ? `${subCategory.name} preview image` : 'Sub-category preview image'} class="w-32 h-32 object-cover rounded-lg border border-gray-100" />
        </div>
      </div>

      <div class="flex items-center gap-2">
        <input 
          type="checkbox" 
          id="s-show-in-scroller" 
          checked={subCategory?.show_in_scroller} 
          class="w-4 h-4 text-primary-600 border-gray-300 rounded focus:ring-primary-500" 
        />
        <label for="s-show-in-scroller" class="text-sm font-medium text-gray-700">Show in Scroller (Blog Page)</label>
      </div>

      <div class="pt-4 border-t border-gray-100">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">SEO Metadata</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
            <input type="text" id="s-meta-title" value={subCategory?.meta_title || ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
            <textarea id="s-meta-desc" rows="3" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">{subCategory?.meta_description || ''}</textarea>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-4">
        <a href="/admin/blog/sub-categories" class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm hover:bg-gray-50">Cancel</a>
        <button type="submit" class="px-6 py-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg text-sm transition-colors">
          Save Sub-category
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('subcategory-form') as HTMLFormElement;
  const nameInput = document.getElementById('s-name') as HTMLInputElement;
  const slugInput = document.getElementById('s-slug') as HTMLInputElement;
  const idInput = document.getElementById('s-id') as HTMLInputElement;
  const imageInput = document.getElementById('s-image-url') as HTMLInputElement;
  const imagePreview = document.getElementById('image-preview') as HTMLDivElement;
  const uploadBtn = document.getElementById('upload-img-btn') as HTMLButtonElement;

  if (imageInput.value) imagePreview.classList.remove('hidden');

  nameInput.addEventListener('input', () => {
    if (idInput.value) return;
    slugInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  });

  uploadBtn.addEventListener('click', () => {
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/*';
    fileInput.onchange = async () => {
      const file = fileInput.files?.[0];
      if (!file) return;

      uploadBtn.textContent = 'Uploading...';
      uploadBtn.disabled = true;

      const formData = new FormData();
      formData.append('file', file);
      formData.append('path', 'blog-subcategories');

      const res = await fetch('/admin/api/upload-image', {
        method: 'POST',
        body: formData
      });

      if (res.ok) {
        const data = await res.json();
        imageInput.value = data.url;
        (imagePreview.querySelector('img') as HTMLImageElement).src = data.url;
        imagePreview.classList.remove('hidden');
      } else {
        alert('Upload failed');
      }
      uploadBtn.textContent = 'Upload';
      uploadBtn.disabled = false;
    };
    fileInput.click();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = idInput.value;
    const body = {
      category_id: (document.getElementById('s-category-id') as HTMLSelectElement).value,
      name: nameInput.value,
      slug: slugInput.value,
      image_url: imageInput.value,
      show_in_scroller: (document.getElementById('s-show-in-scroller') as HTMLInputElement).checked,
      meta_title: (document.getElementById('s-meta-title') as HTMLInputElement).value,
      meta_description: (document.getElementById('s-meta-desc') as HTMLTextAreaElement).value,
    };

    const res = await fetch(id ? `/admin/api/blog-sub-categories?id=${id}` : '/admin/api/blog-sub-categories', {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) window.location.href = '/admin/blog/sub-categories';
    else {
      const err = await res.json();
      alert(err.error || 'Failed to save sub-category');
    }
  });
</script>
