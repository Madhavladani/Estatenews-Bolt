---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { City, Blog } from '../../../lib/types';

const { data: citiesRes } = await supabase.from('cities').select('*').order('name');
const cities: City[] = citiesRes || [];

const { data: collectionsRes } = await supabase.from('collections').select('id, title').order('title');
const allCollections = collectionsRes || [];

const blogId = Astro.url.searchParams.get('id');
let articleToEdit: any = null;
if (blogId) {
  const { data } = await supabase.from('news').select('*').eq('id', blogId).single();
  articleToEdit = data;
}

const { data: authorsRes } = await supabase.from('authors' as any).select('id, full_name').order('full_name');
const authors: { id: string; full_name: string }[] = authorsRes || [];

const { data: categoriesRes } = await supabase.from('blog_categories').select('*, sub_categories:blog_sub_categories(*)').order('name');
const categoriesList = categoriesRes || [];

const pageTitle = articleToEdit ? 'Edit Blog' : 'Add Blog';
---

<AdminLayout title={pageTitle} activeTab="blog">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/blog" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-4xl">
    <form id="news-form" class="space-y-6">
      <input type="hidden" id="n-id" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title *</label>
          <input type="text" id="n-title" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
          <input type="text" id="n-slug" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Author *</label>
          <select id="n-author-id" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">Select Author</option>
            {authors.map((a) => <option value={a.id} selected={articleToEdit?.author_id === a.id}>{a.full_name}</option>)}
          </select>
          <div class="mt-1 flex items-center justify-between">
            <p class="text-xs text-gray-500">Assign an author from the database.</p>
            <a href="/admin/authors/add" target="_blank" class="text-xs text-primary-600 hover:text-primary-700 font-medium">+ Create New Author</a>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Related City (optional)</label>
          <select id="n-city" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">None</option>
            {cities.map((c) => <option value={c.id}>{c.name}</option>)}
          </select>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Featured Image</label>
          <div class="space-y-3">
            <div class="flex gap-3">
              <input type="url" id="n-featured" class="flex-1 px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="https://..." />
              <label class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium cursor-pointer transition-colors whitespace-nowrap flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                <span>Upload</span>
                <input type="file" id="n-featured-file" accept="image/*" class="hidden" />
              </label>
            </div>
            <p id="n-featured-status" class="text-xs text-gray-500"></p>
            <div id="n-featured-preview-container" class="hidden relative inline-block">
              <img id="n-featured-preview" class="max-h-48 rounded-lg border border-gray-200" />
            </div>
          </div>
          <p class="mt-1 text-xs text-gray-500">Used on cards + blog header. High resolution images are auto-compressed.</p>
        </div>
        <div class="flex items-end">
          <label class="inline-flex items-center gap-2 text-sm font-medium text-gray-700">
            <input type="checkbox" id="n-published" class="rounded border-gray-300 text-primary-700 focus:ring-primary-500" />
            Published
          </label>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Excerpt</label>
        <textarea id="n-excerpt" rows="2" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Content (HTML) *</label>
        <!-- Tiptap Toolbar -->
        <div id="tiptap-toolbar" class="flex flex-wrap items-center gap-1 p-2 border border-gray-200 rounded-t-lg bg-gray-50/80">
          <button type="button" data-action="bold" title="Bold (Ctrl+B)" class="tt-btn"><strong>B</strong></button>
          <button type="button" data-action="italic" title="Italic (Ctrl+I)" class="tt-btn"><em>I</em></button>
          <button type="button" data-action="underline" title="Underline (Ctrl+U)" class="tt-btn" style="text-decoration:underline">U</button>
          <button type="button" data-action="strike" title="Strikethrough" class="tt-btn"><s>S</s></button>
          <span class="tt-sep"></span>
          <button type="button" data-action="h1" title="Heading 1" class="tt-btn tt-btn-sm">H1</button>
          <button type="button" data-action="h2" title="Heading 2" class="tt-btn tt-btn-sm">H2</button>
          <button type="button" data-action="h3" title="Heading 3" class="tt-btn tt-btn-sm">H3</button>
          <button type="button" data-action="h4" title="Heading 4" class="tt-btn tt-btn-sm">H4</button>
          <span class="tt-sep"></span>
          <button type="button" data-action="bulletList" title="Bullet List" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <button type="button" data-action="orderedList" title="Ordered List" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h8"/></svg>
          </button>
          <button type="button" data-action="blockquote" title="Blockquote" class="tt-btn">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
          </button>
          <span class="tt-sep"></span>
          <button type="button" data-action="link" title="Insert/Edit Link" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </button>
          <button type="button" data-action="image" title="Insert Image URL" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </button>
          <button type="button" data-action="horizontalRule" title="Horizontal Rule" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-width="2" d="M5 12h14"/></svg>
          </button>
          <button type="button" data-action="codeBlock" title="Code Block" class="tt-btn tt-btn-sm font-mono">&lt;/&gt;</button>
          <span class="tt-sep"></span>
          <button type="button" data-action="undo" title="Undo (Ctrl+Z)" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a5 5 0 015 5v2M3 10l4-4m-4 4l4 4"/></svg>
          </button>
          <button type="button" data-action="redo" title="Redo (Ctrl+Y)" class="tt-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 10H11a5 5 0 00-5 5v2m15-7l-4-4m4 4l-4 4"/></svg>
          </button>
          <span class="tt-sep"></span>
          <button type="button" id="tt-source-toggle" title="Toggle HTML Source" class="tt-btn tt-btn-sm font-mono">HTML</button>
        </div>
        <!-- Tiptap Editor -->
        <div id="tiptap-editor" class="border border-gray-200 border-t-0 rounded-b-lg bg-white min-h-[300px] focus-within:ring-2 focus-within:ring-primary-500 transition-shadow"></div>
        <!-- Source textarea (hidden by default) -->
        <textarea id="n-content-source" class="hidden w-full px-4 py-3 border border-gray-200 border-t-0 rounded-b-lg text-sm font-mono focus:ring-2 focus:ring-primary-500 outline-none transition-shadow min-h-[300px] resize-y bg-gray-900 text-green-400"></textarea>
        <!-- Hidden data textarea for form submission -->
        <textarea id="n-content" class="hidden"></textarea>
        <p class="mt-1 text-xs text-gray-500">Rich text editor — click <strong>HTML</strong> to view/edit raw source code.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Category *</label>
          <select id="n-category-id" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">Select Category</option>
            {categoriesList.map(c => (
              <option value={c.id} selected={articleToEdit?.category_id === c.id}>{c.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Sub-category</label>
          <select id="n-sub-category-id" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">None</option>
            {/* Populated by JS */}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tags (comma separated)</label>
          <input type="text" id="n-tags" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="gujarat, ahmedabad, market" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Publish Date</label>
          <input type="datetime-local" id="n-published-at" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>

      <div class="border-t border-gray-100 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">SEO</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
            <input type="text" id="n-meta-title" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="block text-sm font-medium text-gray-700">OG Image URL</label>
              <button type="button" id="n-og-use-featured" class="text-xs text-primary-600 hover:text-primary-700 font-medium">Use featured image</button>
            </div>
            <input type="url" id="n-og-image" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="https://..." />
            <div id="n-og-preview-container" class="hidden mt-2 relative inline-block">
              <img id="n-og-preview" class="max-h-32 rounded-lg border border-gray-200" />
            </div>
          </div>
        </div>

        <div class="mt-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
          <textarea id="n-meta-desc" rows="2" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Meta Keywords</label>
            <input type="text" id="n-meta-keywords" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="keyword1, keyword2" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Canonical Path (optional)</label>
            <input type="text" id="n-canonical" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="/blog/my-slug" />
          </div>
        </div>

        <div class="mt-6">
          <label class="inline-flex items-center gap-2 text-sm font-medium text-gray-700">
            <input type="checkbox" id="n-noindex" class="rounded border-gray-300 text-primary-700 focus:ring-primary-500" />
            Noindex (exclude from search)
          </label>
        </div>
      </div>

      <div class="border-t border-gray-100 pt-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Frequently Asked Questions</h2>
          <button type="button" id="n-add-faq" class="px-3 py-1.5 text-sm bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg font-medium transition-colors cursor-pointer">+ Add Question</button>
        </div>
        <div id="n-faq-container" class="space-y-4 empty:hidden">
          <p class="text-sm text-gray-500 hidden">No FAQs added yet.</p>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/admin/blog" class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm hover:bg-gray-50">Cancel</a>
        <button type="submit" class="px-5 py-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg text-sm transition-colors">
          Save
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script define:vars={{ articleToEdit, categoriesList }}>
  const form = document.getElementById('news-form');
  const titleInput = document.getElementById('n-title');
  const slugInput = document.getElementById('n-slug');
  const featuredInput = document.getElementById('n-featured');
  const ogImageInput = document.getElementById('n-og-image');
  const featuredFileInput = document.getElementById('n-featured-file');
  const featuredStatus = document.getElementById('n-featured-status');
  const featuredPreview = document.getElementById('n-featured-preview');
  const featuredPreviewContainer = document.getElementById('n-featured-preview-container');
  const ogPreview = document.getElementById('n-og-preview');
  const ogPreviewContainer = document.getElementById('n-og-preview-container');
  const faqContainer = document.getElementById('n-faq-container');
  const addFaqBtn = document.getElementById('n-add-faq');
  const categorySelect = document.getElementById('n-category-id');
  const subCategorySelect = document.getElementById('n-sub-category-id');

  function populateSubCategories(categoryId, selectedId = null) {
    if (!subCategorySelect || !categoryId) return;
    subCategorySelect.innerHTML = '<option value="">None</option>';
    const category = categoriesList.find(c => c.id == categoryId);
    if (category && category.sub_categories) {
      category.sub_categories.forEach(sub => {
        const option = document.createElement('option');
        option.value = sub.id;
        option.textContent = sub.name;
        if (sub.id === selectedId) option.selected = true;
        subCategorySelect.appendChild(option);
      });
    }
  }

  categorySelect?.addEventListener('change', (e) => {
    populateSubCategories(e.target.value);
  });

  function createFaqElement(question = '', answer = '') {
    const div = document.createElement('div');
    div.className = 'faq-item bg-gray-50 p-4 rounded-lg relative border border-gray-100';
    div.innerHTML = `
      <button type="button" class="remove-faq absolute top-3 right-3 text-red-500 hover:text-red-700 p-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
      <div class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Question</label>
          <input type="text" class="faq-question w-full px-3 py-1.5 border border-gray-200 rounded text-sm focus:ring-2 focus:ring-primary-500 outline-none" value="${question.replace(/"/g, '&quot;')}" />
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-700 mb-1">Answer</label>
          <textarea rows="2" class="faq-answer w-full px-3 py-1.5 border border-gray-200 rounded text-sm focus:ring-2 focus:ring-primary-500 outline-none">${answer.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</textarea>
        </div>
      </div>
    `;
    div.querySelector('.remove-faq').addEventListener('click', () => div.remove());
    return div;
  }

  addFaqBtn?.addEventListener('click', () => {
    faqContainer.appendChild(createFaqElement());
  });

  function toLocalDatetimeValue(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const pad = (n) => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
  }

  if (articleToEdit) {
    document.getElementById('n-id').value = articleToEdit.id || '';
    titleInput.value = articleToEdit.title || '';
    slugInput.value = articleToEdit.slug || '';
    document.getElementById('n-author-id').value = articleToEdit.author_id || '';
    document.getElementById('n-city').value = articleToEdit.city_id || '';
    document.getElementById('n-featured').value = articleToEdit.featured_image || '';
    document.getElementById('n-published').checked = !!articleToEdit.is_published;
    document.getElementById('n-excerpt').value = articleToEdit.excerpt || '';
    document.getElementById('n-content').value = articleToEdit.content_html || '';
    document.getElementById('n-tags').value = (articleToEdit.tags || []).join(', ');
    document.getElementById('n-category-id').value = articleToEdit.category_id || '';
    populateSubCategories(articleToEdit.category_id, articleToEdit.sub_category_id);
    document.getElementById('n-published-at').value = toLocalDatetimeValue(articleToEdit.published_at);
    document.getElementById('n-meta-title').value = articleToEdit.meta_title || '';
    document.getElementById('n-meta-desc').value = articleToEdit.meta_description || '';
    document.getElementById('n-meta-keywords').value = articleToEdit.meta_keywords || '';
    document.getElementById('n-canonical').value = articleToEdit.canonical_path || '';
    document.getElementById('n-og-image').value = articleToEdit.og_image || '';
    document.getElementById('n-noindex').checked = !!articleToEdit.noindex;
    
    if (articleToEdit.faqs && Array.isArray(articleToEdit.faqs)) {
      articleToEdit.faqs.forEach(faq => {
        faqContainer.appendChild(createFaqElement(faq.question, faq.answer));
      });
    }
  } else {
    document.getElementById('n-published').checked = true;
    document.getElementById('n-published-at').value = toLocalDatetimeValue(new Date().toISOString());
  }

  function updateFeaturedPreview(url) {
    if (!url) {
      featuredPreviewContainer.classList.add('hidden');
      featuredPreview.removeAttribute('src');
      return;
    }
    featuredPreview.src = url;
    featuredPreviewContainer.classList.remove('hidden');
  }

  function updateOgPreview(url) {
    if (!url) {
      ogPreviewContainer.classList.add('hidden');
      ogPreview.removeAttribute('src');
      return;
    }
    ogPreview.src = url;
    ogPreviewContainer.classList.remove('hidden');
  }

  if (featuredInput.value) {
    updateFeaturedPreview(featuredInput.value);
  }
  if (ogImageInput.value) {
    updateOgPreview(ogImageInput.value);
  }

  featuredInput.addEventListener('input', (e) => {
    const val = e.target.value;
    updateFeaturedPreview(val);
    // Sync with OG image if OG image is empty or same as previous featured
    if (!ogImageInput.value || ogImageInput.value === articleToEdit?.featured_image) {
      ogImageInput.value = val;
      updateOgPreview(val);
    }
  });

  ogImageInput.addEventListener('input', (e) => {
    updateOgPreview(e.target.value);
  });

  document.getElementById('n-og-use-featured')?.addEventListener('click', () => {
    const val = featuredInput.value;
    ogImageInput.value = val;
    updateOgPreview(val);
  });

  async function uploadNewsImage(file) {
    const formData = new FormData();
    formData.append('file', file);
    formData.append('folder', 'news');

    const res = await fetch('/admin/api/upload-image', {
      method: 'POST',
      body: formData,
    });

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Upload failed');
    return data.url;
  }

  featuredFileInput?.addEventListener('change', async () => {
    const file = featuredFileInput.files?.[0];
    if (!file) return;

    // Show local preview immediately
    const localUrl = URL.createObjectURL(file);
    updateFeaturedPreview(localUrl);
    featuredStatus.textContent = 'Uploading to R2... (Compressing 60-70%)';
    featuredStatus.className = 'text-xs text-primary-600 animate-pulse';

    try {
      const remoteUrl = await uploadNewsImage(file);
      featuredInput.value = remoteUrl;
      updateFeaturedPreview(remoteUrl);
      
      // Auto-sync with OG image
      if (!ogImageInput.value || ogImageInput.value === articleToEdit?.featured_image || ogImageInput.value === localUrl) {
        ogImageInput.value = remoteUrl;
        updateOgPreview(remoteUrl);
      }

      featuredStatus.textContent = 'Upload successful!';
      featuredStatus.className = 'text-xs text-green-600';
    } catch (error) {
      console.error(error);
      featuredStatus.textContent = 'Upload failed: ' + error.message;
      featuredStatus.className = 'text-xs text-red-600';
      // Revert preview if needed or just keep local one
    }
  });

  titleInput.addEventListener('input', (e) => {
    if (document.getElementById('n-id').value) return; // don't overwrite slug in edit mode
    const slug = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    slugInput.value = slug;
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Saving...';
    submitBtn.disabled = true;

    try {
      const id = document.getElementById('n-id').value;
      const publishedAtInput = document.getElementById('n-published-at').value;
      const publishedAtIso = publishedAtInput ? new Date(publishedAtInput).toISOString() : new Date().toISOString();

      const body = {
        title: document.getElementById('n-title').value,
        slug: document.getElementById('n-slug').value,
        author_id: document.getElementById('n-author-id').value,
        city_id: document.getElementById('n-city').value || null,
        featured_image: document.getElementById('n-featured').value,
        is_published: document.getElementById('n-published').checked,
        excerpt: document.getElementById('n-excerpt').value,
        content_html: document.getElementById('n-content').value,
        tags: document.getElementById('n-tags').value,
        category_id: document.getElementById('n-category-id').value,
        sub_category_id: document.getElementById('n-sub-category-id').value,
        published_at: publishedAtIso,
        meta_title: document.getElementById('n-meta-title').value,
        meta_description: document.getElementById('n-meta-desc').value,
        meta_keywords: document.getElementById('n-meta-keywords').value,
        canonical_path: document.getElementById('n-canonical').value,
        og_image: document.getElementById('n-og-image').value,
        noindex: document.getElementById('n-noindex').checked,
        faqs: Array.from(document.querySelectorAll('.faq-item')).map(item => ({
          question: item.querySelector('.faq-question').value.trim(),
          answer: item.querySelector('.faq-answer').value.trim()
        })).filter(f => f.question && f.answer),
      };

      const res = await fetch(id ? `/admin/api/blog?id=${id}` : '/admin/api/blog', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        window.location.href = '/admin/blog';
      } else {
        const d = await res.json();
        alert(d.error || 'Failed to save');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      alert('An external error occurred.');
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>

<script>
  import { Editor } from '@tiptap/core';
  import StarterKit from '@tiptap/starter-kit';
  import Underline from '@tiptap/extension-underline';
  import Link from '@tiptap/extension-link';
  import Image from '@tiptap/extension-image';

  const hiddenTextarea = document.getElementById('n-content') as HTMLTextAreaElement;
  const editorContainer = document.getElementById('tiptap-editor')!;
  const sourceTextarea = document.getElementById('n-content-source') as HTMLTextAreaElement;
  const sourceToggle = document.getElementById('tt-source-toggle')!;
  const toolbar = document.getElementById('tiptap-toolbar')!;
  let isSourceMode = false;

  // Initialize Tiptap editor
  const editor = new Editor({
    element: editorContainer,
    extensions: [
      StarterKit.configure({
        heading: { levels: [1, 2, 3, 4] },
      }),
      Underline,
      Link.configure({ openOnClick: false, HTMLAttributes: { rel: 'noopener noreferrer nofollow' } }),
      Image.configure({ inline: false, allowBase64: true }),
    ],
    content: hiddenTextarea.value || '',
    onUpdate({ editor: ed }) {
      hiddenTextarea.value = ed.getHTML();
      updateToolbarState();
    },
    onSelectionUpdate() {
      updateToolbarState();
    },
  });

  // Toolbar button actions
  toolbar.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
    if (!btn) return;
    const action = btn.dataset.action;

    switch (action) {
      case 'bold': editor.chain().focus().toggleBold().run(); break;
      case 'italic': editor.chain().focus().toggleItalic().run(); break;
      case 'underline': editor.chain().focus().toggleUnderline().run(); break;
      case 'strike': editor.chain().focus().toggleStrike().run(); break;
      case 'h1': editor.chain().focus().toggleHeading({ level: 1 }).run(); break;
      case 'h2': editor.chain().focus().toggleHeading({ level: 2 }).run(); break;
      case 'h3': editor.chain().focus().toggleHeading({ level: 3 }).run(); break;
      case 'h4': editor.chain().focus().toggleHeading({ level: 4 }).run(); break;
      case 'bulletList': editor.chain().focus().toggleBulletList().run(); break;
      case 'orderedList': editor.chain().focus().toggleOrderedList().run(); break;
      case 'blockquote': editor.chain().focus().toggleBlockquote().run(); break;
      case 'codeBlock': editor.chain().focus().toggleCodeBlock().run(); break;
      case 'horizontalRule': editor.chain().focus().setHorizontalRule().run(); break;
      case 'link': {
        const prev = editor.getAttributes('link').href || '';
        const url = prompt('Enter URL:', prev);
        if (url === null) break;
        if (url === '') { editor.chain().focus().unsetLink().run(); }
        else { editor.chain().focus().extendMarkRange('link').setLink({ href: url }).run(); }
        break;
      }
      case 'image': {
        const url = prompt('Enter image URL:');
        if (url) { editor.chain().focus().setImage({ src: url }).run(); }
        break;
      }
      case 'undo': editor.chain().focus().undo().run(); break;
      case 'redo': editor.chain().focus().redo().run(); break;
    }
  });

  // HTML source toggle
  sourceToggle.addEventListener('click', () => {
    isSourceMode = !isSourceMode;
    if (isSourceMode) {
      sourceTextarea.value = editor.getHTML();
      editorContainer.classList.add('hidden');
      sourceTextarea.classList.remove('hidden');
      sourceToggle.classList.add('tt-btn-active');
    } else {
      const html = sourceTextarea.value;
      editor.commands.setContent(html);
      hiddenTextarea.value = html;
      editorContainer.classList.remove('hidden');
      sourceTextarea.classList.add('hidden');
      sourceToggle.classList.remove('tt-btn-active');
    }
  });

  // Sync source content on form submit (in case user is in source mode)
  document.getElementById('news-form')?.addEventListener('submit', () => {
    if (isSourceMode) {
      hiddenTextarea.value = sourceTextarea.value;
    }
  }, { capture: true });

  // Update active states on toolbar buttons
  function updateToolbarState() {
    toolbar.querySelectorAll('[data-action]').forEach((btn) => {
      const action = (btn as HTMLElement).dataset.action!;
      let active = false;
      switch (action) {
        case 'bold': active = editor.isActive('bold'); break;
        case 'italic': active = editor.isActive('italic'); break;
        case 'underline': active = editor.isActive('underline'); break;
        case 'strike': active = editor.isActive('strike'); break;
        case 'h1': active = editor.isActive('heading', { level: 1 }); break;
        case 'h2': active = editor.isActive('heading', { level: 2 }); break;
        case 'h3': active = editor.isActive('heading', { level: 3 }); break;
        case 'h4': active = editor.isActive('heading', { level: 4 }); break;
        case 'bulletList': active = editor.isActive('bulletList'); break;
        case 'orderedList': active = editor.isActive('orderedList'); break;
        case 'blockquote': active = editor.isActive('blockquote'); break;
        case 'codeBlock': active = editor.isActive('codeBlock'); break;
        case 'link': active = editor.isActive('link'); break;
      }
      btn.classList.toggle('tt-btn-active', active);
    });
  }
</script>

