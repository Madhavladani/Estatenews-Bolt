---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabase } from '../../../../lib/supabase';
import type { BlogCategory } from '../../../../lib/types';

const id = Astro.url.searchParams.get('id');
let category: BlogCategory | null = null;

if (id) {
  const { data } = await supabase.from('blog_categories').select('*').eq('id', id).single();
  category = data;
}

const pageTitle = category ? 'Edit Category' : 'Add Category';
---

<AdminLayout title={pageTitle} activeTab="blog">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/blog/categories" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-2xl">
    <form id="category-form" class="space-y-6">
      <input type="hidden" id="c-id" value={category?.id || ''} />
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
        <input type="text" id="c-name" required value={category?.name || ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
        <input type="text" id="c-slug" required value={category?.slug || ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" />
      </div>

      <div class="pt-4 border-t border-gray-100">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">SEO Metadata</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
            <input type="text" id="c-meta-title" value={category?.meta_title || ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
            <textarea id="c-meta-desc" rows="3" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none">{category?.meta_description || ''}</textarea>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-4">
        <a href="/admin/blog/categories" class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm hover:bg-gray-50">Cancel</a>
        <button type="submit" class="px-6 py-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg text-sm transition-colors">
          Save Category
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('category-form') as HTMLFormElement;
  const nameInput = document.getElementById('c-name') as HTMLInputElement;
  const slugInput = document.getElementById('c-slug') as HTMLInputElement;
  const idInput = document.getElementById('c-id') as HTMLInputElement;

  nameInput.addEventListener('input', () => {
    if (idInput.value) return;
    slugInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = idInput.value;
    const body = {
      name: nameInput.value,
      slug: slugInput.value,
      meta_title: (document.getElementById('c-meta-title') as HTMLInputElement).value,
      meta_description: (document.getElementById('c-meta-desc') as HTMLTextAreaElement).value,
    };

    const res = await fetch(id ? `/admin/api/blog-categories?id=${id}` : '/admin/api/blog-categories', {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok) window.location.href = '/admin/blog/categories';
    else {
      const err = await res.json();
      alert(err.error || 'Failed to save category');
    }
  });
</script>
