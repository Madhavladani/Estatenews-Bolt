---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { City, Project, Collection, Builder } from '../../../lib/types';

const { data: citiesRes } = await supabase.from('cities').select('*').order('name');
const cities: City[] = citiesRes || [];

const { data: collectionsRes } = await supabase.from('collections').select('*').order('title');
const allCollections = (collectionsRes || []) as Collection[];

const { data: buildersRes } = await supabase.from('builders').select('id, name').order('name');
const builders = (buildersRes || []) as Builder[];

// Check for id to prepopulate (edit mode)
const projectId = Astro.url.searchParams.get('id');
let projectToEdit: Project | null = null;
let currentCollectionIds: string[] = [];

if (projectId) {
  const [pRes, pcRes] = await Promise.all([
    supabase.from('projects').select('*').eq('id', projectId).single(),
    supabase.from('collection_projects').select('collection_id').eq('project_id', projectId)
  ]);
  projectToEdit = pRes.data as Project | null;
  currentCollectionIds = (pcRes.data as any[] || []).map((r: any) => r.collection_id as string);
}

const pageTitle = projectToEdit ? 'Edit Project' : 'Add Project';
---

<AdminLayout title={pageTitle} activeTab="projects">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/projects" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-4xl">
    <form id="project-form" class="space-y-6">
      <input type="hidden" id="p-id" />
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="flex justify-between items-center mb-1">
            <label class="block text-sm font-medium text-gray-700">Title *</label>
            <span id="p-title-count" class="text-xs font-medium text-gray-500">0 / 60</span>
          </div>
          <input type="text" id="p-title" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-all duration-200" />
	      </div>
	      
	      <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
          <input type="text" id="p-slug" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">City *</label>
          <select id="p-city" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">Select City</option>
            {cities.map((c) => <option value={c.id}>{c.name}</option>)}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Project Type *</label>
          <select id="p-type" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="residential">Residential</option>
            <option value="commercial">Commercial</option>
          </select>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Map to Builder Profile</label>
          <select id="p-builder-id" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">None (Legacy)</option>
            {builders.map((b) => <option value={b.id}>{b.name}</option>)}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Builder Name (Legacy)</label>
          <input type="text" id="p-builder" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Builder Phone</label>
          <input type="text" id="p-phone" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Locality</label>
          <select id="p-locality" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">Select Locality</option>
          </select>
          <input type="hidden" id="p-location" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Price Range</label>
          <input type="text" id="p-price" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="e.g. ?50 Lakh - ?1 Cr" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
        <input type="text" id="p-address" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="e.g. Near XYZ Mall, Main Road" />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Project Status</label>
          <select id="p-status" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="under-construction">Under Construction</option>
            <option value="new-launch">New Launch</option>
            <option value="ready-to-move">Ready to Move</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Possession Date</label>
          <input type="text" id="p-possession" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="e.g. December 2026" />
        </div>
      </div>
<div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Short Description</label>
        <textarea id="p-short-desc" rows="2" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"></textarea>
      </div>
      
		      <div>
		        <label class="block text-sm font-medium text-gray-700 mb-1">Full Description</label>
		        <div class="rounded-lg border border-gray-200 overflow-hidden">
		          <div class="flex flex-wrap items-center gap-2 px-3 py-2 bg-gray-50 border-b border-gray-200">
	            <button type="button" data-rte-cmd="bold" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Bold</button>
	            <button type="button" data-rte-cmd="italic" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Italic</button>
	            <button type="button" data-rte-cmd="underline" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Underline</button>
	            <span class="w-px h-5 bg-gray-200 mx-1"></span>
	            <button type="button" data-rte-cmd="insertUnorderedList" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Bullets</button>
	            <button type="button" data-rte-cmd="insertOrderedList" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Numbered</button>
	            <span class="w-px h-5 bg-gray-200 mx-1"></span>
	            <button type="button" data-rte-link="1" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Link</button>
	            <button type="button" data-rte-cmd="removeFormat" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Clear</button>
	            <span class="w-px h-5 bg-gray-200 mx-1"></span>
	            <button type="button" id="p-source-toggle" class="px-2 py-1 text-xs font-medium text-primary-700 bg-primary-50 border border-primary-200 rounded hover:bg-primary-100">Source</button>
	          </div>
	          <div id="p-full-desc-editor" contenteditable="true" class="min-h-[160px] px-4 py-3 text-sm outline-none"></div>
	          <textarea id="p-full-desc-textarea" class="hidden w-full min-h-[160px] px-4 py-3 text-sm font-mono border-0 focus:ring-0 outline-none"></textarea>
	        </div>
		        <textarea id="p-full-desc" class="hidden"></textarea>
		        <p class="mt-2 text-xs text-gray-500">Rich text is saved as HTML.</p>
		      </div>

        <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-gray-900">Custom FAQs</p>
              <p class="text-xs text-gray-500">Enable to override the default FAQs on the project page.</p>
            </div>
            <label class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 select-none">
              <input id="p-use-custom-faqs" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-primary-700 focus:ring-primary-500" />
              Use custom FAQs
            </label>
          </div>

          <div id="p-custom-faqs-section" class="mt-4 hidden">
            <div class="flex items-center justify-between gap-4">
              <p class="text-xs text-gray-500">Add any number of questions/answers (empty items are ignored).</p>
              <button type="button" id="p-add-faq" class="px-3 py-1.5 text-sm bg-white hover:bg-gray-100 text-gray-700 rounded-lg font-medium transition-colors border border-gray-200">+ Add Question</button>
            </div>
            <div id="p-faq-container" class="mt-3 space-y-3"></div>
          </div>
        </div>
	      
	      <div>
	        <label class="block text-sm font-medium text-gray-700 mb-1">Featured Image</label>
	        <input type="file" id="p-featured-file" accept="image/*" class="block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-gray-100 file:px-4 file:py-2 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" />
        <p id="p-featured-status" class="mt-2 text-xs text-gray-500"></p>
        <input type="hidden" id="p-image" />
        <img id="p-featured-preview" alt="Project featured preview" class="hidden mt-3 w-full h-52 object-cover rounded-lg border border-gray-200" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Gallery Images (max 10)</label>
        <input type="file" id="p-gallery-file" accept="image/*" multiple class="block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-gray-100 file:px-4 file:py-2 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" />
        <p id="p-gallery-status" class="mt-2 text-xs text-gray-500"></p>
        <input type="hidden" id="p-gallery" />
        <div id="p-gallery-preview" class="mt-3 grid grid-cols-2 md:grid-cols-5 gap-3"></div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Amenities (comma separated)</label>
        <input type="text" id="p-amenities" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="Swimming Pool, Gym, Clubhouse" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Highlights (comma separated)</label>
        <input type="text" id="p-highlights" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Floor Plans (JSON array)</label>
        <textarea id="p-floor-plans" rows="3" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow font-mono text-xs" placeholder='[{"name":"2 BHK","size":"1050 sq.ft","price":"₹55 Lakh"}]'></textarea>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">RERA Number</label>
          <input type="text" id="p-rera" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Brochure (PDF)</label>
          <input type="file" id="p-brochure-file" accept="application/pdf" class="block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-gray-100 file:px-4 file:py-2 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" />
          <p id="p-brochure-status" class="mt-2 text-xs text-gray-500"></p>
          <input type="hidden" id="p-brochure" />
          <div id="p-brochure-preview" class="mt-2 hidden">
            <a href="#" id="p-brochure-link" target="_blank" class="text-sm text-primary-700 font-medium hover:underline inline-flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              View Brochure
            </a>
          </div>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Latitude</label>
          <input type="number" step="0.000001" id="p-lat" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Longitude</label>
          <input type="number" step="0.000001" id="p-lng" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
          <input type="text" id="p-meta-title" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <div class="flex justify-between items-center mb-1">
            <label class="block text-sm font-medium text-gray-700">Meta Description</label>
            <span id="p-meta-desc-count" class="text-xs font-medium text-gray-500">0 / 160</span>
          </div>
          <textarea id="p-meta-desc" rows="2" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"></textarea>
        </div>
      </div>

      <!-- Collections Section -->
      <div id="collections-section" class="pt-6 border-t border-gray-100">
        <div class="border border-gray-200 rounded-xl overflow-hidden bg-gray-50 shadow-sm transition-all duration-300" id="main-collections-accordion">
          <div class="px-5 py-4 cursor-pointer flex items-center justify-between bg-white hover:bg-gray-50 transition-colors group" id="main-coll-header">
            <div>
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-primary-700 transition-colors">Select Project Collections</h3>
              <p id="no-collections-msg" class="text-[11px] text-gray-500 mt-0.5">Please select a city to see available collections.</p>
            </div>
            <div class="flex items-center gap-2">
              <span id="selected-count" class="text-xs font-bold px-2 py-0.5 rounded-full bg-primary-100 text-primary-700 hidden">0</span>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-primary-500 transition-all duration-300 transform" id="main-coll-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
          
          <div class="p-5 space-y-3 hidden bg-gray-50/50 border-t border-gray-100" id="main-coll-content">
            <div id="collections-container" class="space-y-3">
              {allCollections.map((coll, index) => {
                const colors = [
                  { bg: 'bg-red-50', border: 'border-red-200', text: 'text-red-700' },
                  { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-700' },
                  { bg: 'bg-green-50', border: 'border-green-200', text: 'text-green-700' },
                  { bg: 'bg-yellow-50', border: 'border-yellow-200', text: 'text-yellow-700' },
                  { bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-700' },
                  { bg: 'bg-pink-50', border: 'border-pink-200', text: 'text-pink-700' },
                  { bg: 'bg-indigo-50', border: 'border-indigo-200', text: 'text-indigo-700' }
                ];
                const color = colors[index % colors.length];
                return (
                  <div 
                    class={`collection-item hidden border rounded-xl overflow-hidden transition-all duration-200 ${color.bg} ${color.border} hover:shadow-md h-auto`} 
                    data-city-id={coll.city_id || ''}
                  >
                    <div class="flex items-start gap-4 px-4 py-4">
                      <div class="pt-1">
                        <input 
                          type="checkbox" 
                          class="coll-checkbox w-5 h-5 rounded border-gray-300 text-primary-600 focus:ring-primary-500 transition-colors cursor-pointer" 
                          value={coll.id} 
                          checked={currentCollectionIds.includes(coll.id)}
                        />
                      </div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between mb-1">
                          <span class={`text-[13px] font-bold ${color.text} truncate`}>{coll.title}</span>
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-black uppercase tracking-wider bg-white/50 border border-black/5 opacity-70">{coll.collection_type || 'General'}</span>
                        </div>
                        <p class="text-[11px] text-gray-600 leading-normal line-clamp-2">{coll.intro_content || 'No description available for this collection.'}</p>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
      
      <div class="flex justify-end gap-4 pt-4 border-t border-gray-100">
        <a href="/admin/projects" class="px-6 py-2.5 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Cancel</a>
        <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-primary-700 hover:bg-primary-800 rounded-lg transition-colors shadow-sm">Save Project</button>
      </div>
    </form>
  </div>
</AdminLayout>

	<script define:vars={{ p: projectToEdit }}>
	  const form = document.getElementById('project-form');
	  const titleInput = document.getElementById('p-title');
	  const slugInput = document.getElementById('p-slug');
	  const metaDescInput = document.getElementById('p-meta-desc');
	  const fullDescHidden = document.getElementById('p-full-desc');
	  const fullDescEditor = document.getElementById('p-full-desc-editor');
	  const featuredInput = document.getElementById('p-image');
	  const featuredPreview = document.getElementById('p-featured-preview');
	  const galleryInput = document.getElementById('p-gallery');
	  const brochureInput = document.getElementById('p-brochure');
	  const featuredFileInput = document.getElementById('p-featured-file');
	  const galleryFileInput = document.getElementById('p-gallery-file');
	  const brochureFileInput = document.getElementById('p-brochure-file');
		  const featuredStatus = document.getElementById('p-featured-status');
		  const galleryStatus = document.getElementById('p-gallery-status');
		  const brochureStatus = document.getElementById('p-brochure-status');
		  const galleryPreview = document.getElementById('p-gallery-preview');
		  const brochurePreview = document.getElementById('p-brochure-preview');
			  const brochureLink = document.getElementById('p-brochure-link');
			  const citySelect = document.getElementById('p-city');
			  const localitySelect = document.getElementById('p-locality');
			  const locationHidden = document.getElementById('p-location');
			  const useCustomFaqsCheckbox = document.getElementById('p-use-custom-faqs');
			  const customFaqsSection = document.getElementById('p-custom-faqs-section');
			  const addFaqBtn = document.getElementById('p-add-faq');
			  const faqContainer = document.getElementById('p-faq-container');

			  function createFaqElement(question = '', answer = '') {
			    const div = document.createElement('div');
			    div.className = 'faq-item bg-white p-4 rounded-lg relative border border-gray-200';
			    div.innerHTML = `
			      <button type="button" class="remove-faq absolute top-3 right-3 text-red-500 hover:text-red-700 p-1" aria-label="Remove FAQ">
			        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
			      </button>
			      <div class="space-y-2">
			        <div>
			          <label class="block text-xs font-medium text-gray-700 mb-1">Question</label>
			          <input type="text" class="faq-question w-full px-3 py-2 border border-gray-200 rounded text-sm focus:ring-2 focus:ring-primary-500 outline-none" value="${String(question || '').replace(/\"/g, '&quot;')}" />
			        </div>
			        <div>
			          <label class="block text-xs font-medium text-gray-700 mb-1">Answer</label>
			          <textarea rows="2" class="faq-answer w-full px-3 py-2 border border-gray-200 rounded text-sm focus:ring-2 focus:ring-primary-500 outline-none">${String(answer || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</textarea>
			        </div>
			      </div>
			    `;
			    div.querySelector('.remove-faq')?.addEventListener('click', () => div.remove());
			    return div;
			  }

			  function setCustomFaqsVisible(isVisible) {
			    if (!customFaqsSection) return;
			    customFaqsSection.classList.toggle('hidden', !isVisible);
			  }
  function sanitizeSegment(value) {
    return String(value || '')
      .toLowerCase()
      .replace(/[^a-z0-9-]+/g, '-')
      .replace(/^-|-$/g, '') || 'untitled-project';
  }

  function getProjectFolderBase() {
    const slugValue = document.getElementById('p-slug').value || document.getElementById('p-title').value;
    return `projects/${sanitizeSegment(slugValue)}`;
  }

  function renderGalleryPreview(urls) {
    galleryPreview.innerHTML = '';
    urls.forEach((url, idx) => {
      const img = document.createElement('img');
      img.src = url;
      img.alt = `Gallery ${idx + 1}`;
      img.className = 'w-full h-24 object-cover rounded-lg border border-gray-200';
      galleryPreview.appendChild(img);
    });
  }

	  function updateFeaturedPreview(url) {
	    if (!url) {
	      featuredPreview.classList.add('hidden');
	      featuredPreview.removeAttribute('src');
	      return;
	    }
	    featuredPreview.src = url;
	    featuredPreview.classList.remove('hidden');
	  }

	  function updateBrochurePreview(url) {
	    if (!url) {
	      brochurePreview.classList.add('hidden');
	      brochureLink.removeAttribute('href');
	      return;
	    }
	    brochureLink.href = url;
	    brochurePreview.classList.remove('hidden');
	  }

	  function syncFullDescToHidden() {
	    fullDescHidden.value = fullDescEditor.innerHTML;
	  }

	  function setFullDescHtml(html) {
	    const safeHtml = String(html || '');
	    fullDescEditor.innerHTML = safeHtml;
	    fullDescTextarea.value = safeHtml;
	    syncFullDescToHidden();
	  }
	  
	  // Source code toggle
	  const sourceToggle = document.getElementById('p-source-toggle');
	  const fullDescTextarea = document.getElementById('p-full-desc-textarea');
	  let isSourceMode = false;

	  sourceToggle.addEventListener('click', () => {
	    isSourceMode = !isSourceMode;
	    if (isSourceMode) {
	      fullDescTextarea.value = fullDescEditor.innerHTML;
	      fullDescEditor.classList.add('hidden');
	      fullDescTextarea.classList.remove('hidden');
	      sourceToggle.textContent = 'Visual';
	      sourceToggle.classList.remove('bg-primary-50', 'text-primary-700', 'border-primary-200');
	      sourceToggle.classList.add('bg-gray-900', 'text-white', 'border-gray-900');
	    } else {
	      fullDescEditor.innerHTML = fullDescTextarea.value;
	      fullDescTextarea.classList.add('hidden');
	      fullDescEditor.classList.remove('hidden');
	      sourceToggle.textContent = 'Source';
	      sourceToggle.classList.add('bg-primary-50', 'text-primary-700', 'border-primary-200');
	      sourceToggle.classList.remove('bg-gray-900', 'text-white', 'border-gray-900');
	      syncFullDescToHidden();
	    }
	  });

	  fullDescTextarea.addEventListener('input', () => {
	    fullDescHidden.value = fullDescTextarea.value;
	  });

	  // Toolbar actions
	  document.querySelectorAll('[data-rte-cmd]').forEach((btn) => {
	    btn.addEventListener('click', () => {
	      if (isSourceMode) return;
	      const cmd = btn.getAttribute('data-rte-cmd');
	      if (!cmd) return;
	      fullDescEditor.focus();
	      document.execCommand(cmd, false, null);
	      syncFullDescToHidden();
	    });
	  });
	  document.querySelectorAll('[data-rte-link]').forEach((btn) => {
	    btn.addEventListener('click', () => {
	      if (isSourceMode) return;
	      fullDescEditor.focus();
	      const url = window.prompt('Enter URL');
	      if (!url) return;
	      document.execCommand('createLink', false, url);
	      syncFullDescToHidden();
	    });
	  });
	  fullDescEditor.addEventListener('input', syncFullDescToHidden);

	  if (p) {
	    document.getElementById('p-id').value = p.id;
	    document.getElementById('p-title').value = p.title;
	    document.getElementById('p-slug').value = p.slug;
	    document.getElementById('p-city').value = p.city_id;
    document.getElementById('p-type').value = p.project_type;
    document.getElementById('p-builder-id').value = p.builder_id || '';
    document.getElementById('p-builder').value = p.builder_name || '';
    document.getElementById('p-phone').value = p.builder_phone || '';
    document.getElementById('p-location').value = p.location || '';    document.getElementById('p-address').value = p.address || '';    document.getElementById('p-price').value = p.price_range || '';
	    document.getElementById('p-status').value = p.project_status;
	    document.getElementById('p-possession').value = p.possession_date || '';
	    document.getElementById('p-short-desc').value = p.short_description || '';
	    setFullDescHtml(p.full_description || '');
	    document.getElementById('p-image').value = p.featured_image || '';
	    document.getElementById('p-gallery').value = JSON.stringify(p.gallery_images || []);
	    document.getElementById('p-amenities').value = (p.amenities || []).join(', ');
	    document.getElementById('p-highlights').value = (p.highlights || []).join(', ');
	    document.getElementById('p-floor-plans').value = JSON.stringify(p.floor_plans || []);
    document.getElementById('p-rera').value = p.rera_number || '';
    document.getElementById('p-brochure').value = p.brochure_url || '';
    document.getElementById('p-lat').value = p.latitude || '';
    document.getElementById('p-lng').value = p.longitude || '';
		    document.getElementById('p-meta-title').value = p.meta_title || '';
		    document.getElementById('p-meta-desc').value = p.meta_description || '';

		    if (useCustomFaqsCheckbox) {
		      useCustomFaqsCheckbox.checked = !!p.use_custom_faqs;
		      setCustomFaqsVisible(useCustomFaqsCheckbox.checked);
		      if (faqContainer) faqContainer.innerHTML = '';
		      if (useCustomFaqsCheckbox.checked && Array.isArray(p.custom_faqs) && p.custom_faqs.length > 0) {
		        p.custom_faqs.forEach((faq) => {
		          faqContainer?.appendChild(createFaqElement(faq?.question || '', faq?.answer || ''));
		        });
		      } else if (useCustomFaqsCheckbox.checked) {
		        faqContainer?.appendChild(createFaqElement());
		      }
		    }
		  }
	  if (!p) setFullDescHtml('');
	    updateFeaturedPreview(featuredInput.value);
      updateBrochurePreview(brochureInput.value);
	  renderGalleryPreview((p?.gallery_images || []).filter(Boolean));

	  if (useCustomFaqsCheckbox) {
	    setCustomFaqsVisible(useCustomFaqsCheckbox.checked);
	    useCustomFaqsCheckbox.addEventListener('change', () => {
	      setCustomFaqsVisible(useCustomFaqsCheckbox.checked);
	      if (useCustomFaqsCheckbox.checked && faqContainer && faqContainer.children.length === 0) {
	        faqContainer.appendChild(createFaqElement());
	      }
	    });
	  }

	  addFaqBtn?.addEventListener('click', () => {
	    faqContainer?.appendChild(createFaqElement());
	  });

	  async function loadLocalities(cityId, selectedLocalityId, fallbackLocationName) {
	    if (!localitySelect) return;
	    localitySelect.innerHTML = '<option value="">Select Locality</option>';
    if (!cityId) return;

    try {
      const res = await fetch(`/admin/api/localities?city_id=${encodeURIComponent(cityId)}`);
      const list = res.ok ? await res.json() : [];
      (Array.isArray(list) ? list : []).forEach((loc) => {
        const opt = document.createElement('option');
        opt.value = loc.id;
        opt.textContent = loc.name;
        localitySelect.appendChild(opt);
      });

      if (selectedLocalityId) {
        localitySelect.value = selectedLocalityId;
      } else if (fallbackLocationName) {
        const match = Array.from(localitySelect.options).find(
          (o) => o.textContent?.trim().toLowerCase() === String(fallbackLocationName).trim().toLowerCase(),
        );
        if (match) localitySelect.value = match.value;
      }

      const selected = localitySelect.options[localitySelect.selectedIndex];
      locationHidden.value = selected?.textContent?.trim() || fallbackLocationName || '';
    } catch (e) {
      console.error(e);
    }
  }

  citySelect?.addEventListener('change', () => {
    loadLocalities(citySelect.value, null, '');
  });

  localitySelect?.addEventListener('change', () => {
    const selected = localitySelect.options[localitySelect.selectedIndex];
    locationHidden.value = selected?.textContent?.trim() || '';
  });

  const initialCityId = citySelect?.value || '';
  const initialLocalityId = p?.locality_id || null;
  const initialLocationName = p?.location || '';
  loadLocalities(initialCityId, initialLocalityId, initialLocationName);

  const titleCountSpan = document.getElementById('p-title-count');
  const metaDescCountSpan = document.getElementById('p-meta-desc-count');
  function updateTitleCount() {
    const val = titleInput.value;
    const len = val.length;
    if (titleCountSpan) {
      titleCountSpan.textContent = `${len} / 60`;
      if (len > 60) {
        titleCountSpan.classList.remove('text-gray-500');
        titleCountSpan.classList.add('text-red-500');
        titleInput.classList.remove('border-gray-200', 'focus:ring-primary-500');
        titleInput.classList.add('border-red-300', 'focus:ring-red-500', 'focus:border-red-500', 'bg-red-50');
      } else {
        titleCountSpan.classList.remove('text-red-500');
        titleCountSpan.classList.add('text-gray-500');
        titleInput.classList.remove('border-red-300', 'focus:ring-red-500', 'focus:border-red-500', 'bg-red-50');
        titleInput.classList.add('border-gray-200', 'focus:ring-primary-500');
      }
    }
  }

  function updateMetaDescCount() {
    const val = metaDescInput.value;
    const len = val.length;
    if (metaDescCountSpan) {
      metaDescCountSpan.textContent = `${len} / 160`;
      if (len > 160) {
        metaDescCountSpan.classList.remove('text-gray-500');
        metaDescCountSpan.classList.add('text-red-500');
        metaDescInput.classList.remove('border-gray-200', 'focus:ring-primary-500');
        metaDescInput.classList.add('border-red-300', 'focus:ring-red-500', 'focus:border-red-500', 'bg-red-50');
      } else {
        metaDescCountSpan.classList.remove('text-red-500');
        metaDescCountSpan.classList.add('text-gray-500');
        metaDescInput.classList.remove('border-red-300', 'focus:ring-red-500', 'focus:border-red-500', 'bg-red-50');
        metaDescInput.classList.add('border-gray-200', 'focus:ring-primary-500');
      }
    }
  }

  titleInput.addEventListener('input', (e) => {
    const slug = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    slugInput.value = slug;
    updateTitleCount();
  });

  metaDescInput?.addEventListener('input', updateMetaDescCount);

  // Call on load to setup correct initial status (for edit mode)
  setTimeout(updateTitleCount, 100);
  setTimeout(updateMetaDescCount, 100);
  featuredInput.addEventListener('input', (e) => updateFeaturedPreview(e.target.value));
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Saving...';
    submitBtn.disabled = true;
    
    try {
      const id = document.getElementById('p-id').value;
      const useCustomFaqs = !!useCustomFaqsCheckbox?.checked;
      const customFaqs = useCustomFaqs
        ? Array.from(document.querySelectorAll('#p-faq-container .faq-item'))
            .map((item) => ({
              question: item.querySelector('.faq-question')?.value?.trim() || '',
              answer: item.querySelector('.faq-answer')?.value?.trim() || '',
            }))
            .filter((f) => f.question && f.answer)
        : [];
      const body = {
        title: document.getElementById('p-title').value,
        slug: document.getElementById('p-slug').value,
        city_id: document.getElementById('p-city').value,
        project_type: document.getElementById('p-type').value,
        builder_id: document.getElementById('p-builder-id').value || null,
        builder_name: document.getElementById('p-builder').value,
        builder_phone: document.getElementById('p-phone').value,
        locality_id: document.getElementById('p-locality').value || null,
        location: document.getElementById('p-location').value,
        address: document.getElementById('p-address').value,
        price_range: document.getElementById('p-price').value,
        project_status: document.getElementById('p-status').value,
        possession_date: document.getElementById('p-possession').value,
        short_description: document.getElementById('p-short-desc').value,
        full_description: document.getElementById('p-full-desc').value,
        featured_image: document.getElementById('p-image').value,
        gallery_images: (() => { try { return JSON.parse(document.getElementById('p-gallery').value || '[]'); } catch { return []; } })(),
        amenities: document.getElementById('p-amenities').value,
        highlights: document.getElementById('p-highlights').value,
        floor_plans: document.getElementById('p-floor-plans').value,
        rera_number: document.getElementById('p-rera').value,
	        brochure_url: document.getElementById('p-brochure').value,
	        latitude: parseFloat(document.getElementById('p-lat').value) || 0,
	        longitude: parseFloat(document.getElementById('p-lng').value) || 0,
	        use_custom_faqs: useCustomFaqs,
	        custom_faqs: customFaqs,
	        meta_title: document.getElementById('p-meta-title').value,
	        meta_description: document.getElementById('p-meta-desc').value,
	        collection_ids: Array.from(document.querySelectorAll('.coll-checkbox:checked')).map(cb => cb.value),
	      };

      const res = await fetch(id ? `/admin/api/projects?id=${id}` : '/admin/api/projects', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) { 
        window.location.href = '/admin/projects'; 
      } else { 
        const d = await res.json(); 
        alert(d.error || 'Failed to save'); 
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      alert('An external error occurred.');
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });

  async function uploadProjectImage(fileInputId, folder) {
    const fileInput = document.getElementById(fileInputId);
    const file = fileInput.files?.[0];
    if (!file) {
      alert('Please choose an image first.');
      return null;
    }

    const formData = new FormData();
    formData.append('file', file);
    formData.append('folder', folder);

    const res = await fetch('/admin/api/upload-image', {
      method: 'POST',
      body: formData,
    });

    const data = await res.json();
    if (!res.ok) {
      throw new Error(data.error || 'Upload failed');
    }

    return data.url;
  }

  async function uploadProjectFile(fileInputId, folder) {
    const fileInput = document.getElementById(fileInputId);
    const file = fileInput.files?.[0];
    if (!file) {
      alert('Please choose a file first.');
      return null;
    }

    const formData = new FormData();
    formData.append('file', file);
    formData.append('folder', folder);

    const res = await fetch('/admin/api/upload-file', {
      method: 'POST',
      body: formData,
    });

    const data = await res.json();
    if (!res.ok) {
      throw new Error(data.error || 'Upload failed');
    }

    return data.url;
  }

  featuredFileInput?.addEventListener('change', async () => {
    const file = featuredFileInput.files?.[0];
    if (!file) return;
    const id = document.getElementById('p-id').value;
    updateFeaturedPreview(URL.createObjectURL(file));
    featuredStatus.textContent = 'Uploading featured image...';
    try {
      const url = await uploadProjectImage('p-featured-file', `${getProjectFolderBase()}/featured`);
      if (!url) return;
      featuredInput.value = url;
      updateFeaturedPreview(url);

      if (id) {
        const saveRes = await fetch(`/admin/api/projects?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ featured_image: url }),
        });
        if (!saveRes.ok) {
          const saveErr = await saveRes.json();
          alert(saveErr.error || 'Image uploaded, but database update failed.');
          return;
        }
      }

      featuredStatus.textContent = id
        ? 'Featured image uploaded and saved to database.'
        : 'Featured image uploaded. Save project to persist.';
    } catch (error) {
      console.error(error);
      featuredStatus.textContent = 'Featured image upload failed.';
    }
  });

  galleryFileInput?.addEventListener('change', async () => {
    const files = Array.from(galleryFileInput.files || []);
    if (!files.length) return;
    if (files.length > 10) {
      galleryStatus.textContent = 'You can upload maximum 10 images.';
      galleryFileInput.value = '';
      return;
    }
    const id = document.getElementById('p-id').value;
    const previewUrls = files.map((f) => URL.createObjectURL(f));
    renderGalleryPreview(previewUrls);
    galleryStatus.textContent = `Uploading ${files.length} gallery image(s)...`;
    try {
      const uploadedUrls = [];
      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        const dt = new DataTransfer();
        dt.items.add(file);
        galleryFileInput.files = dt.files;
        const url = await uploadProjectImage('p-gallery-file', `${getProjectFolderBase()}/gallery`);
        if (!url) continue;
        uploadedUrls.push(url);
      }
      galleryInput.value = JSON.stringify(uploadedUrls);
      renderGalleryPreview(uploadedUrls);
      if (id) {
        const saveRes = await fetch(`/admin/api/projects?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ gallery_images: uploadedUrls }),
        });
        if (!saveRes.ok) {
          const saveErr = await saveRes.json();
          alert(saveErr.error || 'Image uploaded, but database update failed.');
          return;
        }
      }
      galleryStatus.textContent = id
        ? 'Gallery uploaded and saved to database.'
        : 'Gallery uploaded. Save project to persist.';
    } catch (error) {
      console.error(error);
      galleryStatus.textContent = 'Gallery upload failed.';
    }
  });

  brochureFileInput?.addEventListener('change', async () => {
    const file = brochureFileInput.files?.[0];
    if (!file) return;
    const id = document.getElementById('p-id').value;
    brochureStatus.textContent = 'Uploading brochure PDF...';
    try {
      const url = await uploadProjectFile('p-brochure-file', `${getProjectFolderBase()}/brochures`);
      if (!url) return;
      brochureInput.value = url;
      updateBrochurePreview(url);

      if (id) {
        const saveRes = await fetch(`/admin/api/projects?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ brochure_url: url }),
        });
        if (!saveRes.ok) {
          const saveErr = await saveRes.json();
          alert(saveErr.error || 'Brochure uploaded, but database update failed.');
          return;
        }
      }

      brochureStatus.textContent = id
        ? 'Brochure uploaded and saved to database.'
        : 'Brochure uploaded. Save project to persist.';
    } catch (error) {
      console.error(error);
      brochureStatus.textContent = 'Brochure upload failed.';
    }
  });

  // Main Accordion Logic
  const mainHeader = document.getElementById('main-coll-header');
  const mainContent = document.getElementById('main-coll-content');
  const mainChevron = document.getElementById('main-coll-chevron');
  const selectedCount = document.getElementById('selected-count');

  function updateSelectedCount() {
    const checked = document.querySelectorAll('.coll-checkbox:checked').length;
    if (checked > 0) {
      selectedCount.textContent = checked;
      selectedCount.classList.remove('hidden');
    } else {
      selectedCount.classList.add('hidden');
    }
  }

  mainHeader?.addEventListener('click', () => {
    const isOpen = !mainContent.classList.contains('hidden');
    if (isOpen) {
      mainContent.classList.add('hidden');
      mainChevron.classList.remove('rotate-180');
    } else {
      mainContent.classList.remove('hidden');
      mainChevron.classList.add('rotate-180');
    }
  });

  document.querySelectorAll('.coll-checkbox').forEach(cb => {
    cb.addEventListener('change', updateSelectedCount);
  });

  function filterCollections(cityId) {
    const items = document.querySelectorAll('.collection-item');
    const msg = document.getElementById('no-collections-msg');
    let found = 0;

    items.forEach(item => {
      const itemCityId = item.dataset.cityId;
      if (!cityId || itemCityId === cityId || itemCityId === '') {
        item.classList.remove('hidden');
        found++;
      } else {
        item.classList.add('hidden');
      }
    });

    if (found > 0) {
      msg.className = 'text-[11px] text-green-600 font-medium mt-0.5';
      msg.textContent = `${found} collections available for this city.`;
    } else {
      msg.className = 'text-[11px] text-gray-500 mt-0.5';
      msg.textContent = cityId ? 'No collections found for this city.' : 'Please select a city to see available collections.';
    }
    
    updateSelectedCount();
  }

  citySelect?.addEventListener('change', () => {
    loadLocalities(citySelect.value, null, '');
    filterCollections(citySelect.value);
  });

  // Initial setup
  filterCollections(citySelect?.value || '');
</script>
