---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { City, Project } from '../../../lib/types';

const { data: citiesRes } = await supabase.from('cities').select('*').order('name');
const cities: City[] = citiesRes || [];

// Check for id to prepopulate (edit mode)
const projectId = Astro.url.searchParams.get('id');
let projectToEdit: Project | null = null;
if (projectId) {
  const { data } = await supabase.from('projects').select('*').eq('id', projectId).single();
  projectToEdit = data;
}

const pageTitle = projectToEdit ? 'Edit Project' : 'Add Project';
---

<AdminLayout title={pageTitle} activeTab="projects">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/projects" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-4xl">
    <form id="project-form" class="space-y-6">
      <input type="hidden" id="p-id" />
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title *</label>
          <input type="text" id="p-title" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
          <input type="text" id="p-slug" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">City *</label>
          <select id="p-city" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="">Select City</option>
            {cities.map((c) => <option value={c.id}>{c.name}</option>)}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Project Type *</label>
          <select id="p-type" required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="residential">Residential</option>
            <option value="commercial">Commercial</option>
          </select>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Builder Name</label>
          <input type="text" id="p-builder" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Builder Phone</label>
          <input type="text" id="p-phone" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
          <input type="text" id="p-location" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Price Range</label>
          <input type="text" id="p-price" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="e.g. ₹50 Lakh - ₹1 Cr" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Project Status</label>
          <select id="p-status" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="under-construction">Under Construction</option>
            <option value="new-launch">New Launch</option>
            <option value="ready-to-move">Ready to Move</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Possession Date</label>
          <input type="text" id="p-possession" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="e.g. December 2026" />
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Short Description</label>
        <textarea id="p-short-desc" rows="2" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"></textarea>
      </div>
      
	      <div>
	        <label class="block text-sm font-medium text-gray-700 mb-1">Full Description</label>
	        <div class="rounded-lg border border-gray-200 overflow-hidden">
	          <div class="flex flex-wrap items-center gap-2 px-3 py-2 bg-gray-50 border-b border-gray-200">
	            <button type="button" data-rte-cmd="bold" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Bold</button>
	            <button type="button" data-rte-cmd="italic" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Italic</button>
	            <button type="button" data-rte-cmd="underline" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Underline</button>
	            <span class="w-px h-5 bg-gray-200 mx-1"></span>
	            <button type="button" data-rte-cmd="insertUnorderedList" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Bullets</button>
	            <button type="button" data-rte-cmd="insertOrderedList" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Numbered</button>
	            <span class="w-px h-5 bg-gray-200 mx-1"></span>
	            <button type="button" data-rte-link="1" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Link</button>
	            <button type="button" data-rte-cmd="removeFormat" class="px-2 py-1 text-xs font-medium text-gray-700 bg-white border border-gray-200 rounded hover:bg-gray-100">Clear</button>
	          </div>
	          <div id="p-full-desc-editor" contenteditable="true" class="min-h-[160px] px-4 py-3 text-sm outline-none"></div>
	        </div>
	        <textarea id="p-full-desc" class="hidden"></textarea>
	        <p class="mt-2 text-xs text-gray-500">Rich text is saved as HTML.</p>
	      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Featured Image</label>
        <input type="file" id="p-featured-file" accept="image/*" class="block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-gray-100 file:px-4 file:py-2 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" />
        <p id="p-featured-status" class="mt-2 text-xs text-gray-500"></p>
        <input type="hidden" id="p-image" />
        <img id="p-featured-preview" alt="Project featured preview" class="hidden mt-3 w-full h-52 object-cover rounded-lg border border-gray-200" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Gallery Images (max 10)</label>
        <input type="file" id="p-gallery-file" accept="image/*" multiple class="block w-full text-sm text-gray-600 file:mr-4 file:rounded-lg file:border-0 file:bg-gray-100 file:px-4 file:py-2 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" />
        <p id="p-gallery-status" class="mt-2 text-xs text-gray-500"></p>
        <input type="hidden" id="p-gallery" />
        <div id="p-gallery-preview" class="mt-3 grid grid-cols-2 md:grid-cols-5 gap-3"></div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Amenities (comma separated)</label>
        <input type="text" id="p-amenities" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" placeholder="Swimming Pool, Gym, Clubhouse" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Highlights (comma separated)</label>
        <input type="text" id="p-highlights" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Floor Plans (JSON array)</label>
        <textarea id="p-floor-plans" rows="3" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow font-mono text-xs" placeholder='[{"name":"2 BHK","size":"1050 sq.ft","price":"₹55 Lakh"}]'></textarea>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">RERA Number</label>
          <input type="text" id="p-rera" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Brochure URL</label>
          <input type="text" id="p-brochure" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Latitude</label>
          <input type="number" step="0.001" id="p-lat" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Longitude</label>
          <input type="number" step="0.001" id="p-lng" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Meta Title</label>
          <input type="text" id="p-meta-title" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Meta Description</label>
          <textarea id="p-meta-desc" rows="2" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"></textarea>
        </div>
      </div>
      
      <div class="flex justify-end gap-4 pt-4 border-t border-gray-100">
        <a href="/admin/projects" class="px-6 py-2.5 text-sm font-medium text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg transition-colors">Cancel</a>
        <button type="submit" class="px-6 py-2.5 text-sm font-medium text-white bg-primary-700 hover:bg-primary-800 rounded-lg transition-colors shadow-sm">Save Project</button>
      </div>
    </form>
  </div>
</AdminLayout>

	<script define:vars={{ p: projectToEdit }}>
	  const form = document.getElementById('project-form');
	  const titleInput = document.getElementById('p-title');
	  const slugInput = document.getElementById('p-slug');
	  const fullDescHidden = document.getElementById('p-full-desc');
	  const fullDescEditor = document.getElementById('p-full-desc-editor');
	  const featuredInput = document.getElementById('p-image');
	  const featuredPreview = document.getElementById('p-featured-preview');
	  const galleryInput = document.getElementById('p-gallery');
	  const featuredFileInput = document.getElementById('p-featured-file');
	  const galleryFileInput = document.getElementById('p-gallery-file');
  const featuredStatus = document.getElementById('p-featured-status');
  const galleryStatus = document.getElementById('p-gallery-status');
  const galleryPreview = document.getElementById('p-gallery-preview');

  function sanitizeSegment(value) {
    return String(value || '')
      .toLowerCase()
      .replace(/[^a-z0-9-]+/g, '-')
      .replace(/^-|-$/g, '') || 'untitled-project';
  }

  function getProjectFolderBase() {
    const slugValue = document.getElementById('p-slug').value || document.getElementById('p-title').value;
    return `projects/${sanitizeSegment(slugValue)}`;
  }

  function renderGalleryPreview(urls) {
    galleryPreview.innerHTML = '';
    urls.forEach((url, idx) => {
      const img = document.createElement('img');
      img.src = url;
      img.alt = `Gallery ${idx + 1}`;
      img.className = 'w-full h-24 object-cover rounded-lg border border-gray-200';
      galleryPreview.appendChild(img);
    });
  }

	  function updateFeaturedPreview(url) {
	    if (!url) {
	      featuredPreview.classList.add('hidden');
	      featuredPreview.removeAttribute('src');
	      return;
	    }
	    featuredPreview.src = url;
	    featuredPreview.classList.remove('hidden');
	  }

	  function syncFullDescToHidden() {
	    fullDescHidden.value = fullDescEditor.innerHTML;
	  }

	  function setFullDescHtml(html) {
	    const safeHtml = String(html || '');
	    fullDescEditor.innerHTML = safeHtml;
	    syncFullDescToHidden();
	  }

	  // Toolbar actions
	  document.querySelectorAll('[data-rte-cmd]').forEach((btn) => {
	    btn.addEventListener('click', () => {
	      const cmd = btn.getAttribute('data-rte-cmd');
	      if (!cmd) return;
	      fullDescEditor.focus();
	      document.execCommand(cmd, false, null);
	      syncFullDescToHidden();
	    });
	  });
	  document.querySelectorAll('[data-rte-link]').forEach((btn) => {
	    btn.addEventListener('click', () => {
	      fullDescEditor.focus();
	      const url = window.prompt('Enter URL');
	      if (!url) return;
	      document.execCommand('createLink', false, url);
	      syncFullDescToHidden();
	    });
	  });
	  fullDescEditor.addEventListener('input', syncFullDescToHidden);

	  if (p) {
	    document.getElementById('p-id').value = p.id;
	    document.getElementById('p-title').value = p.title;
	    document.getElementById('p-slug').value = p.slug;
	    document.getElementById('p-city').value = p.city_id;
    document.getElementById('p-type').value = p.project_type;
    document.getElementById('p-builder').value = p.builder_name || '';
    document.getElementById('p-phone').value = p.builder_phone || '';
    document.getElementById('p-location').value = p.location || '';
    document.getElementById('p-price').value = p.price_range || '';
	    document.getElementById('p-status').value = p.project_status;
	    document.getElementById('p-possession').value = p.possession_date || '';
	    document.getElementById('p-short-desc').value = p.short_description || '';
	    setFullDescHtml(p.full_description || '');
	    document.getElementById('p-image').value = p.featured_image || '';
	    document.getElementById('p-gallery').value = (p.gallery_images || []).join('\n');
	    document.getElementById('p-amenities').value = (p.amenities || []).join(', ');
	    document.getElementById('p-highlights').value = (p.highlights || []).join(', ');
	    document.getElementById('p-floor-plans').value = JSON.stringify(p.floor_plans || []);
    document.getElementById('p-rera').value = p.rera_number || '';
    document.getElementById('p-brochure').value = p.brochure_url || '';
    document.getElementById('p-lat').value = p.latitude || '';
    document.getElementById('p-lng').value = p.longitude || '';
	    document.getElementById('p-meta-title').value = p.meta_title || '';
	    document.getElementById('p-meta-desc').value = p.meta_description || '';
	  }
	  if (!p) setFullDescHtml('');
	  updateFeaturedPreview(featuredInput.value);
	  renderGalleryPreview((p?.gallery_images || []).filter(Boolean));

  titleInput.addEventListener('input', (e) => {
    const slug = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    slugInput.value = slug;
  });
  featuredInput.addEventListener('input', (e) => updateFeaturedPreview(e.target.value));

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Saving...';
    submitBtn.disabled = true;
    
    try {
      const id = document.getElementById('p-id').value;
      const body = {
        title: document.getElementById('p-title').value,
        slug: document.getElementById('p-slug').value,
        city_id: document.getElementById('p-city').value,
        project_type: document.getElementById('p-type').value,
        builder_name: document.getElementById('p-builder').value,
        builder_phone: document.getElementById('p-phone').value,
        location: document.getElementById('p-location').value,
        price_range: document.getElementById('p-price').value,
        project_status: document.getElementById('p-status').value,
        possession_date: document.getElementById('p-possession').value,
        short_description: document.getElementById('p-short-desc').value,
        full_description: document.getElementById('p-full-desc').value,
        featured_image: document.getElementById('p-image').value,
        gallery_images: document.getElementById('p-gallery').value,
        amenities: document.getElementById('p-amenities').value,
        highlights: document.getElementById('p-highlights').value,
        floor_plans: document.getElementById('p-floor-plans').value,
        rera_number: document.getElementById('p-rera').value,
        brochure_url: document.getElementById('p-brochure').value,
        latitude: parseFloat(document.getElementById('p-lat').value) || 0,
        longitude: parseFloat(document.getElementById('p-lng').value) || 0,
        meta_title: document.getElementById('p-meta-title').value,
        meta_description: document.getElementById('p-meta-desc').value,
      };

      const res = await fetch(id ? `/admin/api/projects?id=${id}` : '/admin/api/projects', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) { 
        window.location.href = '/admin/projects'; 
      } else { 
        const d = await res.json(); 
        alert(d.error || 'Failed to save'); 
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      alert('An external error occurred.');
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });

  async function uploadProjectImage(fileInputId, folder) {
    const fileInput = document.getElementById(fileInputId);
    const file = fileInput.files?.[0];
    if (!file) {
      alert('Please choose an image first.');
      return null;
    }

    const formData = new FormData();
    formData.append('file', file);
    formData.append('folder', folder);

    const res = await fetch('/admin/api/upload-image', {
      method: 'POST',
      body: formData,
    });

    const data = await res.json();
    if (!res.ok) {
      throw new Error(data.error || 'Upload failed');
    }

    return data.url;
  }

  featuredFileInput?.addEventListener('change', async () => {
    const file = featuredFileInput.files?.[0];
    if (!file) return;
    const id = document.getElementById('p-id').value;
    updateFeaturedPreview(URL.createObjectURL(file));
    featuredStatus.textContent = 'Uploading featured image...';
    try {
      const url = await uploadProjectImage('p-featured-file', `${getProjectFolderBase()}/featured`);
      if (!url) return;
      featuredInput.value = url;
      updateFeaturedPreview(url);

      if (id) {
        const saveRes = await fetch(`/admin/api/projects?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ featured_image: url }),
        });
        if (!saveRes.ok) {
          const saveErr = await saveRes.json();
          alert(saveErr.error || 'Image uploaded, but database update failed.');
          return;
        }
      }

      featuredStatus.textContent = id
        ? 'Featured image uploaded and saved to database.'
        : 'Featured image uploaded. Save project to persist.';
    } catch (error) {
      console.error(error);
      featuredStatus.textContent = 'Featured image upload failed.';
    }
  });

  galleryFileInput?.addEventListener('change', async () => {
    const files = Array.from(galleryFileInput.files || []);
    if (!files.length) return;
    if (files.length > 10) {
      galleryStatus.textContent = 'You can upload maximum 10 images.';
      galleryFileInput.value = '';
      return;
    }
    const id = document.getElementById('p-id').value;
    const previewUrls = files.map((f) => URL.createObjectURL(f));
    renderGalleryPreview(previewUrls);
    galleryStatus.textContent = `Uploading ${files.length} gallery image(s)...`;
    try {
      const uploadedUrls = [];
      for (let i = 0; i < files.length; i++) {
        const file = files[i];
        const dt = new DataTransfer();
        dt.items.add(file);
        galleryFileInput.files = dt.files;
        const url = await uploadProjectImage('p-gallery-file', `${getProjectFolderBase()}/gallery`);
        if (!url) continue;
        uploadedUrls.push(url);
      }
      galleryInput.value = uploadedUrls.join('\n');
      renderGalleryPreview(uploadedUrls);
      if (id) {
        const saveRes = await fetch(`/admin/api/projects?id=${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ gallery_images: galleryInput.value }),
        });
        if (!saveRes.ok) {
          const saveErr = await saveRes.json();
          alert(saveErr.error || 'Image uploaded, but database update failed.');
          return;
        }
      }
      galleryStatus.textContent = id
        ? 'Gallery uploaded and saved to database.'
        : 'Gallery uploaded. Save project to persist.';
    } catch (error) {
      console.error(error);
      galleryStatus.textContent = 'Gallery upload failed.';
    }
  });
</script>
