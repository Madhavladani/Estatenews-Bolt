---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { Author } from '../../../lib/types';

const authorId = Astro.url.searchParams.get('id');
let authorToEdit: any = null;

if (authorId) {
  const { data } = await supabase.from('authors' as any).select('*').eq('id', authorId).single();
  authorToEdit = data;
}

const pageTitle = authorToEdit ? 'Edit Author' : 'Add Author';
---

<AdminLayout title={pageTitle} activeTab="authors">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/authors" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-4xl">
    <form id="author-form" class="space-y-6">
      <input type="hidden" id="a-id" value={authorToEdit?.id || ''} />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
          <input
            type="text"
            id="a-name"
            required
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            value={authorToEdit?.full_name || ''}
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
          <input
            type="text"
            id="a-slug"
            required
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            value={authorToEdit?.slug || ''}
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Photo URL</label>
          <div class="space-y-3">
            <div class="flex gap-3">
              <input
                type="url"
                id="a-photo"
                class="flex-1 px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
                placeholder="https://..."
                value={authorToEdit?.photo_url || ''}
              />
              <label
                class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-lg text-sm font-medium cursor-pointer transition-colors whitespace-nowrap flex items-center gap-2"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                </svg>
                <span>Upload</span>
                <input type="file" id="a-photo-file" accept="image/*" class="hidden" />
              </label>
            </div>
            <p id="a-photo-status" class="text-xs text-gray-500"></p>
            <div id="a-photo-preview-container" class={authorToEdit?.photo_url ? "relative inline-block" : "hidden relative inline-block"}>
              <img id="a-photo-preview" src={authorToEdit?.photo_url || ''} class="w-24 h-24 rounded-full border border-gray-200 object-cover" />
            </div>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Company Role</label>
          <input
            type="text"
            id="a-role"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            placeholder="e.g. Senior Real Estate Analyst"
            value={authorToEdit?.company_role || ''}
          />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Short Bio</label>
        <textarea
          id="a-bio"
          rows="3"
          class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
          placeholder="Brief introduction of the author..."
        >{authorToEdit?.short_bio || ''}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Experience</label>
          <input
            type="text"
            id="a-experience"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            placeholder="e.g. 10+ years in Real Estate"
            value={authorToEdit?.experience || ''}
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Expertise Areas (comma separated)</label>
          <input
            type="text"
            id="a-expertise"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            placeholder="Property Market, Investment, Luxury Villas"
            value={authorToEdit?.expertise_areas?.join(', ') || ''}
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">LinkedIn Profile</label>
          <input
            type="url"
            id="a-linkedin"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            placeholder="https://linkedin.com/in/username"
            value={authorToEdit?.linkedin_profile || ''}
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Other Social Links (JSON format)</label>
          <textarea
            id="a-socials"
            rows="2"
            class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm font-mono focus:ring-2 focus:ring-primary-500 outline-none transition-shadow"
            placeholder='[{"platform": "Twitter", "url": "..."}]'
          >{JSON.stringify(authorToEdit?.social_links || [])}</textarea>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2 border-t border-gray-100">
        <a href="/admin/authors" class="px-4 py-2 border border-gray-200 text-gray-700 rounded-lg text-sm hover:bg-gray-50">Cancel</a>
        <button
          type="submit"
          class="px-5 py-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg text-sm transition-colors"
        >
          Save Author
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('author-form') as HTMLFormElement;
  const nameInput = document.getElementById('a-name') as HTMLInputElement;
  const slugInput = document.getElementById('a-slug') as HTMLInputElement;
  const photoInput = document.getElementById('a-photo') as HTMLInputElement;
  const photoFileInput = document.getElementById('a-photo-file') as HTMLInputElement;
  const photoStatus = document.getElementById('a-photo-status') as HTMLParagraphElement;
  const photoPreview = document.getElementById('a-photo-preview') as HTMLImageElement;
  const photoPreviewContainer = document.getElementById('a-photo-preview-container') as HTMLDivElement;

  nameInput.addEventListener('input', (e) => {
    const id = (document.getElementById('a-id') as HTMLInputElement).value;
    if (id) return;
    const target = e.target as HTMLInputElement;
    const slug = target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    slugInput.value = slug;
  });

  async function uploadImage(file: File) {
    const formData = new FormData();
    formData.append('file', file);
    formData.append('folder', 'authors');

    const res = await fetch('/admin/api/upload-image', {
      method: 'POST',
      body: formData,
    });

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Upload failed');
    return data.url;
  }

  photoFileInput?.addEventListener('change', async () => {
    const file = photoFileInput.files?.[0];
    if (!file) return;

    photoStatus.textContent = 'Uploading...';
    photoStatus.className = 'text-xs text-primary-600 animate-pulse';

    try {
      const remoteUrl = await uploadImage(file);
      photoInput.value = remoteUrl;
      photoPreview.src = remoteUrl;
      photoPreviewContainer.classList.remove('hidden');
      photoStatus.textContent = 'Upload successful!';
      photoStatus.className = 'text-xs text-green-600';
    } catch (error: any) {
      console.error(error);
      photoStatus.textContent = 'Upload failed: ' + error.message;
      photoStatus.className = 'text-xs text-red-600';
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Saving...';
    submitBtn.disabled = true;

    try {
      const id = (document.getElementById('a-id') as HTMLInputElement).value;
      const expertiseStr = (document.getElementById('a-expertise') as HTMLInputElement).value;
      const expertise_areas = expertiseStr.split(',').map(s => s.trim()).filter(Boolean);
      
      let social_links = [];
      try {
        social_links = JSON.parse((document.getElementById('a-socials') as HTMLTextAreaElement).value);
      } catch (e) {
        console.warn('Social links JSON parse error, using empty array');
      }

      const body = {
        full_name: nameInput.value,
        slug: slugInput.value,
        photo_url: photoInput.value,
        short_bio: (document.getElementById('a-bio') as HTMLTextAreaElement).value,
        experience: (document.getElementById('a-experience') as HTMLInputElement).value,
        company_role: (document.getElementById('a-role') as HTMLInputElement).value,
        expertise_areas,
        linkedin_profile: (document.getElementById('a-linkedin') as HTMLInputElement).value,
        social_links,
      };

      const res = await fetch(id ? `/admin/api/authors?id=${id}` : '/admin/api/authors', {
        method: id ? 'PUT' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        window.location.href = '/admin/authors';
      } else {
        const data = await res.json();
        alert(data.error || 'Failed to save author');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    } catch (err: any) {
      console.error(err);
      alert('An error occurred: ' + err.message);
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>
