---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { Author } from '../../../lib/types';

const { data: authorsRes, error } = await supabase
  .from('authors')
  .select('*')
  .order('full_name');

const authors: Author[] = authorsRes || [];
---

<AdminLayout title="Manage Authors" activeTab="authors">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Authors</h1>
    <a
      href="/admin/authors/add"
      class="px-4 py-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg text-sm transition-colors flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add Author
    </a>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-100">
          <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Author</th>
          <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
          <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Created At</th>
          <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        {authors.length === 0 ? (
          <tr>
            <td colspan="4" class="px-6 py-8 text-center text-gray-500">
              No authors found. Click "Add Author" to create one.
            </td>
          </tr>
        ) : (
          authors.map((author) => (
            <tr class="hover:bg-gray-50 transition-colors group">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <img
                    src={author.photo_url || 'https://via.placeholder.com/40'}
                    alt={author.full_name}
                    class="w-10 h-10 rounded-full object-cover border border-gray-100"
                  />
                  <div>
                    <div class="font-semibold text-gray-900">{author.full_name}</div>
                    <div class="text-xs text-gray-500">/{author.slug}</div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600">{author.company_role}</td>
              <td class="px-6 py-4 text-sm text-gray-500">
                {new Date(author.created_at).toLocaleDateString()}
              </td>
              <td class="px-6 py-4 text-right space-x-2">
                <a
                  href={`/admin/authors/add?id=${author.id}`}
                  class="text-primary-600 hover:text-primary-700 font-medium text-sm"
                >
                  Edit
                </a>
                <button
                  class="text-red-600 hover:text-red-700 font-medium text-sm delete-author"
                  data-id={author.id}
                  data-name={author.full_name}
                >
                  Delete
                </button>
              </td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<script>
  const deleteButtons = document.querySelectorAll('.delete-author');
  deleteButtons.forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.dataset.id;
      const name = target.dataset.name;

      if (confirm(`Are you sure you want to delete author "${name}"? This may break blog post links.`)) {
        try {
          const res = await fetch(`/admin/api/authors?id=${id}`, {
            method: 'DELETE',
          });

          if (res.ok) {
            window.location.reload();
          } else {
            const data = await res.json();
            alert(data.error || 'Failed to delete author');
          }
        } catch (err) {
          console.error(err);
          alert('An error occurred');
        }
      }
    });
  });
</script>
