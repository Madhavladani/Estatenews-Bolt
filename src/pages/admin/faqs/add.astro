---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';
import type { City, Faq } from '../../../lib/types';

const faqId = Astro.url.searchParams.get('id');
let faqToEdit: (Faq & { city?: Pick<City, 'id' | 'name'> | null }) | null = null;

if (faqId) {
  const { data } = await supabase.from('faqs').select('*, city:cities(id,name)').eq('id', faqId).single();
  faqToEdit = (data as any) || null;
}

const { data: citiesData } = await supabase.from('cities').select('id,name').order('name');
const cities: Pick<City, 'id' | 'name'>[] = (citiesData as any) || [];

const pageTitle = faqToEdit ? 'Edit FAQ' : 'Add FAQ';
---

<AdminLayout title={pageTitle} activeTab="faqs">
  <div class="mb-6">
    <div class="flex items-center gap-4">
      <a href="/admin/faqs" class="text-gray-500 hover:text-gray-700 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      </a>
      <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 max-w-2xl">
    <form id="faq-form" class="space-y-4">
      <input type="hidden" id="faq-id" value={faqToEdit?.id ?? ''} />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="faq-city" class="block text-sm font-medium text-gray-700 mb-1">City</label>
          <select id="faq-city" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">
            <option value="" selected={!faqToEdit?.city_id}>General (No City)</option>
            {cities.map((city) => (
              <option value={city.id} selected={city.id === faqToEdit?.city_id}>{city.name}</option>
            ))}
          </select>
          <p class="text-xs text-gray-500 mt-1">General FAQs show on all cities and on the FAQ page.</p>
        </div>

        <div class="flex items-center gap-6 pt-6 md:pt-0">
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input id="faq-homepage" type="checkbox" class="rounded border-gray-300 text-primary-600 focus:ring-primary-500" checked={!!faqToEdit?.is_homepage} />
            Add to home page
          </label>
          <label class="inline-flex items-center gap-2 text-sm text-gray-700">
            <input id="faq-active" type="checkbox" class="rounded border-gray-300 text-primary-600 focus:ring-primary-500" checked={faqToEdit ? !!faqToEdit.is_active : true} />
            Active
          </label>
        </div>
      </div>

      <div>
        <label for="faq-question" class="block text-sm font-medium text-gray-700 mb-1">Question *</label>
        <input type="text" id="faq-question" required value={faqToEdit?.question ?? ''} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
      </div>

      <div>
        <label for="faq-answer" class="block text-sm font-medium text-gray-700 mb-1">Answer *</label>
        <textarea id="faq-answer" rows={6} required class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow">{faqToEdit?.answer ?? ''}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="faq-sort" class="block text-sm font-medium text-gray-700 mb-1">Sort Order</label>
          <input type="number" id="faq-sort" value={faqToEdit?.sort_order ?? 0} class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-500 outline-none transition-shadow" />
          <p class="text-xs text-gray-500 mt-1">Lower numbers appear first.</p>
        </div>
      </div>

      <div class="pt-2 flex gap-3">
        <button type="submit" class="px-6 py-2.5 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg transition-colors text-sm">
          Save FAQ
        </button>
        <a href="/admin/faqs" class="px-6 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-900 font-semibold rounded-lg transition-colors text-sm">
          Cancel
        </a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('faq-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type=\"submit\"]') as HTMLButtonElement | null;
      const originalText = submitBtn?.textContent || 'Save FAQ';
      if (submitBtn) {
        submitBtn.textContent = 'Saving...';
        submitBtn.disabled = true;
      }

      try {
        const id = (document.getElementById('faq-id') as HTMLInputElement)?.value || '';
        const cityId = (document.getElementById('faq-city') as HTMLSelectElement)?.value || null;

        const body = {
          city_id: cityId || null,
          question: (document.getElementById('faq-question') as HTMLInputElement)?.value || '',
          answer: (document.getElementById('faq-answer') as HTMLTextAreaElement)?.value || '',
          is_homepage: !!(document.getElementById('faq-homepage') as HTMLInputElement)?.checked,
          is_active: !!(document.getElementById('faq-active') as HTMLInputElement)?.checked,
          sort_order: parseInt((document.getElementById('faq-sort') as HTMLInputElement)?.value || '0', 10) || 0,
        };

        const res = await fetch(id ? `/admin/api/faqs?id=${id}` : '/admin/api/faqs', {
          method: id ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          window.location.href = '/admin/faqs';
          return;
        }

        const d = await res.json().catch(() => ({}));
        alert(d.error || 'Failed to save');
      } catch (err) {
        console.error(err);
        alert('An external error occurred.');
      } finally {
        if (submitBtn) {
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
        }
      }
    });
  }
</script>

