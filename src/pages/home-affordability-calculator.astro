---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Home Affordability Calculator | Home Nesto"
  description="Determine how much home you can afford based on your income, savings, and monthly debts. Plan your home purchase with confidence using Home Nesto."
>
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Home Nesto Home Affordability Calculator",
      "url": "https://www.homenesto.com/home-affordability-calculator",
      "description": "Calculate your home buying budget based on income and expenses.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "INR" }
    }
  </script>

  <header class="page-header">
    <span class="header-badge">🏠 Budget Planner</span>
    <h1>Home Affordability Calculator<span class="accent-dot">.</span></h1>
    <p>
      Find out your maximum home buying budget based on your financial profile.
    </p>
  </header>

  <main class="main-container">
    <div class="calculator-card">
      <div class="input-grid">
        <div class="input-group">
          <label for="monthlyIncome">Monthly Gross Income (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="monthlyIncome" value="150000" step="5000" />
          </div>
          <input type="range" id="monthlyIncomeSlider" class="range-slider" min="20000" max="1000000" step="5000" value="150000" />
        </div>

        <div class="input-group">
          <label for="existingEmi">Existing Monthly Debts/EMIs (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="existingEmi" value="0" step="1000" />
          </div>
          <input type="range" id="existingEmiSlider" class="range-slider" min="0" max="500000" step="1000" value="0" />
        </div>

        <div class="input-group">
          <label for="downPayment">Down Payment Available (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="downPayment" value="1000000" step="50000" />
          </div>
          <input type="range" id="downPaymentSlider" class="range-slider" min="0" max="50000000" step="50000" value="1000000" />
        </div>

        <div class="input-group">
          <label for="interestRate">Expected Interest Rate (%)</label>
          <div class="input-wrapper">
            <span class="prefix">%</span>
            <input type="number" id="interestRate" value="8.5" step="0.1" />
          </div>
          <input type="range" id="interestRateSlider" class="range-slider" min="1" max="20" step="0.1" value="8.5" />
        </div>

        <div class="input-group">
          <label for="tenure">Loan Tenure (Years)</label>
          <div class="input-wrapper">
            <input type="number" id="tenure" value="20" />
          </div>
          <input type="range" id="tenureSlider" class="range-slider" min="1" max="30" step="1" value="20" />
        </div>
      </div>

      <div class="calc-btn-wrapper">
        <button id="calculateBtn" class="btn-calculate">Calculate Affordability</button>
        <button id="resetBtn" class="btn-reset">↺ Reset</button>
      </div>

      <div id="resultContainer" class="results-container">
        <p class="result-header">🏠 Your Estimated Home Budget</p>
        <div class="result-inner-grid">
          <div class="result-item emi-highlight">
            <p class="result-label">Maximum Property Value</p>
            <p id="totalBudgetText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Maximum Loan Amount</p>
            <p id="maxLoanText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Suggested Monthly EMI</p>
            <p id="suggestedEmiText" class="result-value">—</p>
          </div>
        </div>
      </div>
    </div>

    <section class="faq-section">
      <h2>Affordability FAQs</h2>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>How is home affordability calculated?</summary>
          <div class="faq-answer">
            It is based on your income, existing debts, and the down payment you have saved. Lenders typically prefer that your total debt payments don't exceed 40-50% of your gross income.
          </div>
        </details>
        <details class="faq-item">
          <summary>What is the 28/36 rule?</summary>
          <div class="faq-answer">
            A common rule where you spend 28% of your gross income on housing and no more than 36% on total debt. We use a slightly more flexible Indian market standard of 45-50% for high-income earners.
          </div>
        </details>
      </div>
    </section>

    <p class="footer-note">
      Powered by <strong>Home Nesto</strong> — India's trusted real estate platform.
      &nbsp;|&nbsp;
      <a href="/tools">All Tools</a>
    </p>
  </main>
</BaseLayout>

<script is:inline>
  function calculateAffordability() {
    const income = parseFloat(document.getElementById('monthlyIncome').value) || 0;
    const debts = parseFloat(document.getElementById('existingEmi').value) || 0;
    const downPayment = parseFloat(document.getElementById('downPayment').value) || 0;
    const rate = parseFloat(document.getElementById('interestRate').value) || 0;
    const years = parseFloat(document.getElementById('tenure').value) || 0;

    const maxDti = 0.50; // Max Debt-to-Income ratio (50%)
    const availableForEmi = (income * maxDti) - debts;

    if (availableForEmi <= 0) {
      alert("Your existing debts exceed 50% of your income. You may not be eligible for a new loan currently.");
      return;
    }

    const monthlyRate = rate / 12 / 100;
    const months = years * 12;

    // Loan Amount = EMI * [(1 + r)^n - 1] / [r * (1 + r)^n]
    const maxLoan = availableForEmi * (Math.pow(1 + monthlyRate, months) - 1) / (monthlyRate * Math.pow(1 + monthlyRate, months));
    
    const totalBudget = maxLoan + downPayment;

    document.getElementById('totalBudgetText').innerText = '₹' + Math.round(totalBudget).toLocaleString('en-IN');
    document.getElementById('maxLoanText').innerText = '₹' + Math.round(maxLoan).toLocaleString('en-IN');
    document.getElementById('suggestedEmiText').innerText = '₹' + Math.round(availableForEmi).toLocaleString('en-IN');
    
    document.getElementById('resultContainer').classList.add('visible');
  }

  // Bind sliders and inputs
  const inputs = ['monthlyIncome', 'existingEmi', 'downPayment', 'interestRate', 'tenure'];
  inputs.forEach(id => {
    const input = document.getElementById(id);
    const slider = document.getElementById(id + 'Slider');
    if (slider) {
      input.addEventListener('input', () => { slider.value = input.value; });
      slider.addEventListener('input', () => { input.value = slider.value; });
    }
  });

  document.getElementById('calculateBtn').addEventListener('click', calculateAffordability);
  document.getElementById('resetBtn').addEventListener('click', () => {
    location.reload();
  });
</script>

<style is:global>
  /* Reuse styles from EMI calculator pattern */
  :root {
    --primary: #1e3a5f;
    --accent: #f97316;
    --text-dark: #1a1a2e;
    --text-medium: #4a5568;
    --text-light: #718096;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-200: #e2e8f0;
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
    --radius-xl: 24px;
    --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .page-header {
    background: linear-gradient(160deg, #0a1929 0%, #0d2137 40%, #122d4a 100%);
    padding: 3rem 1.5rem 3.5rem;
    text-align: center;
    color: white;
  }
  
  .page-header h1 { font-size: 2.5rem; }
  .accent-dot { color: var(--accent); }
  .header-badge {
    display: inline-block;
    background: rgba(249, 115, 22, 0.15);
    color: #fca35d;
    font-size: 0.8rem;
    padding: 0.35rem 1rem;
    border-radius: 50px;
    margin-bottom: 1rem;
  }

  .main-container {
    max-width: 960px;
    margin: -2rem auto 0;
    padding: 0 1.25rem 3rem;
  }

  .calculator-card {
    background: white;
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-lg);
  }

  .input-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .input-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .input-wrapper {
    position: relative;
    margin-bottom: 0.5rem;
  }

  .prefix {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-light);
    font-weight: 700;
  }

  .input-wrapper input {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2rem;
    border: 2px solid var(--gray-200);
    border-radius: 12px;
    font-size: 1.1rem;
  }

  .range-slider {
    width: 100%;
    accent-color: var(--primary);
  }

  .calc-btn-wrapper {
    display: flex;
    gap: 1rem;
  }

  .btn-calculate {
    background: var(--accent);
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    cursor: pointer;
    transition: 0.2s;
  }

  .btn-calculate:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(249,115,22,0.4); }

  .results-container {
    margin-top: 2rem;
    background: #1e3a5f;
    color: white;
    padding: 2rem;
    border-radius: 20px;
    display: none;
  }

  .results-container.visible { display: block; }
  .result-header { font-weight: 700; margin-bottom: 1.5rem; font-size: 1.2rem; }
  .result-inner-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
  .result-item { background: rgba(255,255,255,0.1); padding: 1.25rem; border-radius: 15px; }
  .result-label { font-size: 0.8rem; color: #b0c4d8; margin-bottom: 0.5rem; }
  .result-value { font-size: 1.5rem; font-weight: 800; }
  .emi-highlight .result-value { color: #f97316; }

  .faq-section { margin-top: 4rem; }
  .faq-item { background: white; padding: 1rem; border-radius: 12px; margin-bottom: 1rem; }
  .footer-note { text-align: center; margin-top: 3rem; color: var(--text-light); }

  @media (max-width: 768px) {
    .input-grid { grid-template-columns: 1fr; }
    .result-inner-grid { grid-template-columns: 1fr; }
  }
</style>
