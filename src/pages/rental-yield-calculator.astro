---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rental Yield Calculator | Home Nesto"
  description="Calculate the gross and net rental yield of your investment property with Home Nesto's free calculator."
>
  <header class="page-header">
    <span class="header-badge">📊 Yield Analysis</span>
    <h1>Rental Yield Calculator<span class="accent-dot">.</span></h1>
    <p>
      Evaluate the annual return on your rental property investments.
    </p>
  </header>

  <main class="main-container">
    <div class="calculator-card">
      <div class="input-grid">
        <div class="input-group">
          <label for="propertyPrice">Property Value (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="propertyPrice" value="7500000" step="50000" />
          </div>
        </div>

        <div class="input-group">
          <label for="monthlyRent">Monthly Rent (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="monthlyRent" value="30000" step="500" />
          </div>
        </div>

        <div class="input-group">
          <label for="annualExpenses">Annual Maintenance & Taxes (INR)</label>
          <div class="input-wrapper">
            <span class="prefix">₹</span>
            <input type="number" id="annualExpenses" value="60000" step="1000" />
          </div>
        </div>

        <div class="input-group">
          <label for="vacancyRate">Estimated Vacancy (%)</label>
          <div class="input-wrapper">
            <span class="prefix">%</span>
            <input type="number" id="vacancyRate" value="5" step="1" />
          </div>
        </div>
      </div>

      <div class="calc-btn-wrapper">
        <button id="calculateBtn" class="btn-calculate">Calculate Yield</button>
        <button id="resetBtn" class="btn-reset">↺ Reset</button>
      </div>

      <div id="resultContainer" class="results-container">
        <p class="result-header">💎 Rental Yield Breakdown</p>
        <div class="result-inner-grid">
          <div class="result-item emi-highlight">
            <p class="result-label">Net Rental Yield</p>
            <p id="netYieldText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Gross Rental Yield</p>
            <p id="grossYieldText" class="result-value">—</p>
          </div>
          <div class="result-item">
            <p class="result-label">Annual Net Income</p>
            <p id="netIncomeText" class="result-value">—</p>
          </div>
        </div>
      </div>
    </div>
    <div style="margin-top: 3rem; text-align: center;">
      <a href="/tools/" style="color: var(--accent); font-weight: 700; text-decoration: none;">← Back to All Tools</a>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  function calculateYield() {
    const price = parseFloat(document.getElementById('propertyPrice').value) || 0;
    const rent = parseFloat(document.getElementById('monthlyRent').value) || 0;
    const expenses = parseFloat(document.getElementById('annualExpenses').value) || 0;
    const vacancy = parseFloat(document.getElementById('vacancyRate').value) || 0;

    const annualGrossRent = rent * 12;
    const grossYield = (annualGrossRent / price) * 100;

    const adjustedRent = annualGrossRent * (1 - vacancy/100);
    const netIncome = adjustedRent - expenses;
    const netYield = (netIncome / price) * 100;

    document.getElementById('grossYieldText').innerText = grossYield.toFixed(2) + '%';
    document.getElementById('netYieldText').innerText = netYield.toFixed(2) + '%';
    document.getElementById('netIncomeText').innerText = '₹' + Math.round(netIncome).toLocaleString('en-IN');
    
    document.getElementById('resultContainer').classList.add('visible');
  }

  document.getElementById('calculateBtn').addEventListener('click', calculateYield);
  document.getElementById('resetBtn').addEventListener('click', () => { location.reload(); });
</script>

<style is:global>
  :root {
    --primary: #1e3a5f;
    --accent: #f97316;
    --text-dark: #1a1a2e;
    --text-medium: #4a5568;
    --text-light: #718096;
    --white: #ffffff;
    --gray-50: #f8fafc;
    --gray-200: #e2e8f0;
    --shadow-lg: 0 12px 40px rgba(0, 0, 0, 0.12);
    --radius-xl: 24px;
  }
  .page-header { background: linear-gradient(160deg, #0a1929 0%, #0d2137 40%, #122d4a 100%); padding: 3rem 1.5rem 3.5rem; text-align: center; color: white; }
  .header-badge { background: rgba(249, 115, 22, 0.15); color: #fca35d; padding: 0.35rem 1rem; border-radius: 50px; font-size: 0.8rem; margin-bottom: 1rem; display: inline-block; }
  .main-container { max-width: 960px; margin: -2rem auto 0; padding: 0 1.25rem 3rem; }
  .calculator-card { background: white; border-radius: var(--radius-xl); padding: 2.5rem; box-shadow: var(--shadow-lg); }
  .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
  .input-group label { display: block; font-size: 0.85rem; font-weight: 700; margin-bottom: 0.5rem; }
  .input-wrapper { position: relative; margin-bottom: 0.5rem; }
  .prefix { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-light); font-weight: 700; }
  .input-wrapper input { width: 100%; padding: 0.75rem 1rem 0.75rem 2rem; border: 2px solid var(--gray-200); border-radius: 12px; font-size: 1.1rem; }
  .calc-btn-wrapper { display: flex; gap: 1rem; }
  .btn-calculate { background: var(--accent); color: white; border: none; padding: 1rem 2rem; border-radius: 50px; font-weight: 700; cursor: pointer; }
  .results-container { margin-top: 2rem; background: #1e3a5f; color: white; padding: 2rem; border-radius: 20px; display: none; }
  .results-container.visible { display: block; }
  .result-inner-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
  .result-item { background: rgba(255,255,255,0.1); padding: 1.25rem; border-radius: 15px; }
  @media (max-width: 768px) { .input-grid { grid-template-columns: 1fr; } .result-inner-grid { grid-template-columns: 1fr; } }
</style>
