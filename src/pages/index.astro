---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CollectionCard from '../components/CollectionCard.astro';
import FAQSection from '../components/FAQSection.astro';
import NewsCard from '../components/NewsCard.astro';
import { supabase } from '../lib/supabase';
import { buildBreadcrumbSchema } from '../lib/seo';
import type { City, Project, Collection, News } from '../lib/types';

const [citiesRes, projectsRes, collectionsRes, newsRes] = await Promise.all([
  // Build-time fetch only; page is prerendered.
  supabase.from('cities').select('*').order('name'),
  supabase.from('projects').select('*, city:cities(*)').order('published_at', { ascending: false }),
  supabase.from('collections').select('*, city:cities(*)').order('created_at', { ascending: false }),
  supabase.from('news').select('*').eq('is_published', true).order('published_at', { ascending: false }).limit(6),
]);

const cities: City[] = citiesRes.data || [];
const allProjects: (Project & { city?: City })[] = projectsRes.data || [];
const collections: (Collection & { city?: City })[] = collectionsRes.data || [];
const latestNews: News[] = newsRes.data || [];

const residentialProjects = allProjects.filter((p) => p.project_type === 'residential');
const commercialProjects = allProjects.filter((p) => p.project_type === 'commercial');
const latestResidential = residentialProjects.slice(0, 6);
const latestCommercial = commercialProjects.slice(0, 6);
const trendingProjects = allProjects.slice(0, 4);

const projectCounts: Record<string, number> = {};
for (const p of allProjects) {
  const slug = p.city?.slug;
  if (!slug) continue;
  projectCounts[slug] = (projectCounts[slug] || 0) + 1;
}

const featuredDesktopLimit = 12;
const featuredCities = cities.map((city) => {
  const initials = city.name
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? '')
    .join('');
  return { ...city, initials };
});

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://propdiscover.com' },
]);

const listingFaqs = [
  {
    question: 'How do I add my property / project on PropDiscover?',
    answer: 'Use the “List Your Project / Properties” form and share your basic project details. Our team reviews and publishes eligible listings.',
  },
  {
    question: 'What details should I submit?',
    answer: 'Project name, location/city, property type, a short description, and your contact details (builder/company). Images and brochures help.',
  },
  {
    question: 'How long does approval take?',
    answer: 'Most submissions are reviewed within 24–48 hours (business days). We may contact you for missing details.',
  },
  {
    question: 'Is listing free?',
    answer: 'Basic listings can be supported; featured placements and premium promotion may be available on request.',
  },
];
---

<BaseLayout
  title="PropDiscover - Top Real Estate Projects in Gujarat | Residential & Commercial Properties"
  description="Discover the best residential and commercial real estate projects across Ahmedabad, Surat, and Rajkot. Explore new launches, luxury apartments, villas, and office spaces with premium amenities."
  jsonLd={breadcrumbSchema}
>
  <!-- Hero Section -->
  <section class="relative bg-primary-800 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src="https://images.pexels.com/photos/1474115/pexels-photo-1474115.jpeg?auto=compress&cs=tinysrgb&w=1920" alt="" class="w-full h-full object-cover" loading="eager" width="1920" height="1080" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary-900/95 to-primary-800/80"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Discover Top <span class="text-accent-400">Real Estate</span> Projects in Gujarat
        </h1>
        <p class="text-lg md:text-xl text-gray-300 mb-8 leading-relaxed">
          Explore premium residential and commercial properties across Ahmedabad, Surat, and Rajkot. Find your perfect home or investment opportunity.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="relative flex-1">
            <select
              id="city-select"
              class="w-full px-5 py-3.5 rounded-xl text-gray-900 bg-white shadow-lg focus:ring-2 focus:ring-accent-500 outline-none text-sm appearance-none cursor-pointer"
            >
              <option value="" disabled selected>Select your city...</option>
              {cities.map((city) => (
                <option value={city.slug}>{city.name}</option>
              ))}
            </select>
            <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
          <button id="hero-search-btn" class="px-8 py-3.5 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-xl shadow-lg transition-colors text-sm">
            Search Projects
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Cities -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Explore by City</h2>
        <p class="text-gray-600">Find the best properties in Gujarat's top real estate destinations</p>
      </div>

      <div class="md:hidden overflow-x-auto pb-2 -mx-1 px-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <div class="grid grid-rows-2 grid-flow-col auto-cols-max gap-3 min-w-max">
          {featuredCities.map((city, idx) => (
            <a
              href={`/${city.slug}`}
              class:list={[
                'group inline-flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md hover:border-primary-200 transition-all whitespace-nowrap',
                idx >= featuredDesktopLimit && 'mobile-extra-city hidden',
              ]}
            >
              <div class="relative flex items-center justify-center w-10 h-10 rounded-full bg-primary-50 text-primary-700 font-semibold text-xs">
                <svg class="absolute -top-1 -left-1 w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span>{city.initials}</span>
              </div>
	              <div>
	                <p class="text-sm font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">{city.name}</p>
	                <p class="text-xs text-gray-500">{projectCounts[city.slug] || 0} projects</p>
	              </div>
	            </a>
	          ))}
	        </div>
      </div>
      {featuredCities.length > featuredDesktopLimit && (
        <div class="md:hidden flex justify-center mt-6">
          <button
            id="show-all-cities-btn-mobile"
            type="button"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary-700 hover:bg-primary-800 text-white font-medium rounded-lg transition-colors text-sm"
            data-expanded="false"
          >
            View All Cities
          </button>
        </div>
      )}

      <div id="desktop-city-list" class="hidden md:grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredCities.map((city, idx) => (
          <a
            href={`/${city.slug}`}
            class:list={[
              'group flex items-center gap-3 px-4 py-3 bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md hover:border-primary-200 transition-all',
              idx >= featuredDesktopLimit && 'desktop-extra-city hidden',
            ]}
          >
            <div class="relative flex items-center justify-center w-10 h-10 rounded-full bg-primary-50 text-primary-700 font-semibold text-xs">
              <svg class="absolute -top-1 -left-1 w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <span>{city.initials}</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900 group-hover:text-primary-700 transition-colors">{city.name}</p>
              <p class="text-xs text-gray-500">{projectCounts[city.slug] || 0} projects</p>
            </div>
          </a>
        ))}
      </div>

      {featuredCities.length > featuredDesktopLimit && (
        <div class="hidden md:flex justify-center mt-8">
          <button
            id="show-all-cities-btn"
            type="button"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary-700 hover:bg-primary-800 text-white font-medium rounded-lg transition-colors text-sm"
            data-expanded="false"
          >
            View All Cities
          </button>
        </div>
      )}
    </div>
  </section>

  <!-- Residential / Commercial Tabs -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-8 border-b border-gray-200">
        <button id="tab-residential" class="tab-btn px-6 py-3 text-sm font-semibold border-b-2 border-primary-700 text-primary-700 transition-colors" data-tab="residential">
          Residential Projects
        </button>
        <button id="tab-commercial" class="tab-btn px-6 py-3 text-sm font-semibold border-b-2 border-transparent text-gray-500 hover:text-gray-700 transition-colors" data-tab="commercial">
          Commercial Projects
        </button>
      </div>
      <div id="panel-residential" class="tab-panel">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestResidential.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/ahmedabad/residential" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-700 hover:bg-primary-800 text-white font-medium rounded-lg transition-colors text-sm">
            View All Residential Projects
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
      <div id="panel-commercial" class="tab-panel hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestCommercial.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/ahmedabad/commercial" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-700 hover:bg-primary-800 text-white font-medium rounded-lg transition-colors text-sm">
            View All Commercial Projects
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

	  <!-- Trending Projects -->
	  <section class="py-16 bg-gray-50">
	    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
	      <div class="text-center mb-10">
	        <h2 class="text-3xl font-bold text-gray-900 mb-3">Trending Projects</h2>
	        <p class="text-gray-600">Most searched and viewed projects this week</p>
	      </div>
	      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
	        {trendingProjects.map((project) => (
	          <ProjectCard project={project} />
	        ))}
	      </div>
	    </div>
	  </section>

    <!-- Latest News -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between gap-4 mb-10">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2">Latest Real Estate News</h2>
            <p class="text-gray-600">Fresh updates, launches, and market insights.</p>
          </div>
          <a href="/news" class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold text-primary-700 hover:text-primary-800">
            View all news
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>

        {latestNews.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {latestNews.map((article) => (
              <NewsCard article={article} />
            ))}
          </div>
        ) : (
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-10 text-center text-gray-500">
            News will appear here once published.
          </div>
        )}

        <div class="sm:hidden text-center mt-8">
          <a href="/news" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-700 hover:bg-primary-800 text-white font-medium rounded-lg transition-colors text-sm">
            View all news
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

	  <!-- List Your Project / Properties -->
	  <section class="py-16 bg-primary-800 text-white">
	    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
	      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
	        <div class="lg:col-span-2">
	          <h2 class="text-3xl font-bold mb-3">Add Your Properties / Project</h2>
	          <p class="text-gray-200 leading-relaxed">
	            Are you a builder, developer, or channel partner? Submit your listing and get discovered by serious buyers across Gujarat.
	          </p>
	        </div>
	        <div class="flex lg:justify-end">
	          <a
	            href="/list-your-project-properties"
	            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-accent-500 hover:bg-accent-600 text-white font-semibold rounded-xl shadow-lg transition-colors text-sm w-full sm:w-auto"
	          >
	            List Your Project
	            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
	              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
	            </svg>
	          </a>
	        </div>
	      </div>
	    </div>
	  </section>

		  <FAQSection title="Listing FAQs" faqs={listingFaqs} />

  <!-- Collections -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Curated Collections</h2>
        <p class="text-gray-600">Handpicked project collections for every need and budget</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {collections.slice(0, 6).map((col) => (
          <CollectionCard collection={col} />
        ))}
      </div>
    </div>
  </section>

  <!-- SEO Content Block -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Gujarat Real Estate - Your Complete Property Guide</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Gujarat has emerged as one of India's most dynamic real estate markets, with cities like Ahmedabad, Surat, and Rajkot leading the growth. The state's robust infrastructure development, expanding metro connectivity, and business-friendly policies have made it a prime destination for homebuyers and investors alike.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          Ahmedabad, the commercial capital of Gujarat, offers a diverse range of residential and commercial projects. From luxury apartments on SG Highway and Prahlad Nagar to affordable housing in Bopal and Chandlodiya, the city caters to every budget and lifestyle. The Sabarmati Riverfront development has further enhanced the city's appeal with premium waterfront properties.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          Surat, the diamond and textile capital of India, is witnessing unprecedented real estate growth. Areas like Vesu, Piplod, and Adajan offer premium residential options, while the Ring Road corridor is emerging as a major commercial hub. The upcoming metro connectivity is set to further boost property values in the city.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Rajkot, the cultural heart of Saurashtra, presents affordable yet quality real estate options. With developing areas like Kalawad Road and NBU Road, the city offers excellent value for both homebuyers and investors. The growing industrial corridor along Morbi Road is attracting commercial development and business investments.
        </p>
      </div>
    </div>
  </section>

  <!-- Internal Links -->
  <section class="py-12 bg-primary-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold mb-6">Quick Links</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {cities.map((city) => (
          <div>
            <h3 class="font-semibold text-accent-400 mb-2">{city.name}</h3>
            <ul class="space-y-1">
              <li><a href={`/${city.slug}/residential`} class="text-sm text-gray-300 hover:text-white transition-colors">Residential Projects</a></li>
              <li><a href={`/${city.slug}/commercial`} class="text-sm text-gray-300 hover:text-white transition-colors">Commercial Projects</a></li>
            </ul>
          </div>
        ))}
        <div>
          <h3 class="font-semibold text-accent-400 mb-2">Collections</h3>
          <ul class="space-y-1">
            {collections.slice(0, 3).map((col) => (
              <li><a href={`/collections/${col.slug}`} class="text-sm text-gray-300 hover:text-white transition-colors">{col.title}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach((t) => {
        t.classList.remove('border-primary-700', 'text-primary-700');
        t.classList.add('border-transparent', 'text-gray-500');
      });
      tab.classList.remove('border-transparent', 'text-gray-500');
      tab.classList.add('border-primary-700', 'text-primary-700');
      panels.forEach((p) => p.classList.add('hidden'));
      document.getElementById(`panel-${target}`)?.classList.remove('hidden');
    });
  });

  const citySelect = document.getElementById('city-select') as HTMLSelectElement;
  const heroSearchBtn = document.getElementById('hero-search-btn');

  heroSearchBtn?.addEventListener('click', () => {
    const slug = citySelect.value;
    if (slug) {
      window.location.href = `/${slug}`;
    } else {
      citySelect.focus();
    }
  });

  const showAllBtn = document.getElementById('show-all-cities-btn');
  const hiddenDesktopCities = document.querySelectorAll('.desktop-extra-city');
  showAllBtn?.addEventListener('click', () => {
    const isExpanded = showAllBtn.getAttribute('data-expanded') === 'true';
    hiddenDesktopCities.forEach((city) => city.classList.toggle('hidden', isExpanded));
    showAllBtn.setAttribute('data-expanded', String(!isExpanded));
    showAllBtn.textContent = isExpanded ? 'View All Cities' : 'Show Less Cities';
  });

  const showAllBtnMobile = document.getElementById('show-all-cities-btn-mobile');
  const hiddenMobileCities = document.querySelectorAll('.mobile-extra-city');
  showAllBtnMobile?.addEventListener('click', () => {
    const isExpanded = showAllBtnMobile.getAttribute('data-expanded') === 'true';
    hiddenMobileCities.forEach((city) => city.classList.toggle('hidden', isExpanded));
    showAllBtnMobile.setAttribute('data-expanded', String(!isExpanded));
    showAllBtnMobile.textContent = isExpanded ? 'View All Cities' : 'Show Less Cities';
  });
</script>
<script type="application/json" id="city-data-json">
  {JSON.stringify(cities.map((city) => ({ name: city.name, slug: city.slug })))}
</script>
