---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import CollectionCard from '../../components/CollectionCard.astro';
import { supabase } from '../../lib/supabase';
import { buildBreadcrumbSchema, buildFAQSchema } from '../../lib/seo';
import type { Collection } from '../../lib/types';

const { data: collectionsData } = await supabase
  .from('collections')
  .select('*, city:cities(*)')
  .order('created_at', { ascending: false });

const collections: (Collection & { city?: any })[] = collectionsData || [];

const cities = Array.from(
  new Map(
    collections
      .filter((c) => c.city?.slug && c.city?.name)
      .map((c) => {
        const slug = String(c.city.slug).trim().toLowerCase();
        return [slug, { slug, name: c.city.name as string }];
      })
  ).values()
).sort((a, b) => a.name.localeCompare(b.name));

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Home', url: 'https://propdiscover.com' },
  { name: 'Collections', url: 'https://propdiscover.com/collections' },
]);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Curated Real Estate Collections',
  description:
    'Browse curated collections of residential and commercial real estate projects, grouped by theme, budget, lifestyle, and location.',
  itemListElement: collections.map((col, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `https://propdiscover.com/collections/${col.slug}`,
    name: col.title,
    description: col.intro_content,
  })),
};

const faqs = [
  {
    question: 'What are real estate collections on PropDiscover?',
    answer:
      'Collections are curated lists of top projects grouped by theme such as luxury living, affordable homes, new launches, investment picks, and location-based picks to help you shortlist faster.',
  },
  {
    question: 'How do I choose the best collection for my needs?',
    answer:
      'Start by selecting a theme (budget, lifestyle, possession status, or city). Then open a collection to compare projects, pricing ranges, and highlights before you contact builders.',
  },
  {
    question: 'Are collections updated regularly?',
    answer:
      'Yes. Collections are refreshed as new projects launch, pricing or availability changes, and new data is added—so you can make decisions with the latest context.',
  },
  {
    question: 'Can I browse collections city-wise?',
    answer:
      'Yes. Many collections are city-specific. Use the dropdown to open a collection and explore projects in that area.',
  },
];

const faqSchema = buildFAQSchema(faqs);
---

<BaseLayout
  title="Curated Real Estate Collections (Luxury, Affordable, New Launches) | PropDiscover"
  description="Explore curated real estate collections across Gujarat: luxury apartments, affordable homes, new launches, ready-to-move picks, and investment-focused projects. Open any collection to compare the best options fast."
  canonical="https://propdiscover.com/collections"
  keywords="real estate collections, curated property lists, luxury apartments Gujarat, affordable homes Gujarat, new launch projects, ready to move properties, investment properties, residential projects, commercial projects"
  jsonLd={[breadcrumbSchema, itemListSchema, faqSchema]}
  breadcrumbs={[{ name: 'Collections', url: '/collections' }]}
>
  <section class="relative overflow-hidden bg-gradient-to-b from-primary-900 via-primary-800 to-primary-700 text-white">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute -top-24 -right-24 w-72 h-72 bg-white/20 blur-3xl rounded-full"></div>
      <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-accent-400/30 blur-3xl rounded-full"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight">Curated Real Estate Collections</h1>
        <p class="mt-4 text-base md:text-lg text-white/85">
          Explore the strongest shortlists for <strong>luxury</strong>, <strong>affordable</strong>, <strong>new launch</strong> and
          <strong>investment</strong> projects—carefully curated to help you compare faster.
        </p>

        <div class="mt-7 bg-white/10 backdrop-blur rounded-2xl p-4 md:p-5 border border-white/15">
          <div class="flex flex-col sm:flex-row sm:items-end gap-3">
	            <div class="flex-1">
	              <label for="city-select" class="block text-sm font-medium text-white/90">
	                Browse collections by city
	              </label>
		              <select
		                id="city-select"
		                class="mt-2 w-full rounded-xl bg-white text-gray-900 px-3 py-3 text-sm shadow-sm border border-white/30 focus:outline-none focus:ring-2 focus:ring-accent-400"
		              >
		                <option value="/collections">All cities (All collections)</option>
		                {cities.map((city) => (
		                  <option value={`/collections/city/${city.slug}`}>{city.name}</option>
		                ))}
		              </select>
	            </div>
            <div class="text-xs text-white/70 sm:pb-1">
              Choose a city to see only its collections.
            </div>
          </div>
        </div>

	        <div class="mt-6 flex flex-wrap gap-2">
	          {collections.slice(0, 6).map((col) => (
	            <a
	              href={`/collections/${col.slug}`}
	              class="inline-flex items-center rounded-full bg-white/10 hover:bg-white/15 border border-white/15 px-3 py-1.5 text-sm transition"
	            >
	              {col.title}
	            </a>
	          ))}
	        </div>
	      </div>
	    </div>

	    <script is:inline>
	      document.addEventListener('change', (e) => {
	        const t = e.target;
	        if (t && t.id === 'city-select' && t.value) window.location.href = String(t.value);
	      });
	    </script>
	  </section>

  <section class="py-10 md:py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between gap-4 mb-6">
        <div>
		          <h2 class="text-2xl font-bold text-gray-900">All Collections</h2>
		          <p class="text-sm text-gray-600 mt-1">
		            Showing <span id="collections-count">{collections.length}</span> collections
		          </p>
		        </div>
		      </div>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <div class="lg:col-span-4">
          <div class="sticky top-24 space-y-4">
            <h2 class="text-xl font-semibold text-gray-900">Browse by theme</h2>
            <p class="text-sm text-gray-600">
              Collections group top projects by lifestyle, budget, and location. Open a collection to see the projects inside and compare options.
            </p>
            <ul class="text-sm text-gray-700 space-y-2">
              <li class="flex gap-2"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-700"></span><span>Luxury & premium living</span></li>
              <li class="flex gap-2"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-700"></span><span>Affordable & value homes</span></li>
              <li class="flex gap-2"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-700"></span><span>New launches & upcoming</span></li>
              <li class="flex gap-2"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-700"></span><span>Ready-to-move picks</span></li>
              <li class="flex gap-2"><span class="mt-1 w-1.5 h-1.5 rounded-full bg-primary-700"></span><span>Investment-focused projects</span></li>
            </ul>
          </div>
        </div>

	        <div class="lg:col-span-8">
	          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
		            {collections.map((col) => (
		              <CollectionCard collection={col} />
		            ))}
		          </div>
		        </div>
	      </div>
    </div>
  </section>

  <section class="py-10 md:py-14 bg-gray-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-gray-900">Collections FAQs</h2>
        <div class="mt-6 space-y-4">
          {faqs.map((faq) => (
            <details class="group rounded-xl border border-gray-200 bg-white p-4 open:shadow-sm">
              <summary class="cursor-pointer list-none font-semibold text-gray-900 flex items-start justify-between gap-3">
                <span>{faq.question}</span>
                <span class="mt-1 text-gray-400 group-open:rotate-180 transition-transform">⌄</span>
              </summary>
              <p class="mt-3 text-sm text-gray-700 leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
