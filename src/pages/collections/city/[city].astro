---
export const prerender = true;
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CollectionCard from "../../../components/CollectionCard.astro";
import { supabase } from "../../../lib/supabase";
import { buildBreadcrumbSchema } from "../../../lib/seo";
import type { GetStaticPaths } from "astro";
import type { City, Collection } from "../../../lib/types";

type Props = {
  city: City;
  collections: (Collection & { city?: any })[];
  allCities: { slug: string; name: string }[];
};

export const getStaticPaths: GetStaticPaths = async () => {
  const { data: citiesData } = await supabase
    .from("cities")
    .select("*")
    .order("name", { ascending: true });
  const cities = citiesData || [];

  const allCities = cities
    .filter((c) => c.slug && c.name)
    .map((c) => ({
      slug: String(c.slug).trim().toLowerCase(),
      name: c.name as string,
    }));

  const paths: { params: { city: string }; props: Props }[] = [];

  for (const city of cities) {
    const citySlug = String(city.slug || "")
      .trim()
      .toLowerCase();
    if (!citySlug) continue;

    const { data: collectionsData } = await supabase
      .from("collections")
      .select("*, city:cities(*)")
      .eq("city_id", city.id)
      .order("created_at", { ascending: false });

    paths.push({
      params: { city: citySlug },
      props: {
        city,
        collections: (collectionsData || []) as any,
        allCities,
      },
    });
  }

  return paths;
};

const { city, collections, allCities } = Astro.props as Props;

const cleanedSlug = String(city.slug).trim().toLowerCase();

const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: "https://homenesto.com" },
  { name: "Collections", url: "https://homenesto.com/collections" },
  {
    name: city.name,
    url: `https://homenesto.com/collections/city/${cleanedSlug}`,
  },
]);
---

<BaseLayout
  title={`Best Real Estate Collections in ${city.name} | Home Nesto`}
  description={`Explore curated property collections in ${city.name}, ${city.state || ""}. Discover luxury apartments, affordable housing, new launches, and top investment projects.`}
  canonical={`https://homenesto.com/collections/city/${cleanedSlug}`}
  jsonLd={breadcrumbSchema}
  breadcrumbs={[
    { name: "Collections", url: "/collections" },
    { name: city.name, url: `/collections/city/${cleanedSlug}` },
  ]}
>
  {/* Premium Hero Section */}
  <section
    class="relative overflow-hidden bg-[#0a1929] text-white py-16 md:py-24 border-b border-white/5"
  >
    {/* Abstract Background Accents */}
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div
        class="absolute -top-40 -right-40 w-96 h-96 bg-[#1e3a5f]/40 blur-[120px] rounded-full"
      >
      </div>
      <div
        class="absolute top-1/2 -left-40 w-80 h-80 bg-[#f97316]/10 blur-[100px] rounded-full"
      >
      </div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        {/* Main SEO Header content */}
        <div class="lg:col-span-7 space-y-6">
          <span
            class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-[#f97316]/10 text-[#f97316] border border-[#f97316]/20 uppercase tracking-wider"
          >
            Curated Local Guides
          </span>
          <h1
            class="text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight"
          >
            Property Collections <br class="hidden sm:inline" />
            <span
              class="bg-gradient-to-r from-white via-gray-200 to-[#f97316] bg-clip-text text-transparent"
            >
              in {city.name}
            </span>
          </h1>
          <p
            class="text-base md:text-lg text-gray-300 max-w-2xl leading-relaxed"
          >
            Skip the endless scrolling. Browse expertly short-listed projects
            across <strong class="text-white font-semibold">luxury</strong>, <strong
              class="text-white font-semibold">affordable</strong
            >, <strong class="text-white font-semibold">new launch</strong>, and
            high-yield <strong class="text-white font-semibold"
              >investment</strong
            > themes throughout {city.name}.
          </p>
        </div>

        {/* Interactive Filter/Switch Component */}
        <div class="lg:col-span-5 w-full">
          <div
            class="bg-[#1e3a5f]/40 backdrop-blur-md rounded-2xl p-5 md:p-6 border border-white/10 shadow-2xl shadow-black/40"
          >
            <div class="space-y-4">
              <div>
                <label
                  for="city-select"
                  class="block text-xs font-semibold text-gray-400 uppercase tracking-wider"
                >
                  Explore Another Region
                </label>
                <div class="relative mt-2">
                  <select
                    id="city-select"
                    class="w-full appearance-none rounded-xl bg-[#0a1929] text-white pl-4 pr-10 py-3.5 text-sm shadow-inner border border-white/10 focus:outline-none focus:ring-2 focus:ring-[#f97316] focus:border-transparent transition-all cursor-pointer"
                  >
                    <option value="/collections"
                      >All Cities (Global View)</option
                    >
                    {
                      allCities.map((c) => (
                        <option
                          value={`/collections/city/${c.slug}`}
                          selected={c.slug === cleanedSlug}
                        >
                          {c.name}
                        </option>
                      ))
                    }
                  </select>
                  <div
                    class="absolute inset-y-0 right-0 flex items-center pr-4 pointer-events-none text-gray-400"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </div>
                </div>
              </div>

              <div
                class="flex items-center justify-between pt-2 border-t border-white/5 text-xs"
              >
                <span class="text-gray-400">Active Listings</span>
                <span
                  class="font-mono bg-[#f97316]/20 text-[#f97316] px-2.5 py-0.5 rounded-md font-bold"
                >
                  {collections.length}
                  {collections.length === 1 ? "Collection" : "Collections"}
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Content Feed Section */}
  <section class="py-14 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* Dynamic Grid Layout */}
      {
        collections.length > 0 ? (
          <div class="space-y-8">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-gray-200 pb-5">
              <div>
                <h2 class="text-2xl font-bold text-[#0a1929]">
                  Featured Handpicks
                </h2>
                <p class="text-sm text-gray-500 mt-1">
                  Verified handpicked developments categorized by tier lifestyle
                  preferences.
                </p>
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {collections.map((col) => (
                <div class="transform hover:-translate-y-1 transition-all duration-300 ease-out">
                  <CollectionCard collection={col} />
                </div>
              ))}
            </div>
          </div>
        ) : (
          /* Enhanced Empty State Design */
          <div class="max-w-md mx-auto text-center py-16 px-4 bg-white rounded-2xl border border-gray-200 shadow-sm">
            <div class="w-16 h-16 bg-[#1e3a5f]/5 rounded-full flex items-center justify-center mx-auto text-[#1e3a5f]">
              <svg
                class="w-8 h-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                />
              </svg>
            </div>
            <h2 class="mt-5 text-xl font-bold text-[#0a1929]">
              No Collections Live Yet
            </h2>
            <p class="mt-2 text-sm text-gray-600">
              Our market analysts are building exclusive property portfolios for{" "}
              <span class="font-semibold text-gray-900">{city.name}</span>.
              Check back soon.
            </p>
            <div class="mt-6">
              <a
                href="/collections"
                class="inline-flex items-center justify-center rounded-xl bg-[#1e3a5f] hover:bg-[#0a1929] text-white px-5 py-3 text-sm font-semibold transition-all duration-200 shadow-sm shadow-[#1e3a5f]/20 hover:shadow-none"
              >
                Browse Global Architecture
              </a>
            </div>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const select = document.getElementById("city-select");
    if (select) {
      select.addEventListener("change", (e) => {
        const val = e.target.value;
        if (val) window.location.href = String(val);
      });
    }
  });
</script>
