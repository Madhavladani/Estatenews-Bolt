---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms and Conditions | PropDiscover"
  description="Read the Terms and Conditions that govern your use of the PropDiscover website and services."
>
  <section class="py-14 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Terms and Conditions</h1>
      <p class="text-sm text-gray-500 mb-8">Last updated: May 10, 2026</p>
      <div class="bg-white rounded-2xl border border-gray-100 p-6 md:p-8 space-y-6 text-gray-700 leading-relaxed">
        <p>By using PropDiscover, you agree to the following terms and conditions.</p>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Use of Website</h2>
          <p>You agree to use this website lawfully and not misuse, copy, or tamper with content and services.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Information Accuracy</h2>
          <p>We strive to provide accurate property information, but we do not guarantee completeness or real-time availability.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">No Legal Advice</h2>
          <p>Content on this site is for informational purposes only and should not be treated as legal, financial, or investment advice.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Third-Party Content</h2>
          <p>Listings, images, and links may come from third parties. We are not liable for external content or decisions made based on it.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Limitation of Liability</h2>
          <p>PropDiscover will not be liable for any direct or indirect losses resulting from the use of this website.</p>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Changes to Terms</h2>
          <p>We may revise these terms at any time. Continued use of the site means you accept the updated terms.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
