  }
  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .principal-dot {
    background: #5b9bd5;
  }
  .interest-dot {
    background: var(--accent);
  }

  .info-banner {
    margin-top: 1.5rem;
    background: var(--primary-lightest);
    border: 1px solid var(--primary-lighter);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: flex-start;
