    background: var(--primary-lightest);
  }
  .faq-item[open] summary .faq-arrow {
    background: var(--primary);
    color: #fff;
    transform: rotate(180deg);
  }
  .faq-item .faq-answer {
    padding: 0 1.2rem 1.1rem;
    font-size: 0.85rem;
    color: var(--text-medium);
    line-height: 1.65;
  }

  .footer-note {
    text-align: center;
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--text-light);
    font-weight: 500;
  }
  .footer-note a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }
  .footer-note a:hover {
    color: var(--accent);
  }

  @keyframes subtlePulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.35);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(249, 115, 22, 0);
    }
  }
  .pulse-once {
    animation: subtlePulse 1.2s ease-out 1;
  }
</style>

<script>
  // EMI Calculator Logic
  const formatINR = (value) =>
    new Intl.NumberFormat("en-IN", {
      style: "currency",
      currency: "INR",
      maximumFractionDigits: 0,
    }).format(value);

  const loanAmountInput = document.getElementById("loanAmount");
  const interestRateInput = document.getElementById("interestRate");
  const loanTenureInput = document.getElementById("loanTenure");
  const loanAmountSlider = document.getElementById("loanAmountSlider");
  const interestRateSlider = document.getElementById("interestRateSlider");
  const loanTenureSlider = document.getElementById("loanTenureSlider");
  const emiButton = document.getElementById("emiCalcBtn");
  const emiResetBtn = document.getElementById("emiResetBtn");
  const emiResult = document.getElementById("emiResult");
  const monthlyEmiText = document.getElementById("monthlyEmiText");
  const totalInterestText = document.getElementById("totalInterestText");
  const totalPayableText = document.getElementById("totalPayableText");
  const breakdownPrincipalBar = document.getElementById(
    "breakdownPrincipalBar",
  );
  const breakdownInterestBar = document.getElementById("breakdownInterestBar");
  const legendPrincipal = document.getElementById("legendPrincipal");
  const legendInterest = document.getElementById("legendInterest");
  const quickAmountChips = document.getElementById("quickAmountChips");

  const syncNumberToSlider = (num, slider, isFloat) => {
    const val = parseFloat(num.value);
    if (
      !isNaN(val) &&
      val >= parseFloat(slider.min) &&
      val <= parseFloat(slider.max)
    ) {
      slider.value = isFloat ? val.toFixed(1) : val;
    }
  };

  const syncSliderToNumber = (slider, num, isFloat) => {
    num.value = isFloat ? parseFloat(slider.value).toFixed(2) : slider.value;
  };

  const highlightChip = (amount) => {
    quickAmountChips.querySelectorAll(".chip").forEach((chip) => {
      chip.classList.toggle(
        "active",
        parseInt(chip.dataset.amount, 10) === amount,
      );
    });
  };

  const calculateEMI = () => {
    const principal = parseFloat(loanAmountInput.value) || 0;
    const annualRate = parseFloat(interestRateInput.value) || 0;
    const tenureYears = parseFloat(loanTenureInput.value) || 0;

    if (principal <= 0 || annualRate <= 0 || tenureYears <= 0) {
      emiResult.classList.remove("visible");
      return;
    }

    const monthlyRate = annualRate / 12 / 100;
    const months = Math.round(tenureYears * 12);
    let emi;
    if (monthlyRate === 0) {
      emi = principal / months;
    } else {
      const factor = Math.pow(1 + monthlyRate, months);
      emi = (principal * monthlyRate * factor) / (factor - 1);
    }

    const totalPayable = emi * months;
    const totalInterest = totalPayable - principal;
    const principalPct = (principal / totalPayable) * 100;
    const interestPct = (totalInterest / totalPayable) * 100;

    monthlyEmiText.textContent = formatINR(emi);
    totalInterestText.textContent = formatINR(totalInterest);
    totalPayableText.textContent = formatINR(totalPayable);
    breakdownPrincipalBar.style.width = principalPct + "%";
    breakdownInterestBar.style.width = interestPct + "%";
    legendPrincipal.textContent = Math.round(principalPct) + "%";
    legendInterest.textContent = Math.round(interestPct) + "%";

    emiResult.classList.add("visible");
    emiResult.classList.remove("pulse-once");
    void emiResult.offsetWidth;
    emiResult.classList.add("pulse-once");
  };

  const debounce = (fn, delay) => {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  };
  const debouncedCalculate = debounce(calculateEMI, 300);

  loanAmountInput.addEventListener("input", () => {
    syncNumberToSlider(loanAmountInput, loanAmountSlider, false);
    highlightChip(parseInt(loanAmountInput.value, 10));
    debouncedCalculate();
  });
  interestRateInput.addEventListener("input", () => {
    syncNumberToSlider(interestRateInput, interestRateSlider, true);
    debouncedCalculate();
  });
  loanTenureInput.addEventListener("input", () => {
    syncNumberToSlider(loanTenureInput, loanTenureSlider, false);
    debouncedCalculate();
  });

  loanAmountSlider.addEventListener("input", () => {
    syncSliderToNumber(loanAmountSlider, loanAmountInput, false);
    highlightChip(parseInt(loanAmountInput.value, 10));
    debouncedCalculate();
  });
  interestRateSlider.addEventListener("input", () => {
    syncSliderToNumber(interestRateSlider, interestRateInput, true);
    debouncedCalculate();
  });
  loanTenureSlider.addEventListener("input", () => {
    syncSliderToNumber(loanTenureSlider, loanTenureInput, false);
    debouncedCalculate();
  });

  emiButton.addEventListener("click", () => {
    syncNumberToSlider(loanAmountInput, loanAmountSlider, false);
    syncNumberToSlider(interestRateInput, interestRateSlider, true);
    syncNumberToSlider(loanTenureInput, loanTenureSlider, false);
    highlightChip(parseInt(loanAmountInput.value, 10));
    calculateEMI();
    if (window.innerWidth < 768 && emiResult.classList.contains("visible")) {
      emiResult.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  });

  emiResetBtn.addEventListener("click", () => {
    loanAmountInput.value = 5000000;
    interestRateInput.value = 8.5;
    loanTenureInput.value = 20;
    loanAmountSlider.value = 5000000;
    interestRateSlider.value = 8.5;
    loanTenureSlider.value = 20;
    highlightChip(5000000);
    calculateEMI();
  });

  quickAmountChips.addEventListener("click", (e) => {
    const chip = e.target.closest(".chip");
    if (!chip) return;
    const amount = parseInt(chip.dataset.amount, 10);
    loanAmountInput.value = amount;
    loanAmountSlider.value = amount;
    highlightChip(amount);
    calculateEMI();
  });

  // Initial calculation
  calculateEMI();
  highlightChip(5000000);
</script>
