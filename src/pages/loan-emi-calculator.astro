  .faq-section {
    margin-top: 2.5rem;
    background: var(--white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: 2rem 2rem 1.5rem;
    border: 1px solid var(--gray-200);
  }
  .faq-section h2 {
    font-size: 1.5rem;
    font-weight: 800;
