---
import type { Blog } from '../lib/types';

interface Props {
  article: Blog;
}

const { article } = Astro.props;
const href = `/blog/${article.slug}`;

// Reading time estimate from excerpt word count (fallback for listing page)
const text = (article.excerpt || article.meta_description || '').replace(/<[^>]*>/g, '').trim();
const estimatedWords = text.split(/\s+/).filter(Boolean).length;
// Articles on the listing page don't have full HTML; estimate ~5 min average
const readingTime = Math.max(3, Math.ceil(estimatedWords / 30));

const formattedDate = new Date(article.published_at).toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<a href={href} class="group flex flex-col bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-100 h-full">
  <div class="aspect-[16/9] bg-gray-100 overflow-hidden flex-shrink-0">
    {article.featured_image ? (
      <img
        src={article.featured_image}
        alt={`${article.title} — PropDiscover`}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300"
        loading="lazy"
        width="800"
        height="450"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-gray-300">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
  </div>

  <div class="p-5 flex flex-col flex-1">
    {/* Tag badge */}
    {article.tags?.[0] && (
      <span class="inline-block text-[11px] font-semibold px-2.5 py-0.5 rounded-full bg-blue-50 text-blue-700 mb-2 self-start">
        {article.tags[0]}
      </span>
    )}

    <h3 class="text-base font-semibold text-gray-900 group-hover:text-blue-600 transition-colors line-clamp-2 leading-snug">
      {article.title}
    </h3>

    <p class="text-sm text-gray-500 mt-2 line-clamp-2 flex-1">
      {article.excerpt || article.meta_description}
    </p>

    <div class="mt-4 flex items-center justify-between text-xs text-gray-400">
      <time datetime={article.published_at} class="font-medium">
        {formattedDate}
      </time>
      <span class="flex items-center gap-1 text-gray-400">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {readingTime} min
      </span>
    </div>
  </div>
</a>
