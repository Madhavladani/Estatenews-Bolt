---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

{/* ── Reading progress bar ── */}
<div
  id="read-progress"
  class="fixed top-0 left-0 h-[3px] w-0 bg-gradient-to-r from-blue-500 to-blue-700 z-50 transition-none"
  role="progressbar"
  aria-label="Reading progress"
></div>

{/* ── Desktop sticky share bar ── */}
<aside
  class="share-bar-desktop hidden lg:flex flex-col items-center gap-3 fixed left-4 xl:left-8 top-1/2 -translate-y-1/2 z-40"
  aria-label="Share article"
>
  <span class="text-[10px] font-semibold uppercase tracking-widest text-gray-400 [writing-mode:vertical-lr] rotate-180 mb-1">Share</span>

  <a
    href={`https://wa.me/?text=${encodedTitle}%20${encodedUrl}`}
    target="_blank" rel="noopener noreferrer"
    class="share-btn bg-white border border-gray-200 rounded-full w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-green-50 hover:border-green-400 hover:text-green-600 shadow-sm transition-all"
    aria-label="Share on WhatsApp"
    title="Share on WhatsApp"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
  </a>

  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank" rel="noopener noreferrer"
    class="share-btn bg-white border border-gray-200 rounded-full w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-gray-900 hover:border-gray-900 hover:text-white shadow-sm transition-all"
    aria-label="Share on X / Twitter"
    title="Share on X"
  >
    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.737-8.835L1.254 2.25H8.08l4.261 5.632 5.903-5.632Zm-1.161 17.52h1.833L7.084 4.126H5.117Z"/></svg>
  </a>

  <a
    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
    target="_blank" rel="noopener noreferrer"
    class="share-btn bg-white border border-gray-200 rounded-full w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-blue-50 hover:border-blue-500 hover:text-blue-600 shadow-sm transition-all"
    aria-label="Share on LinkedIn"
    title="Share on LinkedIn"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
  </a>

  <a
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
    target="_blank" rel="noopener noreferrer"
    class="share-btn bg-white border border-gray-200 rounded-full w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-blue-50 hover:border-blue-700 hover:text-blue-700 shadow-sm transition-all"
    aria-label="Share on Facebook"
    title="Share on Facebook"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
  </a>

  <button
    id="copy-link-btn"
    class="share-btn bg-white border border-gray-200 rounded-full w-9 h-9 flex items-center justify-center text-gray-500 hover:bg-gray-50 hover:border-gray-400 shadow-sm transition-all"
    aria-label="Copy link"
    title="Copy link"
  >
    <svg id="copy-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
  </button>
</aside>

{/* ── Mobile bottom share strip ── */}
<div class="lg:hidden mt-10 pt-6 border-t border-gray-100">
  <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Share this article</p>
  <div class="flex flex-wrap gap-2">
    <a href={`https://wa.me/?text=${encodedTitle}%20${encodedUrl}`} target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-200 hover:bg-green-100 transition-colors">
      WhatsApp
    </a>
    <a href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 border border-gray-200 hover:bg-gray-200 transition-colors">
      X / Twitter
    </a>
    <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer"
       class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100 transition-colors">
      LinkedIn
    </a>
  </div>
</div>

<script>
  // ── Progress bar
  const bar = document.getElementById('read-progress') as HTMLElement | null;
  if (bar) {
    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const height = document.documentElement.scrollHeight - window.innerHeight;
      const pct = height > 0 ? Math.min(100, (scrollTop / height) * 100) : 0;
      bar.style.width = `${pct}%`;
    }, { passive: true });
  }

  // ── Copy link
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const icon = document.getElementById('copy-icon');
        if (icon) {
          icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>`;
          copyBtn.classList.add('border-green-400', 'text-green-600');
          setTimeout(() => {
            icon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>`;
            copyBtn.classList.remove('border-green-400', 'text-green-600');
          }, 2000);
        }
      } catch (_) {}
    });
  }
</script>
