---
import type { Blog } from '../lib/types';

interface Props {
  article: Blog;
  class?: string;
}

const { article, class: className } = Astro.props;
const href = `/blog/${article.slug}`;

// Reading time estimate from content or excerpt
const text = (article.content_html || article.excerpt || article.meta_description || '').replace(/<[^>]*>/g, '').trim();
const estimatedWords = text.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(3, Math.ceil(estimatedWords / 200));

const formattedDate = new Date(article.published_at).toLocaleDateString('en-IN', {
  year: 'numeric',
  month: 'long',
  day: '2-digit',
});
---

<div class:list={["group relative bg-white rounded-3xl shadow-sm hover:shadow-xl transition-all duration-500 overflow-hidden border border-gray-100", className]}>
  <div class="flex flex-col lg:flex-row h-full">
    {/* Image Section */}
    <div class="lg:w-3/5 relative overflow-hidden">
      <a href={href} class="block h-full">
        {article.featured_image ? (
          <img
            src={article.featured_image}
            alt={`${article.title} — PropDiscover`}
            class="w-full h-full min-h-[300px] lg:min-h-[450px] object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
            loading="eager"
            width="1200"
            height="675"
          />
        ) : (
          <div class="w-full h-full min-h-[300px] flex items-center justify-center bg-gray-50 text-gray-300">
            <svg class="w-20 h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
      
      {/* Absolute Tag Badge */}
      {article.tags?.[0] && (
        <span class="absolute top-6 left-6 inline-block text-xs font-bold px-4 py-1.5 rounded-full bg-blue-600 text-white shadow-lg backdrop-blur-sm">
          {article.tags[0]}
        </span>
      )}
    </div>

    {/* Content Section */}
    <div class="lg:w-2/5 p-8 lg:p-12 flex flex-col justify-center">
      <div class="text-sm uppercase font-bold text-red-600 mb-4 tracking-widest">
        {article.category || article.tags?.[0] || 'Featured Article'}
      </div>

      <a href={href} class="block group/title">
        <h2 class="text-3xl lg:text-4xl font-extrabold text-gray-900 group-hover/title:text-red-700 transition-colors leading-tight mb-6">
          {article.title}
        </h2>
      </a>

      <p class="text-lg text-gray-500 leading-relaxed line-clamp-3 mb-8">
        {article.excerpt || article.meta_description}
      </p>

      <div class="mt-auto pt-6 border-t border-gray-100 flex flex-wrap items-center gap-y-2 text-sm text-gray-400 font-medium">
        <time datetime={article.published_at}>{formattedDate}</time>
        <span class="mx-3 text-gray-300">•</span>
        <span>{readingTime} min read</span>
        <span class="mx-3 text-gray-300">•</span>
        <span class="text-gray-500">By {article.author_name || 'Admin'}</span>
      </div>
    </div>
  </div>
</div>
