---
import type { Blog } from "../lib/types";

interface Props {
  article: Blog;
  class?: string;
}

const { article, class: className } = Astro.props;

const href = `/blog/${article.slug}`;

// Reading time
const text = (
  article.content_html ||
  article.excerpt ||
  article.meta_description ||
  ""
)
  .replace(/<[^>]*>/g, "")
  .trim();

const estimatedWords = text.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(3, Math.ceil(estimatedWords / 200));

const formattedDate = new Date(article.published_at).toLocaleDateString(
  "en-IN",
  {
    year: "numeric",
    month: "short",
    day: "2-digit",
  },
);
---

<div
  class:list={[
    "group relative overflow-hidden rounded-2xl bg-white",
    className,
  ]}
>
  <a href={href} class="relative block overflow-hidden rounded-2xl">
    {/* Image Wrapper */}
    <div class="relative w-full aspect-[16/9] overflow-hidden">
      {
        article.featured_image ? (
          <img
            src={article.featured_image}
            alt={article.title}
            class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
            loading="eager"
            width="1200"
            height="675"
          />
        ) : (
          <div class="absolute inset-0 bg-gray-100 flex items-center justify-center">
            <svg
              class="w-16 h-16 text-gray-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
          </div>
        )
      }

      {/* Overlay */}
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"
      >
      </div>

      {/* Content */}
      <div class="absolute bottom-0 left-0 w-full p-4 md:p-6">
        {/* Meta */}
        <div
          class="flex flex-wrap items-center gap-2 text-white/80 text-xs md:text-sm mb-2"
        >
          <span>{formattedDate}</span>
          <span>•</span>
          <span>{readingTime} min read</span>
        </div>

        {/* Title */}
        <h2
          class="text-white text-base md:text-2xl font-medium leading-snug max-w-3xl"
        >
          {article.title}
        </h2>

        {/* Author */}
        <div class="mt-4 flex items-center gap-3">
          <div
            class="w-9 h-9 rounded-full bg-white/15 backdrop-blur-md flex items-center justify-center text-white text-sm font-medium"
          >
            {(article.author?.full_name || article.author_name || "P").charAt(0)}
          </div>

          <div class="leading-tight">
            <div class="text-white text-sm font-medium">
              {article.author?.full_name || article.author_name || "Home Nesto"}
            </div>

            <div class="text-white/70 text-xs">Real Estate Insights</div>
          </div>
        </div>
      </div>
    </div>
  </a>
</div>
