---
const cities = [
  { name: "Ahmedabad", slug: "ahmedabad" },
  { name: "Surat", slug: "surat" },
  { name: "Rajkot", slug: "rajkot" },
];
const collections = [
  { title: "Top Projects in Ahmedabad", slug: "top-projects-in-ahmedabad" },
  { title: "Luxury Apartments in Surat", slug: "luxury-apartments-in-surat" },
  {
    title: "Best Commercial in Rajkot",
    slug: "best-commercial-projects-in-rajkot",
  },
  {
    title: "New Launch in Ahmedabad",
    slug: "new-launch-projects-in-ahmedabad",
  },
  { title: "Ready to Move in Surat", slug: "ready-to-move-in-surat" },
];
---

<footer class="bg-primary-800 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
      <div>
        <a
          href="/"
          class="flex items-center gap-2 text-xl font-bold text-white mb-4"
        >
          <img
            src="/Nestosve.svg"
            alt="Home Nesto Logo"
            class="h-8 w-auto transform transition-transform duration-300 group-hover:scale-110"
            width="32"
            height="32"
          />
          <span>Home <span class="text-accent-500">Nesto</span></span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-6">
          Discover the best residential and commercial real estate projects
          across Gujarat. Your trusted property discovery platform.
        </p>
        <div class="flex gap-4">
          <a href="https://www.facebook.com/homenesto" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-primary-700/50 flex items-center justify-center text-gray-400 hover:bg-accent-500 hover:text-white transition-all duration-300" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://x.com/homenesto" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-primary-700/50 flex items-center justify-center text-gray-400 hover:bg-accent-500 hover:text-white transition-all duration-300" aria-label="Twitter">
             <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218H13.6823ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z" />
            </svg>
          </a>
          <a href="https://www.instagram.com/home_nesto" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-primary-700/50 flex items-center justify-center text-gray-400 hover:bg-accent-500 hover:text-white transition-all duration-300" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.012 3.82.058 1.036.045 1.86.209 2.514.463a4.923 4.923 0 011.667 1.086 4.924 4.924 0 011.086 1.667c.254.653.418 1.477.463 2.514.047 1.036.058 1.39.058 3.82 0 2.43-.012 2.784-.058 3.82-.045 1.036-.209 1.86-.463 2.514a4.923 4.923 0 01-1.086 1.667 4.924 4.924 0 01-1.667 1.086c-.653.254-1.477.418-2.514.463-1.036.047-1.39.058-3.82.058-2.43 0-2.784-.012-3.82-.058-1.036-.045-1.86-.209-2.514-.463a4.923 4.923 0 01-1.667-1.086 4.924 4.924 0 01-1.086-1.667c-.254-.653-.418-1.477-.463-2.514C2.012 14.816 2 14.462 2 12.031c0-2.43.012-2.784.058-3.82.045-1.036.209-1.86.463-2.514a4.923 4.923 0 011.086-1.667 4.923 4.923 0 011.667-1.086c.653-.254 1.477-.418 2.514-.463C8.548 2.012 8.903 2 11.334 2h.981zm1.284 1.88c-1.025-.046-1.346-.056-3.791-.056s-2.766.01-3.791.056c-1.01.046-1.553.208-1.917.35a3.045 3.045 0 00-1.134.738 3.045 3.045 0 00-.738 1.134c-.142.364-.304.907-.35 1.917-.046 1.025-.056 1.346-.056 3.791s.01 2.766.056 3.791c.046 1.01.208 1.553.35 1.917.184.47.41.865.738 1.134.27.268.664.494 1.134.738.364.142.907.304 1.917.35 1.024.046 1.346.056 3.791.056s2.765-.01 3.791-.056c1.01-.046 1.553-.208 1.917-.35a3.045 3.045 0 001.134-.738c.268-.27.494-.664.738-1.134.142-.364.304-.907.35-1.917.046-1.025.056-1.346.056-3.791s-.01-2.766-.056-3.791c-.046-1.01-.208-1.553-.35-1.917a3.045 3.045 0 00-.738-1.134 3.045 3.045 0 00-1.134-.738c-.364-.142-.907-.304-1.917-.35zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16.3a4.3 4.3 0 110-8.6 4.3 4.3 0 010 8.6zm7.391-9.923a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/home-nesto/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-primary-700/50 flex items-center justify-center text-gray-400 hover:bg-accent-500 hover:text-white transition-all duration-300" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Cities</h3>
        <ul class="space-y-2">
          {
            cities.map((city) => (
              <li>
                <a
                  href={city.slug ? `/${city.slug}/` : '#'}
                  class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
                >
                  {city.name} Properties
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Project Types</h3>
        <ul class="space-y-2">
          {
            cities.map((city) => (
              <li>
                <a
                  href={city.slug ? `/${city.slug}/residential/` : '#'}
                  class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
                >
                  {city.name} Residential
                </a>
              </li>
            ))
          }
          {
            cities.map((city) => (
              <li>
                <a
                  href={city.slug ? `/${city.slug}/commercial/` : '#'}
                  class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
                >
                  {city.name} Commercial
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Collections</h3>
        <ul class="space-y-2">
          {
            collections.map((col) => (
              <li>
                <a
                  href={col.slug ? `/collections/${col.slug}/` : '#'}
                  class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
                >
                  {col.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="/about-us/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >About Us</a
            >
          </li>
          <li>
            <a
              href="/contact-us/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >Contact Us</a
            >
          </li>
          <li>
            <a
              href="/buying-guide/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >Buying Guide</a
            >
          </li>
          <li>
            <a
              href="/properties-roi-calculator/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >Properties ROI Calculator</a
            >
          </li>
          <li>
            <a
              href="/loan-emi-calculator/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >Loan EMI Calculator</a
            >
          </li>
          <li>
            <a
              href="/list-your-project-properties/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >List Your Project / Properties</a
            >
          </li>
          <li>
            <a
              href="/advertise-with-us/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >Advertise With Us</a
            >
          </li>
          <li>
            <a
              href="/tools/"
              class="text-sm text-gray-400 hover:text-accent-400 transition-colors"
              >Tools</a
            >
          </li>
        </ul>
      </div>
    </div>
    <div
      class="border-t border-primary-700 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Home Nesto. All rights reserved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/disclaimer/"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
          >Disclaimer</a
        >
        <a
          href="/editorial-policy/"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
          >Editorial Policy</a
        >
        <a
          href="/verification-process/"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
          >Verification Process</a
        >
        <a
          href="/privacy-policy/"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
          >Privacy Policy</a
        >
        <a
          href="/terms-and-conditions/"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
          >Terms and Conditions</a
        >
        <a
          href="/careers/"
          class="text-sm text-gray-500 hover:text-gray-300 transition-colors"
          >Careers</a
        >
      </div>
    </div>
  </div>
</footer>
