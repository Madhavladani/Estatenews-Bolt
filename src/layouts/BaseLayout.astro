---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { normalizeSiteUrl, toSiteUrl } from "../lib/site-url";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  jsonLd?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  noindex?: boolean;
  prevUrl?: string;
  nextUrl?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  // Article / News SEO extras
  keywords?: string;
  heroImagePreload?: string;
  ogType?: "website" | "article";
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleTags?: string[];
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogImageAlt,
  jsonLd,
  breadcrumbs,
  noindex = false,
  prevUrl,
  nextUrl,
  showHeader = true,
  showFooter = true,
  keywords,
  heroImagePreload,
  ogType = "website",
  articlePublishedTime,
  articleModifiedTime,
  articleTags = [],
} = Astro.props;
const ogAlt = ogImageAlt || title;
const pageUrl = canonical ? normalizeSiteUrl(canonical) : toSiteUrl(Astro.url.pathname);
const og = ogImage || `https://homenesto.com/api/og?title=${encodeURIComponent(title)}`;
const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const isAdminRoute = Astro.url.pathname.startsWith("/admin");
const isLocalhost = ["localhost", "127.0.0.1"].includes(Astro.url.hostname);
const isProduction = import.meta.env.PROD;
const shouldLoadAnalytics = isProduction && !isAdminRoute && !isLocalhost;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta
      name="robots"
      content={noindex
        ? "noindex, nofollow"
        : "index, follow, max-image-preview:large"}
    />
    <link rel="canonical" href={pageUrl} />
    {
      heroImagePreload && (
        <link rel="preload" as="image" href={heroImagePreload} />
      )
    }
    {prevUrl && <link rel="prev" href={toSiteUrl(prevUrl)} />}
    {nextUrl && <link rel="next" href={toSiteUrl(nextUrl)} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={og} />
    <meta property="og:image:alt" content={ogAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:site_name" content="Home Nesto" />
    <meta property="og:type" content={ogType} />
    {
      ogType === "article" && articlePublishedTime && (
        <meta
          property="article:published_time"
          content={articlePublishedTime}
        />
      )
    }
    {
      ogType === "article" && articleModifiedTime && (
        <meta property="article:modified_time" content={articleModifiedTime} />
      )
    }
    {
      ogType === "article" &&
        articleTags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    {
      jsonLdArray.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    {shouldLoadAnalytics && (
      <>
        <!-- Google tag (gtag.js) -->
        <script
          is:inline
          async
          src="https://www.googletagmanager.com/gtag/js?id=G-XR38DT3DD5"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag("js", new Date());

          gtag("config", "G-XR38DT3DD5");
        </script>
      </>
    )}
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    {showHeader && <Header />}
    {breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
    <main>
      <slot />
    </main>
    {showFooter && <Footer />}

    <!-- === REMOVE THIS BLOCK AFTER TESTING CLOUDFLARE CACHE === -->
    <script is:inline>
      async function logCacheStatus() {
        try {
          const res = await fetch(window.location.href, {
            method: "HEAD",
            cache: "no-store",
          });
          const status = res.headers.get("cf-cache-status");
          if (status) {
            console.log("%c" + status);
          } else {
            console.log(
              "No cf-cache-status header found (might be local or not via CF).",
            );
          }
        } catch (e) {}
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", logCacheStatus);
      } else {
        logCacheStatus();
      }
      // Re-run for Astro view transitions just in case
      document.addEventListener("astro:page-load", logCacheStatus);
    </script>
    <!-- === END CLOUDFLARE CACHE TESTING BLOCK === -->
  </body>
</html>
